---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import Button from '../components/ui/Button.astro';
import FinalCTA from '../components/global/FinalCTA.astro';
import JourneyTimelineDesktop from '../components/services/JourneyTimelineDesktop.astro';
import JourneyTimelineMobile from '../components/services/JourneyTimelineMobile.astro';
import { Image } from 'astro:assets';

import portraitImage from '../assets/images/about/akash-portrait.jpg';
import travelMadeiraImage from '../assets/images/about/travel-madeira.jpg';
import site from '../data/site.json';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${site.url}/about#person`,
  name: 'Akash Desai',
  alternateName: 'Kash',
  givenName: 'Akash',
  familyName: 'Desai',
  jobTitle: 'Photographer & Videographer',
  description:
    'Toronto-based wedding and pre-wedding photographer and videographer. Solo practice focused on intimate, unhurried ceremonies and cinematic editorial storytelling.',
  image: `${site.url}/og-default.jpg`,
  url: `${site.url}/about/`,
  worksFor: { '@id': `${site.url}/#business` },
  knowsAbout: [
    'Wedding photography',
    'Pre-wedding photography',
    'Civil ceremony photography',
    'Wedding videography',
    'Cinematic editorial portraiture',
  ],
  sameAs: [site.social.instagram, site.social.pinterest, site.social.youtube],
};

const aboutJourneySteps = [
  {
    label: 'Step 01',
    title: 'A real hello, no scripts.',
    body: 'I start with a free consultation. No pressure. Just a real conversation about who you are, what you are celebrating, and how you want to remember it.',
    hint: '30-minute call · no obligation',
  },
  {
    label: 'Step 02',
    title: 'Every detail, handled.',
    body: 'I take care of locations, timing, and creative direction. You will get a curated mood board and a clear plan, so you know exactly what to expect. All you need to do is show up.',
    hint: 'Mood board · shot list · timeline',
  },
  {
    label: 'Step 03',
    title: 'Prompting, never posing.',
    body: 'On the day, I guide you through natural prompts and movements. No stiff poses. The energy stays calm, unhurried, and focused on the two of you.',
    hint: 'Calm over performance · real reactions',
  },
  {
    label: 'Step 04',
    title: 'A gallery, carefully kept.',
    body: 'Your gallery is hand-edited, colour-graded, and delivered within 1 to 3 weeks through a private online gallery. Every image is treated with the same care.',
    hint: 'Private gallery · 1 to 3 week turnaround',
  },
];
---

<BaseLayout
  title="About Kash | Toronto Wedding Photographer"
  description="Meet Kash, the photographer behind AD Photography. Based in Toronto, specializing in cinematic wedding and pre-wedding photography with a Fujifilm system."
  jsonLd={personSchema}
>
  <!-- Hero -->
  <section class="container-editorial" style="padding-top: var(--spacing-section);">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'About Kash', href: '/about/' },
    ]} />

    <p class="text-label-md text-on-surface-muted reveal eyebrow-rule" style="margin-top: var(--spacing-block);">About Kash</p>
    <h1 class="text-display-lg reveal stagger-1 about-hero-title" style="margin-top: var(--spacing-element); max-width: 22ch;">
      <span class="block">Kash,</span>
      <span class="block">Toronto Wedding Photographer</span>
      <span class="block text-body-lg italic text-on-surface-variant" style="margin-top: var(--spacing-element); letter-spacing: 0; font-weight: 400;">
        Cinematic, honest, unhurried. A solo eye behind every frame.
      </span>
    </h1>
  </section>

  <!-- Bio + Portrait -->
  <section class="container-editorial" style="padding-top: var(--spacing-block);">
    <div class="grid-editorial items-start">
      <div class="col-span-12 md:col-span-5 order-2 md:order-1">
        <p class="text-label-md text-on-surface-muted reveal eyebrow-rule" style="margin-bottom: var(--spacing-element);">Meet Kash</p>
        <div class="bio-expand reveal stagger-1" data-expanded="false">
          <p class="bio-teaser text-body-lg text-on-surface-variant">
            Toronto-based solo photographer and videographer. Intimate, unhurried weddings shot with a cinematic, editorial eye.
            Prompting over posing. Calm over performance. Your photos should feel like <em>you</em>.
          </p>
          <div class="bio-full" style="display: flex; flex-direction: column; gap: var(--spacing-element);">
            <p class="text-body-lg text-on-surface-variant">
              I am a Toronto-based wedding and pre-wedding photographer and videographer, and the founder of AD Photography.
              What started as a love for capturing candid moments has grown into a full creative practice built around one idea:
              your photos should feel like <em>you</em>.
            </p>
            <p class="text-body-lg text-on-surface-variant">
              Fujifilm has been my camera for photos since the beginning. I love it for the colours, the tones, the way it
              renders skin. Video lives on Sony, and lately I have been reaching for Sony for stills too. My style is
              cinematic and editorial but never stiff. I believe in prompting, not posing: guiding you through natural
              movements and real moments instead of asking you to hold a smile for the camera.
            </p>
            <p class="text-body-lg text-on-surface-variant">
              I work solo. That is a deliberate choice. One photographer, one calm voice, a single point of view running
              through every frame. My best work lives in unhurried, intimate celebrations: church ceremonies, backyard
              vows, close-knit receptions. Smaller rooms, closer people, more considered frames.
            </p>
            <p class="text-body-lg text-on-surface-variant">
              Between you and me, I do not love being on the other side of the lens either. I know exactly how it feels to
              stand in front of a camera and be asked to relax. That understanding shapes everything: the prompting, the
              calm direction, the space to just be. When the story calls for it, I travel too. Across Ontario and beyond.
              Because where matters.
            </p>
            <p class="text-body-lg text-on-surface-variant">
              Every session starts with a conversation. I want to know who you are, what matters to you, and how you want to
              remember this chapter. From there, I handle the planning: locations, timing, creative direction. So you can
              just show up and be present.
            </p>
          </div>
          <button type="button" class="bio-toggle" aria-expanded="false">
            Read more
          </button>
        </div>
      </div>
      <figure class="col-span-12 md:col-span-6 md:col-start-7 order-1 md:order-2 reveal-right stagger-2 mb-[var(--spacing-element)] md:mb-0">
        <div class="aspect-[3/4] overflow-hidden">
          <Image
            src={portraitImage}
            alt="Portrait of AD, Toronto wedding photographer and founder of AD Photography"
            widths={[400, 600, 800, 1000]}
            sizes="(max-width: 639px) 100vw, 50vw"
            format="avif"
            quality={75}
            class="w-full h-full object-cover object-bottom parallax-img"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <figcaption class="gallery-plaque">
          <div class="gallery-plaque__line">
            <span class="gallery-plaque__plate">Portrait</span>
            <span class="gallery-plaque__rule" aria-hidden="true"></span>
            <span class="gallery-plaque__meta">Toledo, Spain</span>
          </div>
          <p class="gallery-plaque__title"><em>Akash</em></p>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- Approach Pillars -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <p class="text-label-md text-on-surface-muted reveal eyebrow-rule">The Approach</p>

      <div class="grid grid-cols-1 md:grid-cols-3 reveal stagger-1" style="margin-top: var(--spacing-block); gap: var(--spacing-block);">
        <div>
          <h2 class="text-heading-lg italic">The Curated Frame</h2>
          <p class="text-body-md text-on-surface-variant" style="margin-top: var(--spacing-element); max-width: 38ch;">
            Every image is a deliberate composition. I look for geometry, negative space, and the interplay of light and shadow to build frames that feel considered and quiet.
          </p>
        </div>
        <div>
          <h2 class="text-heading-lg italic">Natural Luminosity</h2>
          <p class="text-body-md text-on-surface-variant" style="margin-top: var(--spacing-element); max-width: 38ch;">
            Light is the foundation. I chase soft window light, golden hour warmth, and the gentle diffusion of overcast skies. The goal is always warmth without harshness.
          </p>
        </div>
        <div>
          <h2 class="text-heading-lg italic">Timeless Aesthetic</h2>
          <p class="text-body-md text-on-surface-variant" style="margin-top: var(--spacing-element); max-width: 38ch;">
            No trends, no heavy filters. The editing is clean and warm, built to age beautifully. These photos should look just as compelling in twenty years as they do today.
          </p>
        </div>
      </div>
    </div>
  </section>

  <JourneyTimelineDesktop
    steps={aboutJourneySteps}
    eyebrow="My Process"
    title="How It Works"
    intro="Four steps, no surprises. From the first message to the final gallery, here is exactly what to expect."
  />
  <JourneyTimelineMobile
    steps={aboutJourneySteps}
    eyebrow="My Process"
    title="How It Works"
    intro="Four steps, no surprises. From the first message to the final gallery, here is exactly what to expect."
  />

  <!-- Travel Teaser -->
  <section class="bg-surface" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-center">
        <div class="col-span-12 md:col-span-4 reveal">
          <p class="text-label-md text-on-surface-muted eyebrow-rule">Off The Clock</p>
          <h2 class="text-display-md" style="margin-top: var(--spacing-element);">The Traveling Eye</h2>
          <p class="text-body-lg text-on-surface-variant mt-4" style="max-width: 42ch;">
            When I am not shooting someone else's story, I am chasing my own. Light, architecture, strangers, cities.
            The same eye, off the clock. A small travel log, coming soon.
          </p>

          <form
            class="travel-notify reveal stagger-2"
            action="https://script.google.com/macros/s/AKfycbw5c2bxZOPov3y9XUgSWZdTmAhwZM9k2E5BBr9AJDiWGp2rDded_RYYrsVaq-HWm7VepQ/exec"
            method="POST"
            data-travel-notify
          >
            <input type="hidden" name="_subject" value="Travel Log signup" />
            <input type="hidden" name="list" value="travel-log" />
            <label for="travel-notify-email" class="text-label-sm text-on-surface-muted" style="letter-spacing: 0.12em; text-transform: uppercase;">
              Know when it's live
            </label>
            <div class="travel-notify-row">
              <input
                id="travel-notify-email"
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="your@email.com"
                class="travel-notify-input"
              />
              <button type="submit" class="travel-notify-submit logo-mark" aria-label="Notify me when travel log is live">
                Notify Me
              </button>
            </div>
            <p class="travel-notify-note text-label-sm text-on-surface-muted" data-notify-note>
              One email when the log goes live. No other list.
            </p>
          </form>
        </div>
        <figure class="travel-collage col-span-12 md:col-span-7 md:col-start-6 reveal-right stagger-2">
          <div class="collage-main">
            <Image
              src={travelMadeiraImage}
              alt="Travel photograph from Madeira, Portugal by AD Photography"
              widths={[640, 960, 1280, 1600]}
              sizes="(max-width: 768px) 100vw, 45vw"
              format="avif"
              quality={80}
              class="w-full h-full object-cover parallax-img"
              loading="lazy"
            />
          </div>
          <figcaption class="gallery-plaque">
            <div class="gallery-plaque__line">
              <span class="gallery-plaque__plate">Travel Log</span>
              <span class="gallery-plaque__rule" aria-hidden="true"></span>
              <span class="gallery-plaque__meta">Coming Soon</span>
            </div>
            <p class="gallery-plaque__title"><em>Madeira</em>, Portugal</p>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ═══ BREAKER · COUNTRIES VISITED ═══
       Horizontal marquee closes the "Traveling Eye" beat: one frame above
       (Madeira), the full list of countries the eye has moved through below. -->
  <section aria-label="Countries I have visited" style="padding-top: var(--spacing-block); padding-bottom: var(--spacing-block);">
    <div class="container-editorial" style="margin-bottom: var(--spacing-element);">
      <p class="text-label-md text-on-surface-muted eyebrow-rule eyebrow-rule-center text-center reveal">
        Countries Visited
      </p>
    </div>
    <div class="breaker-marquee">
      <div class="breaker-marquee__track" aria-hidden="true">
        <div class="breaker-marquee__set">
          <span>Morocco</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Spain</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Greece</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Italy</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Portugal</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Mexico</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Thailand</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Singapore</span>
          <span class="breaker-marquee__dot">·</span>
        </div>
        <div class="breaker-marquee__set">
          <span>Morocco</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Spain</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Greece</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Italy</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Portugal</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Mexico</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Thailand</span>
          <span class="breaker-marquee__dot">·</span>
          <span>Singapore</span>
          <span class="breaker-marquee__dot">·</span>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA
    title="Let's find the light."
    body="Every session starts with a conversation. Tell me about your vision and I will build something beautiful with you."
    ctaLabel="Start the Conversation"
    background="surface-dim"
  />
</BaseLayout>

<style>
  /* About hero title: smaller mobile font so "Toronto Wedding Photographer"
     doesn't break awkwardly on a 375-430px viewport. */
  @media (max-width: 640px) {
    .about-hero-title {
      font-size: clamp(2.25rem, 10vw, 2.75rem);
      line-height: 1.08;
      letter-spacing: -0.015em;
    }
  }

  /* Process zig-zag timeline */
  .process-wrap {
    position: relative;
  }
  .process-path {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-on-surface-muted);
    pointer-events: none;
    z-index: 0;
  }
  .process-path-line {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 2400ms var(--ease-gallery);
  }
  .process-wrap.revealed .process-path-line {
    stroke-dashoffset: 0;
  }

  .process-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 3rem;
    row-gap: calc(var(--spacing-block) * 0.75);
  }
  .process-step {
    position: relative;
    min-height: 180px;
    padding: 1.25rem 0;
  }
  .step-left {
    grid-column: 1 / 2;
    padding-right: 1.5rem;
  }
  .step-right {
    grid-column: 2 / 3;
    padding-left: 1.5rem;
  }

  .process-kicker {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-on-surface-muted);
    margin-bottom: var(--spacing-element);
  }
  .process-meta {
    margin-top: var(--spacing-element);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 767px) {
    .process-path { display: none; }
    .process-steps {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-block);
    }
    .process-step { min-height: 0; padding: 0; }
    .step-left, .step-right {
      grid-column: auto;
      padding-left: 0;
      padding-right: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-path-line { transition: none; stroke-dashoffset: 0; }
  }

  /* Travel collage — flat editorial print, plaque below frames the image. */
  .travel-collage {
    position: relative;
    margin: 0;
  }
  .collage-main {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }


  /* Travel log email signup */
  .travel-notify {
    margin-top: var(--spacing-block);
    max-width: 32rem;
  }
  .travel-notify-row {
    display: flex;
    align-items: stretch;
    margin-top: 0.75rem;
    border-bottom: 1px solid var(--color-on-surface);
  }
  .travel-notify-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 0;
    padding: 0.75rem 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-on-surface);
    outline: none;
  }
  .travel-notify-input::placeholder {
    color: var(--color-on-surface-muted);
  }
  .travel-notify-submit {
    background: transparent;
    border: 0;
    padding: 0.75rem 0 0.75rem 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-on-surface);
    cursor: pointer;
    white-space: nowrap;
    transition: color 500ms var(--ease-gallery);
  }
  .travel-notify-submit:hover {
    color: var(--color-on-surface-variant);
  }
  .travel-notify-note {
    margin-top: 0.75rem;
    font-style: italic;
    letter-spacing: 0;
    text-transform: none;
  }
  .travel-notify[data-state="submitting"] .travel-notify-submit { opacity: 0.6; cursor: wait; }
  .travel-notify[data-state="success"] .travel-notify-row { display: none; }
  .travel-notify[data-state="success"] label { display: none; }

  .bio-expand { padding-bottom: var(--spacing-block); }
  .bio-teaser { display: none; }
  .bio-toggle { display: none; }

  @media (max-width: 767px) {
    .bio-teaser { display: block; }
    .bio-toggle {
      display: inline-block;
      margin-top: var(--spacing-element);
      padding-bottom: 4px;
      border-bottom: 1px solid var(--color-on-surface);
      font-family: var(--font-sans);
      font-size: 0.8125rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-on-surface);
      background: transparent;
      cursor: pointer;
      transition: color 500ms var(--ease-gallery), border-color 500ms var(--ease-gallery);
    }
    .bio-toggle:hover {
      color: var(--color-on-surface-variant);
      border-color: var(--color-on-surface-variant);
    }
    .bio-expand[data-expanded="false"] .bio-full { display: none; }
    .bio-expand[data-expanded="true"] .bio-teaser { display: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.bio-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const wrapper = btn.closest('.bio-expand');
      if (!wrapper) return;
      const expanded = wrapper.getAttribute('data-expanded') === 'true';
      const next = (!expanded).toString();
      wrapper.setAttribute('data-expanded', next);
      btn.setAttribute('aria-expanded', next);
      btn.textContent = expanded ? 'Read more' : 'Read less';
    });
  });

  function initTravelNotify() {
    document.querySelectorAll<HTMLFormElement>('[data-travel-notify]').forEach((form) => {
      if (form.dataset.notifyBound === 'true') return;
      form.dataset.notifyBound = 'true';
      const note = form.querySelector<HTMLElement>('[data-notify-note]');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        form.setAttribute('data-state', 'submitting');
        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          if (res.ok) {
            form.setAttribute('data-state', 'success');
            if (note) note.textContent = "You're on the list. I'll send one email when the log goes live.";
          } else {
            form.setAttribute('data-state', 'error');
            if (note) note.textContent = "Something went sideways. Try emailing info@kashklicks.ca instead.";
          }
        } catch {
          form.setAttribute('data-state', 'error');
          if (note) note.textContent = "Something went sideways. Try emailing info@kashklicks.ca instead.";
        }
      });
    });
  }
  initTravelNotify();
  document.addEventListener('astro:after-swap', initTravelNotify);
</script>
