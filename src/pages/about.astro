---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import Button from '../components/ui/Button.astro';
import { Image } from 'astro:assets';

import portraitImage from '../assets/images/about/akash-portrait.jpg';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Akash',
  jobTitle: 'Wedding Photographer & Videographer',
  worksFor: {
    '@type': 'LocalBusiness',
    name: 'KashKlicks Studios',
  },
  url: 'https://kashklicks.ca/about',
  sameAs: ['https://instagram.com/kash.klicks'],
};
---

<BaseLayout
  title="About"
  description="Meet Akash, the photographer behind KashKlicks Studios. Based in Toronto, specializing in cinematic wedding and pre-wedding photography with a Fujifilm system."
  jsonLd={personSchema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'About', href: '/about' },
    ]} />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Portrait -->
      <div class="relative">
        <!-- TODO: Replace with real content -->
        <Image
          src={portraitImage}
          alt="Akash — photographer and founder of KashKlicks Studios"
          widths={[400, 600, 800]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          class="w-full rounded-lg"
          loading="eager"
        />
      </div>

      <!-- Content -->
      <div>
        <p class="text-accent text-sm tracking-[0.2em] uppercase mb-4">The Photographer</p>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-text-primary">Hey, I'm Akash.</h1>

        <div class="mt-8 space-y-6 text-text-secondary leading-relaxed">
          <p>
            I'm a Toronto-based wedding and pre-wedding photographer and videographer, and the founder of KashKlicks Studios.
            What started as a love for capturing candid moments has grown into a full creative practice built around one idea:
            your photos should feel like <em>you</em>.
          </p>
          <p>
            I shoot with Fujifilm — for the colours, the tones, and the way it renders skin. My style is cinematic and editorial
            but never stiff. I believe in <strong>prompting, not posing</strong> — guiding you through natural movements and real
            moments instead of asking you to hold a smile for the camera.
          </p>
          <p>
            South Asian weddings hold a special place in my work. The colours, the energy, the emotion — there's nothing quite
            like it. But whether it's a pre-wedding session at Scarborough Bluffs or a civil ceremony downtown, I bring the same
            calm direction, attention to light, and commitment to telling your story honestly.
          </p>
          <p>
            Every session starts with a conversation. I want to know who you are, what matters to you, and how you want to
            remember this chapter. From there, I handle the planning — locations, timing, creative direction — so you can
            just show up and be present.
          </p>
        </div>

        <div class="mt-10 flex flex-wrap gap-4">
          <Button href="/portfolio" variant="outline">See My Work</Button>
          <Button href="/contact" variant="primary">Let's Connect</Button>
        </div>
      </div>
    </div>

    <!-- Philosophy Section -->
    <section class="mt-24 max-w-4xl mx-auto text-center">
      <h2 class="font-heading text-3xl font-bold text-text-primary mb-8">How I Work</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div class="bg-bg-card border border-border rounded-lg p-8">
          <h3 class="font-heading text-xl font-bold text-accent mb-3">Effortless</h3>
          <p class="text-text-secondary text-sm">No awkward posing. Just natural guidance, real moments, and photos that feel like you.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-lg p-8">
          <h3 class="font-heading text-xl font-bold text-accent mb-3">Honest</h3>
          <p class="text-text-secondary text-sm">I capture what's real. The laughter, the quiet glances, the in-between moments that matter most.</p>
        </div>
        <div class="bg-bg-card border border-border rounded-lg p-8">
          <h3 class="font-heading text-xl font-bold text-accent mb-3">Cinematic</h3>
          <p class="text-text-secondary text-sm">Beautiful light, intentional composition, and timeless editing that elevates every frame.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
