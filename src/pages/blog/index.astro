---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Tips, guides, and behind-the-scenes stories from AD Photography. Wedding planning advice, Toronto location guides, and photography inspiration."
>
  <div class="container-editorial" style="padding-top: var(--spacing-block); padding-bottom: var(--spacing-section);">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog' },
    ]} />

    <header class="max-w-3xl" style="margin-bottom: var(--spacing-block);">
      <h1 class="text-display-md reveal stagger-1">Stories & Guides</h1>
      <p class="text-body-lg text-on-surface-variant mt-4 reveal stagger-2" style="max-width: 55ch;">
        Tips, location guides, and behind-the-scenes from our sessions.
      </p>
    </header>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}`} class="group block reveal" style={`transition-delay: ${(i % 3) * 100 + 100}ms;`}>
            <article>
              {post.data.coverImage ? (
                <div class="aspect-[3/2] overflow-hidden bg-surface-dim">
                  <Image
                    src={post.data.coverImage}
                    alt={post.data.coverImageAlt}
                    widths={[400, 600]}
                    sizes="(max-width: 768px) 100vw, 33vw"
                    loading="lazy"
                    class="w-full h-full object-cover cubic-ease group-hover:scale-[1.02]"
                    style="transition-duration: var(--duration-slow);"
                  />
                </div>
              ) : (
                <div class="aspect-[3/2] bg-surface-dim" />
              )}
              <div class="mt-4">
                <div class="flex items-center gap-3 text-label-sm text-on-surface-muted mb-3">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {post.data.tags.length > 0 && (
                    <>
                      <span aria-hidden="true">/</span>
                      <span>{post.data.tags[0]}</span>
                    </>
                  )}
                </div>
                <h2 class="text-heading-md group-hover:text-on-surface-variant cubic-ease" style="transition-duration: var(--duration-hover);">
                  {post.data.title}
                </h2>
                <p class="text-body-lg text-on-surface-variant mt-2 line-clamp-3" style="max-width: 45ch;">
                  {post.data.description}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-body-lg text-on-surface-muted py-12">Blog posts coming soon. Check back for tips, guides, and behind-the-scenes stories.</p>
    )}
  </div>
</BaseLayout>
