---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Tips, guides, and behind-the-scenes stories from KashKlicks Studios. Wedding planning advice, Toronto location guides, and photography inspiration."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog' },
    ]} />

    <SectionHeading
      title="Stories & Guides"
      subtitle="Tips, location guides, and behind-the-scenes from our sessions"
    />

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group block">
            <article class="bg-bg-card border border-border rounded-lg overflow-hidden hover:border-border-hover transition-colors">
              <div class="aspect-[16/9] bg-bg-elevated" />
              <div class="p-6">
                <div class="flex items-center gap-3 text-xs text-text-muted mb-3">
                  <time datetime={post.data.publishDate.toISOString()}>
                    {post.data.publishDate.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {post.data.tags.length > 0 && (
                    <>
                      <span>·</span>
                      <span class="text-accent">{post.data.tags[0]}</span>
                    </>
                  )}
                </div>
                <h2 class="font-heading text-xl font-bold text-text-primary group-hover:text-accent transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm text-text-secondary line-clamp-3">
                  {post.data.description}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-center text-text-muted py-12">Blog posts coming soon — check back for tips, guides, and behind-the-scenes stories.</p>
    )}
  </div>
</BaseLayout>
