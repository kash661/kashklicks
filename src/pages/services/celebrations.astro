---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PricingCard from '../../components/ui/PricingCard.astro';
import PackageAddOns from '../../components/ui/PackageAddOns.astro';
import FAQAccordion from '../../components/ui/FAQAccordion.astro';
import Button from '../../components/ui/Button.astro';
import BookingLink from '../../components/ui/BookingLink.astro';
import ShareButton from '../../components/ui/ShareButton.astro';
import PortfolioFinalCTA from '../../components/global/PortfolioFinalCTA.astro';
import ContactModal from '../../components/global/ContactModal.astro';
import FloatingPackagesLink from '../../components/global/FloatingPackagesLink.astro';
import { Image } from 'astro:assets';
import JourneyTimelineDesktop from '../../components/services/JourneyTimelineDesktop.astro';
import JourneyTimelineMobile from '../../components/services/JourneyTimelineMobile.astro';

import packages from '../../data/packages.json';
import faqData from '../../data/faq.json';
import site from '../../data/site.json';

import heroImage from '../../assets/images/homepage/celebrations-hero.jpg';
import serviceDetailImage from '../../assets/images/homepage/celebrations-service-detail.jpg';
import momentImage from '../../assets/images/homepage/celebrations-moment.jpg';
import ctaImage from '../../assets/images/homepage/celebrations-cta.jpg';

const celebrationsJourneySteps = [
  {
    label: 'Step 01',
    title: 'Book a Consultation',
    body: "Tell me about your event. A free, no-obligation call to talk through the details and make sure I'm the right fit.",
  },
  {
    label: 'Step 02',
    title: 'Planning Together',
    body: 'I go over timing, the venue, coverage needs, and the must-have moments you want preserved. No detail is too small.',
  },
  {
    label: 'Step 03',
    title: 'Your Event',
    body: 'I blend in and capture everything naturally. Candid moments, group shots, decor details. You enjoy the celebration. I handle the memories.',
  },
  {
    label: 'Step 04',
    title: 'Full Delivery',
    body: 'Your complete gallery delivered within 2 weeks. Private online gallery, yours to keep and share.',
  },
];

const eventPackages = packages.filter((p) => p.category === 'Events').sort((a, b) => a.order - b.order);
const eventFaq = faqData.filter((q: any) => !q.services || q.services.includes('celebrations'));

const celebrationsService = {
  title: 'Events & Celebrations',
  description: 'Birthdays, bridal showers, baby showers, corporate events. Every gathering has moments worth preserving. My event coverage is relaxed, natural, and designed to capture the energy of your celebration.',
  includes: [
    'Minimum 2 hours coverage',
    'Unlimited edited photos',
    'Candid and group shots',
    'Detail and decor photography',
    'Private online gallery',
    '2-week delivery',
  ],
};

const businessRef = { '@id': `${site.url}/#business` };

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Toronto Event Photography',
  description: celebrationsService.description,
  provider: businessRef,
  areaServed: { '@type': 'City', name: 'Toronto' },
  serviceType: 'Event Photography',
  image: `${site.url}/og-default.jpg`,
};

const offerCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: 'Event & Celebrations Photography Packages',
  description: 'Toronto event and celebration photography packages by AD Photography. Birthdays, bridal showers, baby showers, and more from $550.',
  url: `${site.url}/services/celebrations`,
  offeredBy: businessRef,
  itemListElement: eventPackages.filter((p) => p.price !== null).map((p) => ({
    '@type': 'Offer',
    name: p.name,
    description: p.description,
    price: p.salePrice || p.price,
    priceCurrency: p.currency,
    availability: 'https://schema.org/InStock',
    seller: businessRef,
  })),
};

const faqPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: eventFaq.map((q: any) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: { '@type': 'Answer', text: q.answer },
  })),
};

const jsonLd = [serviceSchema, offerCatalogSchema, faqPageSchema];
---

<BaseLayout
  title="Toronto Event Photography"
  description="Event and celebration photography in Toronto. Birthdays, bridal showers, corporate events from $550. Relaxed, natural coverage. Book a free consultation."
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs (visually hidden, still crawled by Google for search snippets) -->
  <div class="sr-only">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'Celebrations', href: '/services/celebrations' },
    ]} />
  </div>

  <!-- Hero: Featured review + portrait image -->
  <section style="padding-top: var(--spacing-block); padding-bottom: var(--spacing-block);">
    <div class="container-editorial">
      <div class="grid-editorial items-center" style="min-height: 80svh;">
        <!-- Review -->
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">Events &amp; Celebrations</p>
          <blockquote class="text-display-md" style="max-width: 20ch;">
            "The best celebrations are the ones where nobody is performing. Just people, together, being happy."
          </blockquote>
          <p class="text-label-sm text-on-surface-muted mt-8">Toronto</p>
          <div class="mt-8">
            <ShareButton
              variant="labeled"
              url="/services/celebrations"
              title="Toronto Event Photography, AD Photography"
              text="Birthdays, bridal showers, and private events from $550."
              label="Share"
            />
          </div>
        </div>
        <!-- Portrait image + plaque -->
        <figure class="col-span-12 md:col-span-6 md:col-start-7 reveal-right stagger-2">
          <div class="aspect-[3/4] overflow-hidden hover-zoom">
            <Image
              src={heroImage}
              alt="Toronto birthday and celebration photography by AD Photography"
              widths={[640, 960, 1280]}
              sizes="(max-width: 768px) 100vw, 50vw"
              quality={75}
              format="avif"
              class="w-full h-full object-cover parallax-img"
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <figcaption class="gallery-plaque">
            <div class="gallery-plaque__line">
              <span class="gallery-plaque__plate">Celebration</span>
              <span class="gallery-plaque__rule" aria-hidden="true"></span>
              <span class="gallery-plaque__meta">Toronto</span>
            </div>
            <p class="gallery-plaque__title">Your celebration, <em>captured.</em></p>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICE DESCRIPTION ═══ -->
  <section class="section-frame bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-center" style="margin-bottom: var(--spacing-block);">
        <div class="col-span-12 lg:col-span-5 aspect-[3/4] overflow-hidden reveal-left hover-zoom order-2 lg:order-1 mt-10 lg:mt-0">
          <Image
            src={serviceDetailImage}
            alt="Candid celebration photography capturing guests and decor at a Toronto event"
            widths={[400, 600, 800]}
            sizes="(max-width: 1024px) 100vw, 42vw"
            quality={90}
            class="w-full h-full object-cover parallax-img"
            loading="lazy"
          />
        </div>
        <div class="col-span-12 lg:col-span-6 lg:col-start-7 reveal stagger-2 order-1 lg:order-2">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">What I Offer</p>
          <h1 class="section-title char-reveal">Toronto event <em>photography.</em></h1>
          <p class="section-deck text-on-surface-variant mt-8 measure-wide">{celebrationsService.description}</p>
          <p class="text-label-sm text-on-surface-muted uppercase tracking-widest mt-10 mb-4">What's Included</p>
          <ul class="space-y-3">
            {celebrationsService.includes.map((item) => (
              <li class="text-body-md text-on-surface-variant pl-5 relative">
                <span class="absolute left-0 top-0 text-on-surface-muted" aria-hidden="true">/</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Scroll indicator to journey -->
      <div class="flex flex-col items-center mt-16 reveal stagger-3">
        <p class="text-label-sm text-on-surface-muted mb-3">Your Journey</p>
        <div class="scroll-chevron">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-on-surface-muted" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <JourneyTimelineDesktop steps={celebrationsJourneySteps} />
  <JourneyTimelineMobile steps={celebrationsJourneySteps} />

  <!-- ═══ CALENDLY CTA (post-journey) ═══ -->
  <section class="bg-background" style="padding: 0 0 var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="text-center reveal">
        <h3 class="text-heading-lg font-serif mb-2">Ready to start?</h3>
        <p class="text-body-md text-on-surface-variant mb-8">Book a free 30-minute consultation call</p>
        <BookingLink variant="primary" label="Book Your Call" />
        <div class="flex flex-col items-center mt-12">
          <p class="text-body-md text-on-surface-variant mb-3">I believe in transparent pricing. See my packages below.</p>
          <div class="scroll-chevron">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-on-surface-muted" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EVENT PACKAGES ═══ -->
  <section id="packages" class="section-frame bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-end" style="margin-bottom: var(--spacing-block);">
        <div class="col-span-12 md:col-span-7">
          <p class="text-label-md text-on-surface-muted reveal eyebrow-rule mb-6">Curated Collections</p>
          <h2 class="section-title reveal stagger-1">Event <em>packages.</em></h2>
        </div>
        <div class="col-span-12 md:col-span-5 md:col-start-8 mt-6 md:mt-0">
          <p class="section-deck text-on-surface-variant reveal stagger-2 measure-wide">
            Every booking includes a free consultation to walk through your event, your timeline, and the moments that matter most to you.
          </p>
        </div>
      </div>

      <div class="pricing-grid reveal stagger-3">
        {eventPackages.map((pkg, i) => (
          <PricingCard
            id={pkg.id}
            name={pkg.name}
            price={pkg.price}
            salePrice={pkg.salePrice}
            description={pkg.description}
            highlights={pkg.highlights}
            popular={pkg.popular}
            featured={!!pkg.salePrice}
            ordinal={i}
            service="celebration"
            ctaLabel="Enquire"
          />
        ))}
      </div>

      <!-- Shared add-ons section (pulled from all celebrations packages above) -->
      <div class="mt-12">
        <PackageAddOns
          title="Add-Ons & Extras"
          description="Optional upgrades you can add to any celebration booking."
          packages={eventPackages}
        />
      </div>

      <!-- CTA below packages -->
      <div class="text-center mt-16 reveal">
        <p class="text-label-sm text-on-surface-muted mb-2">Have questions? I'll get back to you within 24 hours, guaranteed.</p>
        <div class="mt-6">
          <a href="/contact?service=celebrations" class="magnetic inline-flex items-center justify-center whitespace-nowrap px-12 py-5 bg-primary text-on-dark font-sans text-label-md hover:bg-primary-hover cubic-ease" style="transition-duration: var(--duration-hover);">Contact Me</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EDITORIAL INTERLUDE ═══ -->
  <section class="bg-surface" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-center">
        <figure class="col-span-12 md:col-span-6 reveal-left">
          <div class="aspect-[3/4] overflow-hidden hover-zoom">
            <Image
              src={momentImage}
              alt="Floral centerpiece and candlelight details at a Toronto celebration, photographed before guests arrive"
              widths={[640, 960, 1280]}
              sizes="(max-width: 768px) 100vw, 50vw"
              quality={90}
              class="w-full h-full object-cover parallax-img"
              loading="lazy"
            />
          </div>
          <figcaption class="gallery-plaque">
            <div class="gallery-plaque__line">
              <span class="gallery-plaque__plate">Detail</span>
              <span class="gallery-plaque__rule" aria-hidden="true"></span>
              <span class="gallery-plaque__meta">Before the room fills</span>
            </div>
          </figcaption>
        </figure>
        <div class="col-span-12 md:col-span-4 md:col-start-8 reveal stagger-2">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">In The Details</p>
          <p class="text-quote text-on-surface-variant" style="max-width: 28ch;">
            Petals, candlelight, the hush before the room fills. The details you spent months planning, remembered.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GOOD TO KNOW ═══ -->
  <section class="section-frame bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="text-center mb-16 reveal">
        <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule eyebrow-rule-center">Before You Book</p>
        <h2 class="section-title mx-auto">Good to <em>know.</em></h2>
      </div>

      <div class="good-to-know-grid">
        <div class="good-to-know-item reveal">
          <p class="text-heading-md font-serif italic mb-3">Free consultation</p>
          <p class="text-body-md text-on-surface-variant">Included with every booking. No pressure, just a conversation about your event and what you want captured.</p>
        </div>
        <div class="good-to-know-item reveal stagger-1">
          <p class="text-heading-md font-serif italic mb-3">Location guidance</p>
          <p class="text-body-md text-on-surface-variant">I help you think through the space and how to make the most of it. Light first, location second. One great spot can give you a dozen different looks.</p>
        </div>
        <div class="good-to-know-item reveal stagger-2">
          <p class="text-heading-md font-serif italic mb-3">GTA travel included</p>
          <p class="text-body-md text-on-surface-variant">No surprise fees. Travel within the Greater Toronto Area is typically covered. Anything beyond, I discuss upfront.</p>
        </div>
        <div class="good-to-know-item reveal stagger-3">
          <p class="text-heading-md font-serif italic mb-3">Canada-wide</p>
          <p class="text-body-md text-on-surface-variant">Based in Toronto, but I travel for the moments that matter. If your event is outside the GTA, let's talk.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="section-frame bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial max-w-3xl">
      <div class="text-center mb-12 reveal">
        <h2 class="text-heading-lg font-serif italic">Questions you might have</h2>
      </div>
      <div class="reveal stagger-1">
        <FAQAccordion items={eventFaq} />
      </div>
    </div>
  </section>

  <PortfolioFinalCTA
    eyebrow="Planning something?"
    title="Let's make it memorable."
    body="Book a free consultation. No pressure, just a conversation about your celebration."
    ctaLabel="Begin Your Journey"
    ctaHref="/contact?service=celebrations"
    background="background"
    image={ctaImage}
    imageAlt="Toronto celebration photography by AD Photography"
    imageCaption="Begin Your Story"
  />

  <ContactModal />
  <FloatingPackagesLink />
</BaseLayout>
