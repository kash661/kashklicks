---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PricingCard from '../../components/ui/PricingCard.astro';
import PackageAddOns from '../../components/ui/PackageAddOns.astro';
import FAQAccordion from '../../components/ui/FAQAccordion.astro';
import Button from '../../components/ui/Button.astro';
import BookingLink from '../../components/ui/BookingLink.astro';
import ShareButton from '../../components/ui/ShareButton.astro';
import JourneyTimelineDesktop from '../../components/services/JourneyTimelineDesktop.astro';
import JourneyTimelineMobile from '../../components/services/JourneyTimelineMobile.astro';
import PortfolioFinalCTA from '../../components/global/PortfolioFinalCTA.astro';
import ctaImage from '../../assets/images/homepage/homepage-05.jpg';
import { Image } from 'astro:assets';

import packages from '../../data/packages.json';
import faqData from '../../data/faq.json';
import site from '../../data/site.json';

import heroImage from '../../assets/images/homepage/homepage-06.jpg';
const preWeddingServiceImage = (await import('../../assets/images/homepage/prewedding-service-detail.jpg')).default;

const preWeddingPackages = packages.filter((p) => p.category === 'Pre-Wedding').sort((a, b) => a.order - b.order);
const preWeddingFaq = faqData.filter((q: any) => !q.services || q.services.includes('pre-wedding'));

const preWeddingService = {
  title: 'Pre-Weddings & E-Shoots',
  description: 'Your love story deserves to be told beautifully, before the big day even arrives. My pre-wedding sessions capture the connection between you and your partner through cinematic photography and filmmaking at Toronto\'s most stunning locations.',
  includes: [
    'Professional photography & optional videography',
    'Location scouting and guidance',
    'Outfit and styling consultation',
    'High-resolution edited photos',
    'Custom cinematic films (select packages)',
    'Private online gallery',
  ],
};

const businessRef = { '@id': `${site.url}/#business` };

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Toronto Pre-Wedding Photography',
  description: preWeddingService.description,
  provider: businessRef,
  areaServed: { '@type': 'City', name: 'Toronto' },
  serviceType: 'Pre-Wedding Photography',
  image: `${site.url}/og-default.jpg`,
};

const offerCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: 'Pre-Wedding Photography Packages',
  description: 'Toronto pre-wedding and engagement photography packages by AD Photography. Sessions starting from $350.',
  url: `${site.url}/services/pre-wedding`,
  offeredBy: businessRef,
  itemListElement: preWeddingPackages.filter((p) => p.price !== null).map((p) => ({
    '@type': 'Offer',
    name: p.name,
    description: p.description,
    price: p.salePrice || p.price,
    priceCurrency: p.currency,
    availability: 'https://schema.org/InStock',
    seller: businessRef,
  })),
};

const faqPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: preWeddingFaq.map((q: any) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: { '@type': 'Answer', text: q.answer },
  })),
};

const jsonLd = [serviceSchema, offerCatalogSchema, faqPageSchema];

const preWeddingJourneySteps = [
  {
    label: 'Step 01',
    title: 'Book a Consultation',
    body: 'A free, no-obligation call to talk about your session. No pressure, just a conversation about what you are envisioning and what matters most to you.',
  },
  {
    label: 'Step 02',
    title: 'Planning Together',
    body: "I'll help you choose your location, outfits, time of day, and mood. I walk through every package and find the right fit for your vision and your budget.",
  },
  {
    label: 'Step 03',
    title: 'Lock In Your Date',
    body: 'Sign a simple contract. A 50% retainer secures your session date and gets things started.',
  },
  {
    label: 'Step 04',
    title: 'Your Session Day',
    body: 'I capture everything. The remaining 50% is due on the day of your session. You just show up and be yourselves. I handle the rest.',
  },
  {
    label: 'Step 05',
    title: 'Video Draft',
    body: 'I send you an edited draft of your film. Give me all your feedback in one round, and I custom curate the final cut for you.',
  },
  {
    label: 'Step 06',
    title: 'Full Delivery',
    body: 'Your complete gallery and final film delivered within 1 to 3 weeks. Private online gallery, yours to keep and share.',
  },
];
---

<BaseLayout
  title="Toronto Pre-Wedding Photography"
  description="Toronto pre-wedding and engagement photography from $350. Cinematic sessions at stunning locations with outfit guidance and optional films. Book a free consultation."
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs (visually hidden, still crawled by Google for search snippets) -->
  <div class="sr-only">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Services', href: '/services' },
      { label: 'Pre-Weddings & E-Shoots', href: '/services/pre-wedding' },
    ]} />
  </div>

  <!-- Hero: Featured review + portrait image -->
  <section style="padding-top: var(--spacing-block);">
    <div class="container-editorial">
      <div class="grid-editorial items-center" style="min-height: 80vh;">
        <!-- Review -->
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">Pre-Weddings & E-Shoots</p>
          <blockquote class="text-display-md" style="max-width: 20ch;">
            "This is beyond what we were expecting. These photos are amazzzing."
          </blockquote>
          <p class="text-label-md text-on-surface-variant mt-8">Swati & Saksham</p>
          <p class="text-label-sm text-on-surface-muted">Toronto</p>
          <div class="mt-8">
            <ShareButton
              variant="labeled"
              url="/services/pre-wedding"
              title="Toronto Pre-Wedding Photography, AD Photography"
              text="Cinematic pre-wedding and engagement sessions from $350."
              label="Share"
            />
          </div>
        </div>
        <!-- Portrait image -->
        <div class="col-span-12 md:col-span-6 md:col-start-7 aspect-[3/4] overflow-hidden reveal-right stagger-2 image-caption" data-caption="Swati & Saksham, Toronto">
          <Image
            src={heroImage}
            alt="Swati and Saksham pre-wedding photography in Toronto by AD Photography"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={75}
            format="avif"
            class="w-full h-full object-cover parallax-img"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICE DESCRIPTION ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-center" style="margin-bottom: var(--spacing-block);">
        <div class="col-span-12 lg:col-span-5 aspect-[3/4] overflow-hidden reveal-left image-caption order-2 lg:order-1 mt-10 lg:mt-0" data-caption="Cinematic Pre-Wedding">
          <Image
            src={preWeddingServiceImage}
            alt="Toronto pre-wedding couple at golden hour by AD Photography"
            widths={[400, 600, 800]}
            sizes="(max-width: 1024px) 100vw, 42vw"
            quality={90}
            class="w-full h-full object-cover parallax-img"
            loading="lazy"
          />
        </div>
        <div class="col-span-12 lg:col-span-5 lg:col-start-7 reveal stagger-2 order-1 lg:order-2">
          <p class="text-label-md text-on-surface-muted eyebrow-rule">What I Offer</p>
          <h1 class="text-display-md char-reveal" style="margin-top: var(--spacing-element);">Toronto Pre-Wedding Photography</h1>
          <p class="text-body-lg text-on-surface-variant mt-4" style="max-width: 50ch;">{preWeddingService.description}</p>
          <p class="text-label-sm text-on-surface-muted uppercase tracking-widest mt-10 mb-4">What's Included</p>
          <ul class="space-y-3">
            {preWeddingService.includes.map((item) => (
              <li class="text-body-md text-on-surface-variant pl-5 relative">
                <span class="absolute left-0 top-0 text-on-surface-muted" aria-hidden="true">/</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Scroll indicator to journey -->
      <div class="flex flex-col items-center mt-16 reveal stagger-3">
        <p class="text-label-sm text-on-surface-muted mb-3">Your Journey</p>
        <div class="scroll-chevron">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-on-surface-muted" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <JourneyTimelineDesktop steps={preWeddingJourneySteps} />
  <JourneyTimelineMobile steps={preWeddingJourneySteps} />

  <!-- ═══ CALENDLY CTA (post-journey) ═══ -->
  <section class="bg-background" style="padding: 0 0 var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="text-center reveal">
        <h3 class="text-heading-lg font-serif mb-2">Ready to start?</h3>
        <p class="text-body-md text-on-surface-variant mb-8">Book a free 30-minute consultation call</p>
        <BookingLink variant="primary" label="Book Your Call" />
        <div class="flex flex-col items-center mt-12">
          <p class="text-body-md text-on-surface-variant mb-3">I believe in transparent pricing. See my packages below.</p>
          <div class="scroll-chevron">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-on-surface-muted" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PRE-WEDDING PACKAGES ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-end" style="margin-bottom: var(--spacing-block);">
        <div class="col-span-12 md:col-span-5">
          <p class="text-label-md text-on-surface-muted reveal eyebrow-rule">Curated Collections</p>
          <h2 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element);">Pre-Wedding Packages</h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 mt-6 md:mt-0">
          <p class="text-quote text-on-surface-variant reveal stagger-2" style="max-width: 50ch;">
            <span class="md:hidden">Every session includes a free consultation.</span>
            <span class="hidden md:inline">Every session includes a free consultation to walk through your vision, choose the right location, and plan the moments that will mean the most to you.</span>
          </p>
        </div>
      </div>

      <!-- Filter -->
      <div class="reveal stagger-3 mb-10" id="package-filter">
        <p class="text-label-sm text-on-surface-muted mb-4">Show me</p>
        <div class="flex flex-wrap gap-3">
          <button
            id="filter-all"
            class="filter-pill px-6 py-2 text-label-sm bg-primary text-on-dark cubic-ease"
            style="transition-duration: var(--duration-hover);"
            data-active="true"
          >All Packages</button>
          <button
            id="filter-video"
            class="filter-pill px-6 py-2 text-label-sm bg-surface-container text-on-surface-variant hover:text-on-surface cubic-ease"
            style="transition-duration: var(--duration-hover);"
          >Includes Film</button>
          <button
            id="filter-sale"
            class="filter-pill px-6 py-2 text-label-sm bg-surface-container text-on-surface-variant hover:text-on-surface cubic-ease"
            style="transition-duration: var(--duration-hover);"
          >Limited Offer</button>
          <button
            id="filter-photo-only"
            class="filter-pill px-6 py-2 text-label-sm bg-surface-container text-on-surface-variant hover:text-on-surface cubic-ease"
            style="transition-duration: var(--duration-hover);"
          >Photos Only</button>
        </div>
      </div>

      <!-- All packages in one grid with data attributes -->
      <div class="grid grid-cols-1 md:grid-cols-3 reveal stagger-3" style="gap: 2px;" id="package-grid">
        {preWeddingPackages.map((pkg) => (
          <div
            class="package-card transition-opacity cubic-ease"
            style="transition-duration: 0.6s;"
            data-price={pkg.price || 99999}
            data-film={pkg.film ? 'true' : 'false'}
            data-sale={pkg.salePrice ? 'true' : 'false'}
            data-custom={pkg.custom ? 'true' : 'false'}
          >
            <PricingCard
              id={pkg.id}
              name={pkg.name}
              price={pkg.price}
              salePrice={pkg.salePrice}
              description={pkg.description}
              highlights={pkg.highlights}
              popular={pkg.popular}
              featured={!!pkg.salePrice}
              custom={pkg.custom}
            />
          </div>
        ))}
      </div>

      <!-- Shared add-ons section (pulled from all pre-wedding packages above) -->
      <div class="mt-12">
        <PackageAddOns
          title="Add-Ons & Extras"
          description="Optional upgrades that apply across any of the sessions above."
          packages={preWeddingPackages}
        />
      </div>

      <script>
        function initPackageFilter() {
          const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
          const cards = document.querySelectorAll<HTMLElement>('.package-card');
          if (!pills.length || !cards.length) return;

          function setActive(activeId: string) {
            pills.forEach((pill) => {
              if (pill.id === activeId) {
                pill.classList.remove('bg-surface-container', 'text-on-surface-variant');
                pill.classList.add('bg-primary', 'text-on-dark');
                pill.dataset.active = 'true';
              } else {
                pill.classList.add('bg-surface-container', 'text-on-surface-variant');
                pill.classList.remove('bg-primary', 'text-on-dark');
                pill.dataset.active = 'false';
              }
            });
          }

          function applyFilter(filterId: string) {
            setActive(filterId);

            cards.forEach((card) => {
              const hasFilm = card.dataset.film === 'true';
              const onSale = card.dataset.sale === 'true';
              const isCustom = card.dataset.custom === 'true';
              if (isCustom) {
                card.style.opacity = '1';
                return;
              }

              let matches = true;

              if (filterId === 'filter-video') {
                matches = hasFilm;
              } else if (filterId === 'filter-sale') {
                matches = onSale;
              } else if (filterId === 'filter-photo-only') {
                matches = !hasFilm;
              }

              card.style.opacity = matches ? '1' : '0.15';
            });
          }

          pills.forEach((pill) => {
            pill.addEventListener('click', () => applyFilter(pill.id));
          });
        }

        initPackageFilter();
        document.addEventListener('astro:after-swap', initPackageFilter);
      </script>

      <!-- CTA below packages -->
      <div class="text-center mt-16 reveal">
        <p class="text-label-sm text-on-surface-muted mb-2">Have questions? I'll get back to you within 24 hours, guaranteed.</p>
        <div class="mt-6">
          <a href="/contact?service=pre-wedding" class="magnetic inline-flex items-center justify-center whitespace-nowrap px-12 py-5 bg-primary text-on-dark font-sans text-label-md hover:bg-primary-hover cubic-ease" style="transition-duration: var(--duration-hover);">Contact Me</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GOOD TO KNOW ═══ -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="text-center mb-16 reveal">
        <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule eyebrow-rule-center">Before You Book</p>
        <h2 class="text-display-md">Good to Know</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-surface-container">
        <div class="bg-background p-10 reveal">
          <p class="text-heading-md font-serif italic mb-3">Free consultation</p>
          <p class="text-body-md text-on-surface-variant">Included with every booking. No pressure, just a conversation about your vision and what your session looks like.</p>
        </div>
        <div class="bg-background p-10 reveal stagger-1">
          <p class="text-heading-md font-serif italic mb-3">Location guidance</p>
          <p class="text-body-md text-on-surface-variant">I help you find the perfect spot. Light first, location second. One great spot can give you a dozen different looks.</p>
        </div>
        <div class="bg-background p-10 reveal stagger-2">
          <p class="text-heading-md font-serif italic mb-3">Outfit changes welcome</p>
          <p class="text-body-md text-on-surface-variant">Bring as many looks as your package allows. I help you plan what works best for each location and time of day.</p>
        </div>
        <div class="bg-background p-10 reveal stagger-3">
          <p class="text-heading-md font-serif italic mb-3">Quick turnaround</p>
          <p class="text-body-md text-on-surface-variant">Most pre-wedding galleries are delivered within 1 to 3 weeks. Films take a little longer, but I'll keep you updated every step of the way.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial max-w-3xl">
      <div class="text-center mb-12 reveal">
        <h2 class="text-heading-lg font-serif italic">Questions you might have</h2>
      </div>
      <div class="reveal stagger-1">
        <FAQAccordion items={preWeddingFaq} />
      </div>
    </div>
  </section>

  <PortfolioFinalCTA
    title="Let's capture your story."
    body="Book a free consultation. No pressure, just a conversation about your vision."
    ctaLabel="Begin Your Journey"
    ctaHref="/contact?service=pre-wedding"
    background="background"
    image={ctaImage}
    imageAlt="Toronto pre-wedding couple portrait by AD Photography"
    imageCaption="Begin Your Journey"
  />
</BaseLayout>
