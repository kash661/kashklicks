---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import PricingCard from '../components/ui/PricingCard.astro';
import PackageAddOns from '../components/ui/PackageAddOns.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import Button from '../components/ui/Button.astro';
import BookingLink from '../components/ui/BookingLink.astro';
import GearStrip from '../components/global/GearStrip.astro';
import gearStripCard01 from '../assets/images/portfolio/ayushi-parth/25.jpg';
import gearStripCard04 from '../assets/images/gear/04-wedding-override.jpg';
import { Image } from 'astro:assets';

import packages from '../data/packages.json';
import faqData from '../data/faq.json';
import site from '../data/site.json';

// Hero: editorial portrait (DSCF4845)
import heroImage from '../assets/images/intimate-wedding/hero-DSCF4845.jpg';

// Work gallery: Toronto-local couples
const noraAliCover = (await import('../assets/images/portfolio/nora-ali-cover.jpg')).default;
const natalieShavarCover = (await import('../assets/images/portfolio/natalie-shavar-cover.jpg')).default;
const alexAzizCover = (await import('../assets/images/portfolio/alex-aziz-cover.jpg')).default;
const anushkaAnthonyAlt = (await import('../assets/images/portfolio/anushka-anthony/21.jpg')).default;

// Wedding packages only (photo-only — no film)
const weddingPackages = packages
  .filter((p) => p.category === 'Wedding')
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
const civilPackage = packages.find((p) => p.category === 'Civil Ceremony');

const weddingFaq = faqData.filter(
  (q: any) => !q.services || q.services.includes('wedding')
);

// Featured Toronto couples for work gallery
const torontoWork = [
  {
    couple: 'Nora + Ali',
    venue: 'Backyard Wedding, Toronto',
    image: noraAliCover,
    href: '/portfolio/nora-ali',
    aspect: 'aspect-[3/4]',
  },
  {
    couple: 'Alex + Aziz',
    venue: 'TD Centre & Commerce Court',
    image: alexAzizCover,
    href: '/portfolio/alex-aziz',
    aspect: 'aspect-[3/4]',
  },
  {
    couple: 'Natalie + Shavar',
    venue: 'The Glenerin Inn',
    image: natalieShavarCover,
    href: '/portfolio/natalie-shavar',
    aspect: 'aspect-[3/4]',
  },
  {
    couple: 'Anushka + Anthony',
    venue: 'Toronto City Hall',
    image: anushkaAnthonyAlt,
    href: '/portfolio/anushka-anthony',
    aspect: 'aspect-[3/4]',
  },
];

// Structured data
const businessRef = { '@id': `${site.url}/#business` };

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Intimate Wedding Photography Toronto',
  description:
    'Solo editorial wedding photography for intimate Toronto weddings. Church, civil, backyard, and small-venue ceremonies across the GTA.',
  provider: businessRef,
  areaServed: { '@type': 'City', name: 'Toronto' },
  serviceType: 'Intimate Wedding Photography',
  image: `${site.url}/og-default.jpg`,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'CAD',
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: '1200',
      priceCurrency: 'CAD',
    },
  },
};

const offerCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: 'Intimate Wedding Photography Packages, Toronto',
  description:
    'Intimate wedding photography packages for Toronto and GTA couples. Coverage from $1,200.',
  url: `${site.url}/intimate-wedding-toronto`,
  offeredBy: businessRef,
  itemListElement: weddingPackages
    .filter((p) => p.price !== null)
    .map((p) => ({
      '@type': 'Offer',
      name: p.name,
      description: p.description,
      price: p.salePrice || p.price,
      priceCurrency: p.currency,
      availability: 'https://schema.org/InStock',
      seller: businessRef,
    })),
};

const faqPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: weddingFaq.map((q: any) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: { '@type': 'Answer', text: q.answer },
  })),
};

const jsonLd = [serviceSchema, offerCatalogSchema, faqPageSchema];
---

<BaseLayout
  title="Intimate Wedding Photographer Toronto"
  description="Solo editorial wedding photographer for Toronto couples. Church, civil, backyard, and small-venue ceremonies. Coverage from $1,200. Begin the conversation."
  canonicalUrl={`${site.url}/intimate-wedding-toronto`}
  jsonLd={jsonLd}
>
  <!-- Breadcrumbs (visually hidden, crawled for search snippets) -->
  <div class="sr-only">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Intimate Wedding Photography Toronto', href: '/intimate-wedding-toronto' },
    ]} />
  </div>

  <!-- flatpickr (date picker) — CDN + Digital Curator theme overrides -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css" />
  <style is:global>
    /* Editorial overrides for flatpickr — flat corners, neutral palette */
    .flatpickr-calendar {
      border-radius: 0 !important;
      border: 1px solid var(--color-surface-container, #e4e2e1) !important;
      box-shadow: 0 8px 32px rgba(26, 26, 24, 0.08) !important;
      font-family: var(--font-sans, 'Inter', system-ui, sans-serif) !important;
      background: #ffffff !important;
    }
    .flatpickr-day,
    .flatpickr-day.today,
    .flatpickr-day.selected,
    .flatpickr-day.startRange,
    .flatpickr-day.endRange {
      border-radius: 0 !important;
    }
    .flatpickr-day.selected,
    .flatpickr-day.selected:hover {
      background: #1a1a18 !important;
      border-color: #1a1a18 !important;
      color: #faf9f6 !important;
    }
    .flatpickr-day.today {
      border-color: #5f5e5e !important;
    }
    .flatpickr-day:hover {
      background: #f4f4f0 !important;
    }
    .flatpickr-months .flatpickr-month,
    .flatpickr-weekdays {
      background: #ffffff !important;
      color: #1a1a18 !important;
    }
    .flatpickr-current-month .flatpickr-monthDropdown-months,
    .flatpickr-current-month input.cur-year {
      color: #1a1a18 !important;
      font-weight: 500 !important;
    }
    .flatpickr-weekday {
      color: #5c605c !important;
      font-weight: 500 !important;
      text-transform: uppercase !important;
      letter-spacing: 0.08em !important;
      font-size: 0.6875rem !important;
    }
    .flatpickr-input[readonly] {
      cursor: pointer;
    }
  </style>

  <!-- ═══ HERO — editorial, filter-headline ═══ -->
  <section style="padding-top: var(--spacing-block);">
    <div class="container-editorial">
      <div class="grid-editorial items-center min-h-[85svh] md:min-h-[80vh]">
        <!-- Filter headline + sub + price anchor + CTA -->
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">Toronto · Intimate Weddings</p>
          <h1 class="text-display-lg char-reveal" style="max-width: 14ch;">
            Toronto weddings, unhurried.
          </h1>
          <p class="text-body-lg text-on-surface-variant mt-8" style="max-width: 40ch;">
            For couples getting married here. One photographer. Intimate ceremonies: church, civil, backyard, small venues.
          </p>
          <p class="text-label-sm text-on-surface-muted mt-6 tracking-widest uppercase">
            Weddings from $1,200 · Solo · Photo-only
          </p>
          <div class="mt-8">
            <span class="magnetic inline-block">
              <Button href="#inquire" variant="primary">Begin the Conversation</Button>
            </span>
          </div>
        </div>

        <!-- Portrait image -->
        <div
          class="col-span-12 md:col-span-6 md:col-start-7 aspect-[3/4] overflow-hidden reveal-right stagger-2 hover-zoom"
        >
          <Image
            src={heroImage}
            alt="Intimate Toronto wedding photograph by AD Photography"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={75}
            format="avif"
            class="w-full h-full object-cover parallax-img"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VENUE TRUST STRIP — first-scroll credibility via named Toronto venues ═══
       Editorial brand pattern per vault/Editorial LP Pattern.md: named venues > review counts.
       Skip "500+ couples" claims; use specificity instead of statistics. -->
  <section class="bg-background" style="padding: 0 0 var(--spacing-block) 0;">
    <div class="container-editorial">
      <div class="text-center reveal">
        <p class="text-label-sm text-on-surface-muted uppercase" style="letter-spacing: 0.14em; max-width: 68ch; margin-inline: auto; line-height: 1.8;">
          Toronto City Hall · TD Centre · The Glenerin Inn · University of Toronto · Backyards across the GTA
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ THE KIT — four cameras, four looks ═══ -->
  <GearStrip
    imageOverrides={{
      '01': {
        src: gearStripCard01,
        alt: 'Ayushi and Parth walking up stone steps through a classical archway, Toronto wedding session',
      },
      '04': {
        src: gearStripCard04,
        alt: 'Candid wedding moment captured on a handheld compact, the kind of angle your crew catches',
      },
    }}
  />

  <!-- ═══ RECENT TORONTO WORK ═══ -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-end" style="margin-bottom: var(--spacing-block);">
        <div class="col-span-12 md:col-span-5">
          <p class="text-label-md text-on-surface-muted reveal eyebrow-rule">Recent Work</p>
          <h2 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element);">
            Toronto couples, here.
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 mt-6 md:mt-0">
          <p class="text-body-lg text-on-surface-variant reveal stagger-2" style="max-width: 50ch;">
            A small selection of couples who chose to marry in the city. Church. City Hall. Backyard. Each one a quiet day, photographed.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {torontoWork.map((item, i) => (
          <a
            href={item.href}
            class={`block reveal stagger-${(i % 4) + 1} hover-zoom`}
          >
            <div class={`${item.aspect} overflow-hidden bg-surface-container`}>
              <Image
                src={item.image}
                alt={`${item.couple} wedding photography, ${item.venue}, by AD Photography`}
                widths={[320, 480, 640]}
                sizes="(max-width: 768px) 50vw, 25vw"
                quality={75}
                format="avif"
                class="w-full h-full object-cover transition-transform"
                loading="lazy"
              />
            </div>
            <p class="text-label-sm text-on-surface-variant mt-3">{item.couple}</p>
            <p class="text-label-sm text-on-surface-muted">{item.venue}</p>
          </a>
        ))}
      </div>

      <div class="mt-16 reveal text-center">
        <Button href="/portfolio/weddings" variant="secondary">See the Full Portfolio</Button>
      </div>
    </div>
  </section>

  <!-- ═══ APPROACH — three cols ═══ -->
  <section class="bg-surface" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="text-center mb-16 reveal">
        <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule eyebrow-rule-center">The Approach</p>
        <h2 class="text-display-md">How I shoot a Toronto wedding.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-surface-container">
        <div class="bg-background p-6 md:p-10 reveal">
          <p class="text-heading-md font-serif italic mb-3">One photographer</p>
          <p class="text-body-md text-on-surface-variant">
            My full attention across your entire day. Multiple cameras so no moment slips away, one eye on the edit so your gallery feels like a single story.
          </p>
        </div>
        <div class="bg-background p-6 md:p-10 reveal stagger-1">
          <p class="text-heading-md font-serif italic mb-3">Photography only</p>
          <p class="text-body-md text-on-surface-variant">
            I shoot weddings on camera, not video. Film is for pre-wedding sessions. The wedding is documented in stills, honest, editorial, unhurried.
          </p>
        </div>
        <div class="bg-background p-6 md:p-10 reveal stagger-2">
          <p class="text-heading-md font-serif italic mb-3">Made here</p>
          <p class="text-body-md text-on-surface-variant">
            Toronto venues. Local families. Local stories. I know the churches, the halls, the backyards, and the light in each.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WEDDING PACKAGES ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-end" style="margin-bottom: var(--spacing-block);">
        <div class="col-span-12 md:col-span-5">
          <p class="text-label-md text-on-surface-muted reveal eyebrow-rule">Collections</p>
          <h2 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element);">
            Transparent pricing.
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 mt-6 md:mt-0">
          <p class="text-body-lg text-on-surface-variant reveal stagger-2" style="max-width: 50ch;">
            Three wedding collections, priced openly. Every package includes a free consultation to walk through your day before you decide.
          </p>
        </div>
      </div>

      <div class="pricing-grid reveal stagger-3">
        {weddingPackages.map((pkg, i) => (
          <PricingCard
            id={pkg.id}
            name={pkg.name}
            price={pkg.price}
            salePrice={pkg.salePrice}
            description={pkg.description}
            highlights={pkg.highlights}
            popular={pkg.popular}
            featured={!!pkg.salePrice}
            ordinal={i}
            service="wedding"
            ctaLabel="Enquire"
          />
        ))}
      </div>

      <!-- Shared add-ons section (pulled from all wedding packages above) -->
      <div class="mt-12">
        <PackageAddOns
          title="Add-Ons & Extras"
          description="Optional upgrades that apply across the collections above. Add any combination to your booking."
          packages={weddingPackages}
        />
      </div>

      {civilPackage && (
        <div class="mt-12 reveal">
          <!-- Compact single-row civil ceremony callout -->
          <div class="border-t border-b border-surface-container py-6 md:py-8">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 md:gap-8">
              <div class="flex items-baseline gap-4 flex-wrap">
                <p class="text-label-sm text-on-surface-muted uppercase tracking-widest">Also Available</p>
                <p class="text-heading-md font-serif italic text-on-surface">Civil Ceremony · ${civilPackage.price}</p>
              </div>
              <a
                href="/services/civil-ceremony"
                class="inline-flex items-center gap-2 text-label-sm text-on-surface uppercase tracking-widest hover:text-on-surface-variant cubic-ease group shrink-0"
                style="transition-duration: var(--duration-hover);"
              >
                <span>Details</span>
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1" style="transition-duration: var(--duration-hover);">→</span>
              </a>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ BEGIN THE CONVERSATION — inline inquiry form + Calendly CTA ═══ -->
  <section id="inquire" class="bg-background" style="padding: var(--spacing-section) 0 var(--spacing-block) 0;">
    <div class="container-editorial" style="max-width: 64rem;">
      <!-- Header -->
      <div class="text-center mb-12 reveal">
        <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule eyebrow-rule-center">Begin the Conversation</p>
        <h2 class="text-display-md">Tell me about your day.</h2>
        <p class="text-body-lg text-on-surface-variant mt-6 mx-auto" style="max-width: 52ch;">
          A short note gets the conversation started. I read every inquiry myself and reply within 24 hours.
        </p>
      </div>

      <!-- Inquiry form — shared BEM treatment with /contact ContactForm:
           boxed white inputs, champagne hairline borders, italic serif
           placeholders, roman-numeral section legends. -->
      <div id="lp-form-wrapper" class="reveal stagger-1">
        <form
          id="lp-inquiry-form"
          action="https://script.google.com/macros/s/AKfycbw5c2bxZOPov3y9XUgSWZdTmAhwZM9k2E5BBr9AJDiWGp2rDded_RYYrsVaq-HWm7VepQ/exec"
          method="POST"
          novalidate
        >
          <!-- Honeypot -->
          <div class="absolute -left-[9999px] opacity-0 h-0 w-0 overflow-hidden" aria-hidden="true">
            <label for="lp_gotcha">Don't fill this out</label>
            <input type="text" id="lp_gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Source tracking -->
          <input type="hidden" name="source" value="intimate-wedding-toronto" />
          <input type="hidden" name="event_type" value="wedding" />

          <!-- Package context — prefilled when Inquire is tapped on a PricingCard. -->
          <input type="hidden" id="lp-package-id" name="package_id" value="" />
          <input type="hidden" id="lp-package-name" name="package_name" value="" />

          <!-- ═══ I · ABOUT YOU ═══ -->
          <fieldset class="form-section">
            <legend class="form-section__legend">
              <span class="form-section__number">I</span>
              <span class="form-section__title">About You</span>
            </legend>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-8">
              <div class="form-field">
                <label for="lp-name" class="form-field__label">
                  Your Name <span class="form-field__required" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="lp-name"
                  name="name"
                  autocomplete="given-name"
                  required
                  aria-required="true"
                  aria-describedby="lp-name-error"
                  class="form-field__input"
                />
                <p id="lp-name-error" class="form-error-msg form-field__error hidden" role="alert"></p>
              </div>

              <div class="form-field">
                <label for="lp-partner" class="form-field__label">
                  Partner's Name <span class="form-field__optional">(if applicable)</span>
                </label>
                <input
                  type="text"
                  id="lp-partner"
                  name="partner_name"
                  autocomplete="off"
                  class="form-field__input"
                />
                <p class="form-error-msg form-field__error hidden" role="alert"></p>
              </div>

              <div class="form-field">
                <label for="lp-email" class="form-field__label">
                  Email <span class="form-field__required" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="lp-email"
                  name="email"
                  autocomplete="email"
                  required
                  aria-required="true"
                  inputmode="email"
                  aria-describedby="lp-email-error"
                  class="form-field__input"
                />
                <p id="lp-email-error" class="form-error-msg form-field__error hidden" role="alert"></p>
              </div>

              <div class="form-field">
                <label for="lp-phone" class="form-field__label">
                  Phone <span class="form-field__optional">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="lp-phone"
                  name="phone"
                  autocomplete="tel"
                  inputmode="tel"
                  placeholder="(416) 555 0199"
                  aria-describedby="lp-phone-error"
                  class="form-field__input"
                />
                <p id="lp-phone-error" class="form-error-msg form-field__error hidden" role="alert"></p>
              </div>
            </div>
          </fieldset>

          <!-- ═══ II · YOUR DAY ═══ -->
          <fieldset class="form-section">
            <legend class="form-section__legend">
              <span class="form-section__number">II</span>
              <span class="form-section__title">Your Day</span>
            </legend>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-8">
              <div class="form-field">
                <label for="lp-date" class="form-field__label">
                  Ceremony Date <span class="form-field__optional">(tentative is fine)</span>
                </label>
                <input
                  type="date"
                  id="lp-date"
                  name="event_date"
                  class="form-field__input"
                />
              </div>

              <div class="form-field">
                <label for="lp-location" class="form-field__label">
                  Ceremony Location <span class="form-field__optional">(optional)</span>
                </label>
                <input
                  type="text"
                  id="lp-location"
                  name="location"
                  placeholder="City, venue, or neighborhood"
                  class="form-field__input"
                />
              </div>
            </div>
          </fieldset>

          <!-- ═══ III · THE STORY ═══ -->
          <fieldset class="form-section">
            <legend class="form-section__legend">
              <span class="form-section__number">III</span>
              <span class="form-section__title">The Story</span>
            </legend>

            <div class="form-field">
              <label for="lp-message" class="form-field__label">
                A Few Words About Your Day <span class="form-field__optional">(optional)</span>
              </label>
              <textarea
                id="lp-message"
                name="message"
                rows="4"
                placeholder="The feel, the place, anything that helps me understand the day."
                class="form-field__textarea"
              ></textarea>
            </div>
          </fieldset>

          <!-- Submit -->
          <div class="form-submit">
            <div class="form-submit__break"></div>
            <button
              id="lp-submit-btn"
              type="submit"
              class="form-submit__button magnetic w-full sm:w-auto"
            >
              Send Inquiry
              <span class="form-submit__arrow" aria-hidden="true">&rarr;</span>
            </button>
            <p class="form-submit__note">
              <span class="form-field__required not-italic" aria-hidden="true">*</span> required · I reply within 24 hours
            </p>
          </div>
        </form>

        <!-- Success state -->
        <div id="lp-success" class="hidden bg-surface-dim p-6 md:p-10" role="status" aria-live="polite">
          <p class="text-label-md text-on-surface-muted mb-4">Thank You</p>
          <h3 class="text-heading-lg font-serif">Your note is on its way.</h3>
          <p class="text-body-lg text-on-surface-variant mt-4" style="max-width: 50ch;">
            I'll read it carefully and reply within 24 hours to start planning something with you.
          </p>
        </div>

        <!-- Error state -->
        <div id="lp-error" class="hidden bg-surface-dim p-6" role="alert" aria-live="assertive">
          <p class="text-label-md text-on-surface">Something went wrong</p>
          <p class="mt-1 text-body-lg text-on-surface-variant">
            Please try again, or reach me directly at <a href={`mailto:${site.email}`} class="underline hover:text-on-surface cubic-ease">{site.email}</a>.
          </p>
          <button
            id="lp-retry-btn"
            type="button"
            class="mt-3 text-label-md text-on-surface-variant hover:text-on-surface cubic-ease underline"
            style="transition-duration: var(--duration-hover);"
          >
            Try again
          </button>
        </div>
      </div>

      <!-- Calendly CTA -->
      <div class="mt-16 text-center reveal">
        <div class="h-px bg-ghost max-w-xs mx-auto mb-8"></div>
        <p class="text-heading-md font-serif italic mb-3">Have any questions?</p>
        <p class="text-body-md text-on-surface-variant mb-8 mx-auto" style="max-width: 40ch;">
          Book a free 30-minute consultation. No pressure, just a conversation.
        </p>
