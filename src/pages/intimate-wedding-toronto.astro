  <!-- ═══ Meta Pixel Lead-event gate (45s dwell OR 60% scroll) ═══
       Rationale: paid-LP best practice per council review 2026-04-17. Firing
       Lead on every arrival trains Meta's algorithm toward form-mashers and
       diaspora tire-kickers. This gate only signals "qualified engagement"
       to Meta once a visitor has demonstrated real intent. Safe to ship
       before Meta Pixel base code is installed — `fbq` calls are no-ops
       until it lands in BaseLayout. -->
  <script is:inline>
    (function () {
      var DWELL_MS = 45000;
      var SCROLL_PCT = 0.6;
      var FLAG_KEY = 'ad_qualified_engagement';
      var fired = false;

      if (sessionStorage.getItem(FLAG_KEY) === 'true') {
        return; // already qualified this session
      }

      function qualify(source) {
        if (fired) return;
        fired = true;
        try { sessionStorage.setItem(FLAG_KEY, 'true'); } catch (_) {}
        if (typeof window.fbq === 'function') {
          window.fbq('trackCustom', 'QualifiedEngagement', { source: source });
        }
      }

      // 45-second dwell timer
      var dwellTimer = setTimeout(function () { qualify('dwell'); }, DWELL_MS);

      // Scroll tracker
      function onScroll() {
        var h = document.documentElement;
        var total = h.scrollHeight - h.clientHeight;
        if (total <= 0) return;
        var pct = h.scrollTop / total;
        if (pct >= SCROLL_PCT) {
          qualify('scroll');
          window.removeEventListener('scroll', onScroll);
          clearTimeout(dwellTimer);
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>

  <!-- ═══ Sticky mobile CTA — shows after hero, hides near form ═══ -->
  <div
    id="lp-sticky-cta"
    class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-background border-t border-ghost translate-y-full transition-transform pointer-events-none"
    style="transition-duration: 400ms; transition-timing-function: var(--ease-gallery);"
    aria-hidden="true"
  >
    <div class="px-5 py-4 safe-area-bottom">
      <a
        href="#inquire"
        class="flex w-full items-center justify-center whitespace-nowrap px-6 py-4 bg-primary text-on-dark text-label-md cubic-ease hover:bg-primary-hover"
        style="transition-duration: var(--duration-hover);"
      >
        Begin the Conversation
      </a>
    </div>
  </div>

  <script is:inline>
    (function () {
      function initStickyCta() {
        var cta = document.getElementById('lp-sticky-cta');
        var inquire = document.getElementById('inquire');
        if (!cta || !inquire) return;

        var HERO_THRESHOLD = 400;
        var shown = false;
        var inquireVisible = false;

        function update() {
          var shouldShow = window.scrollY > HERO_THRESHOLD && !inquireVisible;
          if (shouldShow !== shown) {
            shown = shouldShow;
            if (shown) {
              cta.classList.remove('translate-y-full', 'pointer-events-none');
              cta.setAttribute('aria-hidden', 'false');
            } else {
              cta.classList.add('translate-y-full', 'pointer-events-none');
              cta.setAttribute('aria-hidden', 'true');
            }
          }
        }

        // Observe the inquiry section — hide sticky CTA when user reaches the form
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              inquireVisible = e.isIntersecting;
              update();
            });
          }, { threshold: 0.15 });
          io.observe(inquire);
        }

        window.addEventListener('scroll', update, { passive: true });
        update();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initStickyCta);
      } else {
        initStickyCta();
      }
    })();
  </script>

  <!-- flatpickr script (loaded once; no-op if page already has it) -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13"></script>

  <!-- ═══ LP inquiry form init + Lead event gate ═══
       Lead fires ONLY if visitor qualified (45s dwell OR 60% scroll).
       Prevents pixel poisoning per council review 2026-04-17. -->
  <script is:inline>
    (function () {
      function initLpInquiryForm() {
        var form = document.getElementById('lp-inquiry-form');
        var submitBtn = document.getElementById('lp-submit-btn');
        var successEl = document.getElementById('lp-success');
        var errorEl = document.getElementById('lp-error');
        var retryBtn = document.getElementById('lp-retry-btn');
        if (!form || !submitBtn || !successEl || !errorEl) return;

        var originalBtnText = submitBtn.textContent;

        // Init flatpickr on the ceremony date input
        var dateInput = document.getElementById('lp-date');
        if (dateInput && typeof window.flatpickr === 'function') {
          window.flatpickr(dateInput, {
            dateFormat: 'Y-m-d',
            altInput: true,
            altFormat: 'F j, Y',
            minDate: 'today',
            disableMobile: false,
            monthSelectorType: 'static'
          });
        }

        // Phone validation: strip non-digits, require ≥10 digits (NANP standard)
        function isValidPhone(value) {
          var digits = value.replace(/\D/g, '');
          return digits.length >= 10 && digits.length <= 15;
        }

        function clearFieldError(field) {
          var wrap = field.closest('.form-field');
          var errMsg = wrap ? wrap.querySelector('.form-error-msg') : null;
          if (errMsg) { errMsg.textContent = ''; errMsg.classList.add('hidden'); }
          field.removeAttribute('aria-invalid');
        }

        function showFieldError(field, message) {
          var wrap = field.closest('.form-field');
          var errMsg = wrap ? wrap.querySelector('.form-error-msg') : null;
          if (errMsg) { errMsg.textContent = message; errMsg.classList.remove('hidden'); }
          field.setAttribute('aria-invalid', 'true');
        }

        function validateForm() {
          var valid = true;
          var firstInvalid = null;
          var requiredFields = form.querySelectorAll('[required]');
          requiredFields.forEach(function (field) {
            clearFieldError(field);
            if (!field.value.trim()) {
              showFieldError(field, 'This field is required.');
              valid = false;
              if (!firstInvalid) firstInvalid = field;
            } else if (field.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value.trim())) {
              showFieldError(field, 'Please enter a valid email address.');
              valid = false;
              if (!firstInvalid) firstInvalid = field;
            } else if (field.type === 'tel' && !isValidPhone(field.value)) {
              showFieldError(field, 'Please enter a valid phone number.');
              valid = false;
              if (!firstInvalid) firstInvalid = field;
            }
          });
          if (firstInvalid) firstInvalid.focus();
          return valid;
        }

        form.querySelectorAll('input, textarea, select').forEach(function (field) {
          field.addEventListener('input', function () { clearFieldError(field); });
          field.addEventListener('change', function () { clearFieldError(field); });
        });

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          if (!validateForm()) return;
          var honeypot = form.querySelector('[name="_gotcha"]');
          if (honeypot && honeypot.value) return;

          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';
          errorEl.classList.add('hidden');

          var formData = new FormData(form);
          formData.delete('_gotcha');

          fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          }).then(function (response) {
            if (!response.ok) throw new Error('Form submission failed: ' + response.status);
            form.classList.add('hidden');
            successEl.classList.remove('hidden');
            successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });

            // ─── Ad-platform conversion events, gated ───
            // Fire ONLY if the visitor qualified (45s dwell OR 60% scroll).
            // Prevents Meta + Google from optimizing toward tire-kickers
            // per council review 2026-04-17.
            var qualified = sessionStorage.getItem('ad_qualified_engagement') === 'true';
            if (qualified) {
              // Meta Pixel Lead event
              if (typeof window.fbq === 'function') {
                window.fbq('track', 'Lead', {
                  content_name: 'intimate-wedding-toronto',
                  content_category: 'wedding-inquiry'
                });
              }
              // Google Ads conversion — Intimate Wedding Inquiry
              if (typeof window.gtag === 'function') {
                window.gtag('event', 'conversion', {
                  'send_to': 'AW-18099849669/T8MMCMX8gp4cEMWT17ZD',
                  'value': 650.0,
                  'currency': 'CAD',
                  'transaction_id': ''
                });
              }
            }
          }).catch(function () {
            errorEl.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = originalBtnText;
          });
        });

        if (retryBtn) {
          retryBtn.addEventListener('click', function () {
            errorEl.classList.add('hidden');
          });
        }

        // ─── Calendly CTA click conversion ───
        // Fire Meta Lead + Google Ads conversion when a qualified visitor
        // clicks any Calendly link on this page (same gate as form submit).
        var calendlyLinks = document.querySelectorAll('a[href*="calendly.com"]');
        calendlyLinks.forEach(function (link) {
          link.addEventListener('click', function () {
            var qualified = sessionStorage.getItem('ad_qualified_engagement') === 'true';
            if (!qualified) return;
            if (typeof window.fbq === 'function') {
              window.fbq('track', 'Lead', {
                content_name: 'intimate-wedding-toronto-calendly',
                content_category: 'wedding-consultation'
              });
            }
            if (typeof window.gtag === 'function') {
              window.gtag('event', 'conversion', {
                'send_to': 'AW-18099849669/T8MMCMX8gp4cEMWT17ZD',
                'value': 650.0,
                'currency': 'CAD',
                'transaction_id': ''
              });
            }
          });
        });

        // ─── Pricing card "Inquire" → scroll to inline form + prefill ───
        // The LP uses this inline form instead of a ContactModal, so we
        // intercept PricingCard's [data-open-modal="contact-modal"] clicks,
        // prefill the hidden package context fields, and smooth-scroll
        // the visitor to #inquire.
        var pkgIdField = document.getElementById('lp-package-id');
        var pkgNameField = document.getElementById('lp-package-name');
        var inquireAnchor = document.getElementById('inquire');
        var pricingInquireBtns = document.querySelectorAll('[data-open-modal="contact-modal"]');
        pricingInquireBtns.forEach(function (btn) {
          btn.addEventListener('click', function (e) {
            e.preventDefault();
            var pkgId = btn.getAttribute('data-package') || '';
            var pkgName = btn.getAttribute('data-package-name') || '';
            if (pkgIdField) pkgIdField.value = pkgId;
            if (pkgNameField) pkgNameField.value = pkgName;
            if (inquireAnchor) {
              inquireAnchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
              setTimeout(function () {
                var firstField = document.getElementById('lp-name');
                if (firstField && typeof firstField.focus === 'function') {
                  firstField.focus({ preventScroll: true });
                }
              }, 600);
            }
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLpInquiryForm);
      } else {
        initLpInquiryForm();
      }
    })();
  </script>
</BaseLayout>
