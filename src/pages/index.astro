---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import InvestmentSection from '../components/global/InvestmentSection.astro';
import GearBreaker from '../components/global/GearBreaker.astro';
import MobileGearBreaker from '../components/global/MobileGearBreaker.astro';
import RecentWork from '../components/global/RecentWork.astro';
import MobileRecentWork from '../components/global/MobileRecentWork.astro';
import testimonials from '../data/testimonials.json';

// Hero
import heroImage from '../assets/images/hero/hero-main.jpg';

// Signature Style pair
import signatureLeft from '../assets/images/homepage/homepage-07.jpg';
import signatureRight from '../assets/images/portfolio/alex-aziz/05.jpg';

// Investment
import investmentImage from '../assets/images/homepage/homepage-04.jpg';

const testimonial = testimonials[0];

const faqItems = [
  {
    question: 'When is the best time to shoot?',
    answer: 'Golden hour, always. Early morning or late afternoon light is unmatched. Overcast days work beautifully too. I will guide you on timing.',
  },
  {
    question: 'Will you help us with posing?',
    answer: 'I prompt, not pose. Natural movements, real reactions. The photos end up looking and feeling like you.',
  },
  {
    question: 'What if it rains?',
    answer: 'I still shoot. Covered spots, indoor spaces, or your home. Rain photos can be stunning. If you need to reschedule, 48 hours notice is all I ask.',
  },
  {
    question: 'How long until I get my photos?',
    answer: 'Sneak peek within days. Full gallery in 2 to 3 months. Priority 2-3 week delivery is available for an additional fee.',
  },
];

// Journal: latest two blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const journalPosts = allPosts
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 2);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'AD Photography',
    url: 'https://kashklicks.ca',
    description:
      'Toronto wedding photographer and filmmaker capturing candid, cinematic pre-wedding and wedding photography across the GTA and Canada.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
];
---

<BaseLayout
  title="Home"
  description="Toronto wedding photographer and filmmaker. AD Photography captures candid, cinematic pre-wedding and wedding photography across the GTA and Canada. Packages from $350."
  transparentHeader={true}
  showSplash={false}
  jsonLd={jsonLd}
>
  <script is:inline>
    // Splash temporarily disabled. Pre-seed the "seen" flag so the hero
    // entrance script in this file (and the SoundManager) treat the visit
    // as a return visit and render the hero immediately without waiting
    // for the splash:done event. To re-enable: flip showSplash back to
    // true in the BaseLayout props above and delete this seeding line.
    if (typeof sessionStorage !== 'undefined') {
      sessionStorage.setItem('kk-splash-seen', 'true');
    }
  </script>

  <style is:global>
    html.splash-pending .home-hero__copy .logo-mark,
    html.splash-pending .home-hero__copy h1,
    html.splash-pending .home-hero__copy h2,
    html.splash-pending .home-hero .hero-cta,
    html.splash-pending .home-hero .gallery-caption,
    html.splash-pending .home-hero .scroll-rail-wrap {
      opacity: 0;
    }

    /* Lock each tagline char's formatting context + GPU layer so the glyph shape
       (notably the Cormorant "f" with its long descender + crossbar) doesn't
       shift between opacity phases. Mobile rasterization is the most sensitive:
       subpixel antialiasing, GPU layer toggling, and OpenType contextual
       alternates can each cause the same char to re-render with different
       pixels mid-animation. All three are neutralised below. */
    .home-hero__copy h2[data-entrance-defer] .tagline-char {
      display: inline-block;
      transform: translate3d(0, 0, 0); /* permanent GPU layer — no re-rasterization */
      backface-visibility: hidden;
      will-change: opacity;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: geometricPrecision;
      font-feature-settings: "kern" 0, "liga" 0, "calt" 0;
      font-synthesis: none;
    }

    /* Desktop: two sentences flow inline. Mobile: each sentence on its own line. */
    .home-hero__copy h2[data-entrance-defer] .tagline-line {
      display: inline;
    }
    @media (max-width: 767px) {
      .home-hero__copy h2[data-entrance-defer] .tagline-line {
        display: block;
      }
    }

    /* Word wrapper keeps words atomic — lines only break between words. */
    .home-hero__copy h2[data-entrance-defer] .tagline-word {
      display: inline-block;
      white-space: nowrap;
    }

    /* Mobile: hero text sits higher so the photograph takes the lower half.
       Desktop stays true-centered. */
    @media (max-width: 767px) {
      .home-hero__copy {
        justify-content: flex-start;
        padding-top: 18vh;
      }
    }

    /* Per-character split produced by initSectionHeadings (desktop only).
       Word wrapper keeps a word atomic so line wrapping happens only at spaces;
       chars inside a word are inline-block (required for transform) and the
       word itself uses white-space: nowrap. */
    [data-gsap-chars] .gsap-word {
      display: inline-block;
      white-space: nowrap;
    }
    [data-gsap-chars] .gsap-char {
      display: inline-block;
      will-change: transform, opacity;
      /* Per-char splitting breaks the italic's natural letter flow, which
         triggers OpenType contextual alternates/ligatures/kerning pairs to
         fall back to wrong glyph forms (most visible: "d" renders as its
         isolated cursive variant and reads like "a"). Neutralise all
         position-aware features so each char renders in its default form. */
      font-feature-settings: "kern" 0, "liga" 0, "calt" 0, "clig" 0, "dlig" 0, "hlig" 0;
      font-variant-ligatures: none;
      font-kerning: none;
    }
  </style>

  <!-- ═══ 1. HERO ═══ -->
  <section class="home-hero relative h-[100svh] min-h-[600px] w-full overflow-hidden bg-surface-container">
    <Image
      src={heroImage}
      alt="Toronto wedding photographer AD Photography, Mehak and Manal session"
      class="home-hero__image absolute inset-0 w-full h-full object-cover"
      widths={[768, 1280, 1600]}
      sizes="100vw"
      quality={72}
      format="avif"
      loading="eager"
      fetchpriority="high"
    />
    <div class="home-hero__overlay absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>

    <!-- Informational H1 (keyword-rich) styled small; emotional H2 (tagline) styled large -->
    <div class="home-hero__copy absolute inset-0 flex flex-col items-center justify-center text-center px-6">
      <p class="logo-mark text-[0.8125rem] text-on-dark eyebrow-rule eyebrow-rule-center eyebrow-rule-on-dark mb-8">AD Photos</p>
      <h1 class="text-body-md text-on-dark/70 font-normal order-2 mt-6 max-w-[36ch] mx-auto">Your Toronto wedding photographer and filmmaker, telling real love stories.</h1>
      <h2 class="text-display-lg text-on-dark char-reveal order-1" data-fade-prefix-count="12" data-fade-prefix-opacity="0.4">Moments fade. Memories don't.</h2>
    </div>

    <script is:inline>
      // On first visit the hero tagline is driven by the GSAP entrance timeline,
      // not by char-reveal.ts. Strip the class before the module script picks it up.
      if (
        typeof sessionStorage !== 'undefined' &&
        sessionStorage.getItem('kk-splash-seen') !== 'true'
      ) {
        const heroTag = document.querySelector('.home-hero__copy h2.char-reveal');
        if (heroTag) {
          heroTag.classList.remove('char-reveal');
          heroTag.setAttribute('data-entrance-defer', 'true');
        }
      }
    </script>

    <!-- Caption -->
    <div class="hidden md:block absolute bottom-20 left-8 md:left-16 gallery-caption text-on-dark/90">
      <p class="font-medium">Mehak & Manal</p>
      <p class="text-on-dark/60">Kelowna, BC 2026</p>
    </div>

    <!-- Hero CTA anchored above the scroll rail -->
    <div class="absolute left-1/2 -translate-x-1/2 hero-cta z-10">
      <a
        href="/contact"
        class="magnetic inline-flex items-center justify-center whitespace-nowrap px-9 py-3.5 border border-on-dark/70 text-on-dark font-sans text-[0.8125rem] tracking-[0.12em] uppercase hover:bg-on-dark hover:text-on-surface cubic-ease"
        style="transition-duration: var(--duration-hover);"
      >
        Begin Your Story
      </a>
    </div>

    <!-- Scroll indicator: hairline rail with a travelling dot -->
    <div class="absolute left-1/2 -translate-x-1/2 scroll-rail-wrap" aria-hidden="true">
      <span class="scroll-rail"></span>
    </div>
  </section>

  <!-- ═══ 2. SIGNATURE STYLE — PHOTO PAIR ═══ -->
  <section class="py-[var(--spacing-section)]">
    <div class="container-editorial" style="margin-bottom: var(--spacing-block);">
      <div class="grid-editorial items-end">
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted eyebrow-rule mb-4">Signature Style</p>
          <h2 class="text-display-md text-on-surface measure-tight" data-gsap-chars>Quiet moments, real connection.</h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 mt-6 md:mt-0 reveal stagger-2">
          <p class="text-quote text-on-surface-variant measure-wide">
            No posing, no pretending. Just the in-between moments that end up meaning the most.
          </p>
        </div>
      </div>
    </div>
    <div class="grid-editorial">
      <div class="col-span-12 md:col-span-7 gallery-frame hover-zoom reveal-left">
        <Image
          src={signatureLeft}
          alt="Candid Toronto wedding photography, Ayushi and Parth"
          class="parallax-img"
          widths={[640, 960, 1280]}
          sizes="(max-width: 768px) 100vw, 58vw"
          quality={80}
        />
        <div class="gallery-caption text-on-surface">
          <p class="font-medium">Ayushi + Parth</p>
          <p class="text-on-surface-variant">Toronto</p>
        </div>
      </div>
      <div class="col-span-12 md:col-span-5 mt-3 md:mt-24 gallery-frame hover-zoom reveal-right stagger-2">
        <Image
          src={signatureRight}
          alt="Toronto pre-wedding portrait, Alex and Aziz"
          class="parallax-img"
          widths={[640, 960]}
          sizes="(max-width: 768px) 100vw, 42vw"
          quality={80}
        />
        <div class="gallery-caption text-on-surface">
          <p class="font-medium">Alex + Aziz</p>
          <p class="text-on-surface-variant">Toronto</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BREAKER · THE KIT ═══
       Two independent components per the mobile/desktop separation rule.
       GearBreaker renders ≥1024px (asymmetric chapter-page layout).
       MobileGearBreaker renders <1024px (vertical stack on hairline rail). -->
  <GearBreaker />
  <MobileGearBreaker />

  <!-- ═══ 3. INVESTMENT ═══ -->
  <InvestmentSection
    image={investmentImage}
    imageAlt="Full-day wedding photography coverage in Toronto by AD Photography"
  />

  <!-- ═══ 4. TESTIMONIAL ═══ -->
  <section class="py-[var(--spacing-section)] bg-white">
    <div class="container-editorial text-center max-w-3xl mx-auto">
      <p class="text-label-md text-on-surface-muted reveal eyebrow-rule eyebrow-rule-center mb-10">Kind Words</p>
      <blockquote class="text-quote text-on-surface mb-8 reveal stagger-1">
        "{testimonial.quote}"
      </blockquote>
      <p class="text-label-md text-on-surface-variant reveal stagger-2">
        {testimonial.name} &middot; {testimonial.event}
      </p>
    </div>
  </section>

  <!-- ═══ 5. RECENT WORK ═══
       Two independent components per the mobile/desktop separation rule.
       RecentWork renders ≥1024px (column grid, corner ticks, anchored
       outlined numerals). MobileRecentWork renders <1024px (vertical
       stack, inline numerals above each frame). -->
  <RecentWork />
  <MobileRecentWork />

  <!-- ═══ BREAKER · WHERE I'VE SHOT ═══
       Horizontal motion breaker — continuous right-to-left marquee of
       destinations. Different axis and different rhythm than every other
       section's vertical reveal. -->
  <section class="breaker-marquee" aria-label="Destinations I've photographed">
    <div class="breaker-marquee__track" aria-hidden="true">
      <div class="breaker-marquee__set">
        <span>Toronto</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Muskoka</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Niagara</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Kelowna</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Madeira</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Porto</span>
        <span class="breaker-marquee__dot">·</span>
      </div>
      <div class="breaker-marquee__set">
        <span>Toronto</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Muskoka</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Niagara</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Kelowna</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Madeira</span>
        <span class="breaker-marquee__dot">·</span>
        <span>Porto</span>
        <span class="breaker-marquee__dot">·</span>
      </div>
    </div>
  </section>

  <!-- ═══ 6. FAQ ═══ -->
  <section class="py-[var(--spacing-section)] bg-surface-dim">
    <div class="container-editorial">
      <div class="grid-editorial items-end mb-[var(--spacing-block)]">
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted eyebrow-rule mb-4">Questions</p>
          <h2 class="text-display-md text-on-surface measure-tight" data-gsap-chars>Things couples ask me.</h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 mt-6 md:mt-0 reveal stagger-2">
          <p class="text-quote text-on-surface-variant measure-wide">
            Short answers to the questions that come up most. Full list lives on the services pages.
          </p>
        </div>
      </div>
      <div class="grid-editorial">
        <div class="col-span-12 md:col-span-10 md:col-start-2 reveal">
          <FAQAccordion items={faqItems} />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ 7. JOURNAL ═══ -->
  <section class="py-[var(--spacing-section)] bg-white">
    <div class="container-editorial">
      <div class="text-center mb-[var(--spacing-block)]">
        <p class="text-label-md text-on-surface-muted reveal eyebrow-rule eyebrow-rule-center mb-4">The Journal</p>
        <h2 class="text-display-md text-on-surface" data-gsap-chars>Stories & guides.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-12">
        {journalPosts.map((post, i) => (
          <a href={`/blog/${post.id}`} class="group block reveal" style={`transition-delay: ${(i + 1) * 100}ms;`}>
            <div class="aspect-[3/2] overflow-hidden bg-surface-dim">
              <Image
                src={post.data.coverImage}
                alt={post.data.coverImageAlt}
                class="w-full h-full object-cover cubic-ease group-hover:scale-[1.02]"
                widths={[400, 600]}
                sizes="(max-width: 768px) 100vw, 33vw"
                quality={80}
                style="transition-duration: var(--duration-slow);"
              />
            </div>
            <h3 class="text-heading-md text-on-surface group-hover:text-on-surface-variant cubic-ease mt-4" style="transition-duration: var(--duration-hover);">
              {post.data.title}
            </h3>
          </a>
        ))}
      </div>
      <div class="text-center mt-[var(--spacing-block)] reveal">
        <a href="/blog" class="magnetic inline-flex items-center text-label-md text-on-surface border-b border-on-surface pb-1 hover:text-on-surface-variant hover:border-on-surface-variant cubic-ease" style="transition-duration: var(--duration-hover);">Read the journal</a>
      </div>
    </div>
  </section>

  <!-- ═══ 8. CONTACT CTA ═══ -->
  <section class="relative py-[var(--spacing-section)] overflow-hidden">
    <video muted loop playsinline preload="none" poster="/og-default.jpg" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" data-autoplay>
      <source src="https://kashklicks.b-cdn.net/kashklicks_backgroundMedia.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container-editorial relative z-10">
      <div class="flex flex-col items-center text-center">
        <p class="text-label-md text-on-dark-variant reveal eyebrow-rule eyebrow-rule-center eyebrow-rule-on-dark mb-6">Ready?</p>
        <h2 class="text-display-md text-on-dark mb-4" data-gsap-chars>Start the Conversation</h2>
        <p class="text-body-lg text-on-dark/70 mb-10 reveal stagger-2">
          Let's talk about your day. No obligations, just a conversation.
        </p>
        <div class="reveal stagger-3">
          <a href="/contact" class="magnetic inline-flex items-center justify-center whitespace-nowrap px-10 py-4 bg-white text-on-surface font-sans text-[0.875rem] tracking-[0.08em] uppercase hover:bg-white/90 cubic-ease" style="transition-duration: var(--duration-hover);">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initHomeHero = () => {
    const hero = document.querySelector<HTMLElement>('.home-hero');
    if (!hero) return () => {};

    const mm = gsap.matchMedia();

    // Desktop + tablet: pinned ken-burns. Respects reduced-motion.
    mm.add(
      {
        desktop: '(min-width: 768px) and (prefers-reduced-motion: no-preference)',
      },
      () => {
        gsap
          .timeline({
            scrollTrigger: {
              trigger: hero,
              start: 'top top',
              end: '+=100%',
              scrub: 1,
              pin: true,
              anticipatePin: 1,
              invalidateOnRefresh: true,
            },
          })
          .to('.home-hero__image', { scale: 1.12, yPercent: -4, ease: 'none' }, 0)
          .to('.home-hero__overlay', { opacity: 0.6, ease: 'none' }, 0)
          .to('.home-hero__copy', { yPercent: -18, opacity: 0, ease: 'power1.in' }, 0);
      }
    );

    return () => mm.revert();
  };

  const initHeroEntrance = () => {
    const firstVisit = sessionStorage.getItem('kk-splash-seen') !== 'true';
    if (!firstVisit) {
      document.documentElement.classList.remove('splash-pending');
      return () => {};
    }

    // Split the hero tagline into per-char spans so GSAP can type it out.
    // Each sentence goes in its own .tagline-line wrapper so mobile CSS can
    // force sentence-level line breaks instead of wrapping mid-word.
    const h2 = document.querySelector<HTMLHeadingElement>(
      '.home-hero__copy h2[data-entrance-defer]'
    );
    let h2Chars: HTMLElement[] = [];
    if (h2 && !h2.dataset.splitDone) {
      const fullText = h2.textContent || '';
      h2.textContent = '';
      h2.setAttribute('aria-label', fullText);
      const boundary = fullText.indexOf('. ');
      const sentences = boundary > -1
        ? [fullText.slice(0, boundary + 1), fullText.slice(boundary + 2)]
        : [fullText];
      sentences.forEach((sentence, index) => {
        const line = document.createElement('span');
        line.className = 'tagline-line';
        // Wrap each word so the browser can only line-break at real word
        // boundaries, never mid-word into inline-block char shards.
        const tokens = sentence.split(/(\s+)/);
        tokens.forEach((token) => {
          if (token === '') return;
          if (/^\s+$/.test(token)) {
            line.appendChild(document.createTextNode(' '));
            return;
          }
          const word = document.createElement('span');
          word.className = 'tagline-word';
          for (const char of token) {
            const span = document.createElement('span');
            span.className = 'tagline-char';
            span.textContent = char;
            span.setAttribute('aria-hidden', 'true');
            word.appendChild(span);
          }
          line.appendChild(word);
        });
        h2.appendChild(line);
        if (index < sentences.length - 1) {
          h2.appendChild(document.createTextNode(' '));
        }
      });
      h2.dataset.splitDone = 'true';
      h2Chars = Array.from(h2.querySelectorAll<HTMLElement>('.tagline-char'));
    }

    const targets = [
      '.home-hero__copy .logo-mark',
      '.home-hero__copy h1',
      '.home-hero .hero-cta',
      '.home-hero .gallery-caption',
      '.home-hero .scroll-rail-wrap',
    ];

    // Take over from the anti-FOUC CSS with inline GSAP styles.
    gsap.set(targets, { opacity: 0 });
    gsap.set(h2Chars, { opacity: 0 });
    if (h2) gsap.set(h2, { opacity: 1 });
    document.documentElement.classList.remove('splash-pending');

    // "Moments fade." → first 12 chars. After the tagline types in, these fade away
    // while "Memories don't." stays — the phrase demonstrates itself.
    const momentsFadeChars = h2Chars.slice(0, 12);

    const runEntrance = () => {
      gsap
        .timeline({ defaults: { ease: 'power3.out' } })
        .fromTo(
          '.home-hero__copy .logo-mark',
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.6 },
          0
        )
        .to(
          h2Chars,
          { opacity: 1, duration: 0.35, stagger: 0.035, ease: 'power1.out' },
          0.2
        )
        .addLabel('taglineIn', '>')
        .fromTo(
          '.home-hero__copy h1',
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0, duration: 0.6 },
          'taglineIn+=0.05'
        )
        .fromTo(
          '.home-hero .hero-cta',
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0, duration: 0.55 },
          '-=0.25'
        )
        .fromTo(
          '.home-hero .gallery-caption',
          { opacity: 0, y: 8 },
          { opacity: 1, y: 0, duration: 0.55 },
          '-=0.4'
        )
        .fromTo(
          '.home-hero .scroll-rail-wrap',
          { opacity: 0 },
          { opacity: 1, duration: 0.5 },
          '-=0.3'
        )
        // "Moments fade." — the words fade (but linger faintly) while "Memories don't." stays
        .to(
          momentsFadeChars,
          { opacity: 0.32, duration: 0.5, stagger: 0.035, ease: 'power1.in' },
          'taglineIn+=0.9'
        );
    };

    document.addEventListener('splash:done', runEntrance, { once: true });
    return () => document.removeEventListener('splash:done', runEntrance);
  };

  // Desktop-only: upgrade section display headings + pull-quote from the
  // existing .reveal IntersectionObserver to a GSAP ScrollTrigger char-reveal.
  // One-shot timeline per element — no scrub, no pin, no paint cost after the
  // heading enters view. Mobile and reduced-motion keep their native render.
  const initSectionHeadings = () => {
    const mm = gsap.matchMedia();
    mm.add(
      '(min-width: 768px) and (prefers-reduced-motion: no-preference)',
      () => {
        const targets = document.querySelectorAll<HTMLElement>('[data-gsap-chars]');
        targets.forEach((el) => {
          if (el.dataset.charsSplit === 'true') return;
          const text = (el.textContent || '').trim();
          if (!text) return;
          el.setAttribute('aria-label', text);
          el.textContent = '';
          // Split into word groups first so line wrapping can only happen at
          // real word boundaries. Chars inside a word wrapper stay atomic.
          const words = text.split(/(\s+)/);
          for (const token of words) {
            if (/^\s+$/.test(token)) {
              el.appendChild(document.createTextNode(' '));
              continue;
            }
            const word = document.createElement('span');
            word.className = 'gsap-word';
            word.setAttribute('aria-hidden', 'true');
            for (const char of token) {
              const span = document.createElement('span');
              span.className = 'gsap-char';
              span.textContent = char;
              word.appendChild(span);
            }
            el.appendChild(word);
          }
          el.dataset.charsSplit = 'true';

          const chars = el.querySelectorAll<HTMLElement>('.gsap-char');
          gsap.set(chars, { opacity: 0, yPercent: 18 });

          gsap.to(chars, {
            opacity: 1,
            yPercent: 0,
            duration: 0.7,
            ease: 'power2.out',
            stagger: 0.018,
            scrollTrigger: {
              trigger: el,
              start: 'top 82%',
              once: true,
            },
          });
        });
      }
    );
    return () => mm.revert();
  };

  let cleanupPin = initHomeHero();
  let cleanupEntrance = initHeroEntrance();
  let cleanupHeadings = initSectionHeadings();

  document.addEventListener('astro:page-load', () => {
    cleanupPin?.();
    cleanupEntrance?.();
    cleanupHeadings?.();
    cleanupPin = initHomeHero();
    cleanupEntrance = initHeroEntrance();
    cleanupHeadings = initSectionHeadings();
  });
  document.addEventListener('astro:before-preparation', () => {
    cleanupPin?.();
    cleanupEntrance?.();
    cleanupHeadings?.();
  });
</script>
