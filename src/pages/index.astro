---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialCard from '../components/ui/TestimonialCard.astro';
import Button from '../components/ui/Button.astro';
import { Image } from 'astro:assets';

import testimonials from '../data/testimonials.json';
import portfolio from '../data/portfolio.json';
import site from '../data/site.json';

import heroImage from '../assets/images/hero/hero-main.jpg';

// Dynamic portfolio image imports
const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const featuredWork = portfolio.filter((p) => p.featured).slice(0, 3);

const reviewSchemas = testimonials.map((t) => ({
  '@type': 'Review',
  reviewRating: {
    '@type': 'Rating',
    ratingValue: t.rating,
    bestRating: 5,
  },
  author: { '@type': 'Person', name: t.name },
  reviewBody: t.quote,
}));

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
};

const jsonLd = [websiteSchema, ...reviewSchemas.map((r) => ({ '@context': 'https://schema.org', ...r }))];
---

<BaseLayout
  title="Home"
  description="AD Photography. Toronto wedding photographer and videographer. Cinematic pre-wedding, wedding, and engagement photography across the GTA and Canada."
  transparentHeader={true}
  showSplash={true}
  jsonLd={jsonLd}
>
  <!-- ═══ HERO ═══ -->
  <section class="relative h-screen flex items-end -mt-20 lg:-mt-24">
    <Image
      src={heroImage}
      alt="Couple at sunset, AD Photography Toronto wedding photography"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      widths={[768, 1200, 1920]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/20 to-[var(--color-background)]" />

    <div class="relative container-editorial pb-16 sm:pb-20 lg:pb-24">
      <h1 class="text-display-lg text-on-dark max-w-4xl">
        Warm, candid wedding and civil ceremony photography with quiet luxury.
      </h1>
      <div class="mt-8">
        <Button href="/portfolio" variant="secondary" class="text-on-dark border-white/30 hover:border-white/60">View Portfolio</Button>
      </div>
    </div>
  </section>

  <!-- ═══ INTRO / THE APPROACH ═══ -->
  <section style="padding-block: var(--spacing-section);">
    <div class="container-editorial">
      <div class="grid-editorial">
        <div class="col-span-12 lg:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted">The Approach</p>
          <h2 class="text-heading-lg italic mt-4 text-on-surface">An observant eye for the unscripted.</h2>
        </div>
        <div class="col-span-12 lg:col-start-7 lg:col-span-6 reveal stagger-1">
          <p class="text-body-lg text-on-surface-variant">
            We photograph the moments between moments. The glance across the room, the quiet laugh, the unplanned gesture that says everything. Our work is rooted in patience, close observation, and a deep respect for what is already happening.
          </p>
          <p class="text-body-md text-on-surface-variant mt-6">
            Every session is shaped by calm, minimal direction. We guide when it helps and step back when the real story is unfolding. The result is a collection that feels like you, not like a shoot.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CURATED COLLECTIONS ═══ -->
  <section class="bg-surface-dim" style="padding-block: var(--spacing-section);">
    <div class="container-editorial">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12 reveal">
        <div>
          <p class="text-label-md text-on-surface-muted">Featured Work</p>
          <h2 class="text-heading-lg text-on-surface mt-2">Curated Collections</h2>
        </div>
        <a href="/portfolio" class="text-label-md text-on-surface-variant hover:text-on-surface cubic-ease" style="transition-duration: var(--duration-hover);">
          View All Collections &rarr;
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredWork.map((entry, i) => {
          const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
          const img = portfolioImages[imgPath]?.default;
          return img ? (
            <a href={`/portfolio/${entry.slug}`} class={`group block reveal stagger-${i + 1}`}>
              <div class="aspect-[2/3] overflow-hidden bg-surface-container">
                <Image
                  src={img}
                  alt={`${entry.couple}, ${entry.location}`}
                  widths={[400, 600]}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  class="w-full h-full object-cover cubic-ease group-hover:scale-[1.02]"
                  style="transition-duration: var(--duration-slow);"
                  loading="lazy"
                />
              </div>
              <h3 class="text-heading-md text-on-surface mt-4">{entry.couple}</h3>
              <p class="text-label-md text-on-surface-muted mt-1">{entry.location}</p>
            </a>
          ) : null;
        })}
      </div>
    </div>
  </section>

  <!-- ═══ APPROACH PILLARS ═══ -->
  <section style="padding-block: var(--spacing-section);">
    <div class="container-editorial">
      <p class="text-label-md text-on-surface-muted text-center mb-12 reveal">Our Approach</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
        <div class="text-center reveal stagger-1">
          <h3 class="text-heading-lg italic text-on-surface">Intimate</h3>
          <p class="text-body-md text-on-surface-variant mt-4">
            Small, intentional sessions that put connection first. No large production crews, no chaos. Just you, your people, and a photographer who pays attention.
          </p>
        </div>
        <div class="text-center reveal stagger-2">
          <h3 class="text-heading-lg italic text-on-surface">Candid</h3>
          <p class="text-body-md text-on-surface-variant mt-4">
            Real expressions, real laughter, real emotion. We capture what is actually happening, not a rehearsed version of it. Every image earns its place.
          </p>
        </div>
        <div class="text-center reveal stagger-3">
          <h3 class="text-heading-lg italic text-on-surface">Calm</h3>
          <p class="text-body-md text-on-surface-variant mt-4">
            A steady, grounded presence on your day. We move quietly, direct gently, and never rush. The best moments come when everyone feels at ease.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIAL ═══ -->
  <section class="bg-surface-dim" style="padding-block: var(--spacing-section);">
    <div class="container-editorial flex flex-col items-center text-center reveal">
      <p class="text-label-md text-on-surface-muted mb-8">{site.name}</p>
      <div class="max-w-3xl">
        <TestimonialCard
          name={testimonials[0].name}
          event={testimonials[0].event}
          quote={testimonials[0].quote}
          rating={testimonials[0].rating}
        />
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="bg-surface-dark" style="padding-block: var(--spacing-section);">
    <div class="container-editorial text-center reveal">
      <p class="text-label-sm text-on-dark-variant">Availability is limited</p>
      <h2 class="text-display-md text-on-dark mt-4">Start the Conversation</h2>
      <p class="text-body-lg text-on-dark-variant mt-6 max-w-2xl mx-auto">
        Whether you are planning a wedding, a civil ceremony, or an intimate celebration, we would love to hear your story. Reach out and let's talk about what you are envisioning.
      </p>
      <div class="mt-10">
        <Button href="/contact" variant="primary">Inquire Now</Button>
      </div>
    </div>
  </section>
</BaseLayout>
