---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import InvestmentSection from '../components/global/InvestmentSection.astro';
import GearBreaker from '../components/global/GearBreaker.astro';
import MobileGearBreaker from '../components/global/MobileGearBreaker.astro';
import testimonials from '../data/testimonials.json';

// Hero
import heroImage from '../assets/images/hero/hero-main.jpg';

// Signature Style pair
import signatureLeft from '../assets/images/homepage/homepage-07.jpg';
import signatureRight from '../assets/images/portfolio/alex-aziz/05.jpg';

// Investment
import investmentImage from '../assets/images/homepage/homepage-04.jpg';

// Recent Work
import recentWide from '../assets/images/portfolio/meghna-puneeth/06.jpg';
import recentPortraitLeft from '../assets/images/homepage/homepage-03.jpg';
import recentPortraitRight from '../assets/images/homepage/homepage-02.jpg';

const testimonial = testimonials[0];

const faqItems = [
  {
    question: 'When is the best time to shoot?',
    answer: 'Golden hour, always. Early morning or late afternoon light is unmatched. Overcast days work beautifully too. I will guide you on timing.',
  },
  {
    question: 'Will you help us with posing?',
    answer: 'I prompt, not pose. Natural movements, real reactions. The photos end up looking and feeling like you.',
  },
  {
    question: 'What if it rains?',
    answer: 'I still shoot. Covered spots, indoor spaces, or your home. Rain photos can be stunning. If you need to reschedule, 48 hours notice is all I ask.',
  },
  {
    question: 'How long until I get my photos?',
    answer: 'Sneak peek within days. Full gallery in 2 to 3 months. Priority 2-3 week delivery is available for an additional fee.',
  },
];

// Journal: latest two blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const journalPosts = allPosts
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 2);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'AD Photography',
    url: 'https://kashklicks.ca',
    description:
      'Toronto wedding photographer and filmmaker capturing candid, cinematic pre-wedding and wedding photography across the GTA and Canada.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: { '@type': 'Answer', text: item.answer },
    })),
  },
];
---

<BaseLayout
  title="Home"
  description="Toronto wedding photographer and filmmaker. AD Photography captures candid, cinematic pre-wedding and wedding photography across the GTA and Canada. Packages from $350."
  transparentHeader={true}
  showSplash={false}
  jsonLd={jsonLd}
>
  <script is:inline>
    // Splash temporarily disabled. Pre-seed the "seen" flag so the hero
    // entrance script in this file (and the SoundManager) treat the visit
    // as a return visit and render the hero immediately without waiting
    // for the splash:done event. To re-enable: flip showSplash back to
    // true in the BaseLayout props above and delete this seeding line.
    if (typeof sessionStorage !== 'undefined') {
      sessionStorage.setItem('kk-splash-seen', 'true');
    }
  </script>

  <style is:global>
    html.splash-pending .home-hero__copy .logo-mark,
    html.splash-pending .home-hero__copy h1,
    html.splash-pending .home-hero__copy h2,
    html.splash-pending .home-hero .hero-cta,
    html.splash-pending .home-hero .gallery-caption,
    html.splash-pending .home-hero .scroll-rail-wrap {
      opacity: 0;
    }

    /* Lock each tagline char's formatting context + GPU layer so the glyph shape
       (notably the Cormorant "f" with its long descender + crossbar) doesn't
       shift between opacity phases. Mobile rasterization is the most sensitive:
       subpixel antialiasing, GPU layer toggling, and OpenType contextual
       alternates can each cause the same char to re-render with different
       pixels mid-animation. All three are neutralised below. */
    .home-hero__copy h2[data-entrance-defer] .tagline-char {
      display: inline-block;
      transform: translate3d(0, 0, 0); /* permanent GPU layer — no re-rasterization */
      backface-visibility: hidden;
      will-change: opacity;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: geometricPrecision;
      font-feature-settings: "kern" 0, "liga" 0, "calt" 0;
      font-synthesis: none;
    }

    /* Desktop: two sentences flow inline. Mobile: each sentence on its own line. */
    .home-hero__copy h2[data-entrance-defer] .tagline-line {
      display: inline;
    }
    @media (max-width: 767px) {
      .home-hero__copy h2[data-entrance-defer] .tagline-line {
        display: block;
      }
    }

    /* Word wrapper keeps words atomic — lines only break between words. */
    .home-hero__copy h2[data-entrance-defer] .tagline-word {
      display: inline-block;
      white-space: nowrap;
    }

    /* Mobile: hero text sits higher so the photograph takes the lower half.
       Desktop stays true-centered. */
    @media (max-width: 767px) {
      .home-hero__copy {
        justify-content: flex-start;
        padding-top: 18vh;
      }
    }

    /* Per-character split produced by initSectionHeadings (desktop only).
       Word wrapper keeps a word atomic so line wrapping happens only at spaces;
       chars inside a word are inline-block (required for transform) and the
       word itself uses white-space: nowrap. */
    [data-gsap-chars] .gsap-word {
      display: inline-block;
      white-space: nowrap;
    }
    [data-gsap-chars] .gsap-char {
      display: inline-block;
      will-change: transform, opacity;
      /* Per-char splitting breaks the italic's natural letter flow, which
         triggers OpenType contextual alternates/ligatures/kerning pairs to
         fall back to wrong glyph forms (most visible: "d" renders as its
         isolated cursive variant and reads like "a"). Neutralise all
         position-aware features so each char renders in its default form. */
      font-feature-settings: "kern" 0, "liga" 0, "calt" 0, "clig" 0, "dlig" 0, "hlig" 0;
      font-variant-ligatures: none;
      font-kerning: none;
    }
  </style>

  <!-- ═══ 1. HERO ═══ -->
  <section class="home-hero relative h-[100svh] min-h-[600px] w-full overflow-hidden bg-surface-container">
    <Image
      src={heroImage}
      alt="Toronto wedding photographer AD Photography, Mehak and Manal session"
      class="home-hero__image absolute inset-0 w-full h-full object-cover"
      widths={[768, 1280, 1600]}
      sizes="100vw"
      quality={72}
      format="avif"
      loading="eager"
      fetchpriority="high"
    />
    <div class="home-hero__overlay absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>

    <!-- Informational H1 (keyword-rich) styled small; emotional H2 (tagline) styled large -->
    <div class="home-hero__copy absolute inset-0 flex flex-col items-center justify-center text-center px-6">
      <p class="logo-mark text-[0.8125rem] text-on-dark eyebrow-rule eyebrow-rule-center eyebrow-rule-on-dark mb-8">AD Photos</p>
      <h1 class="text-body-md text-on-dark/70 font-normal order-2 mt-6 max-w-[36ch] mx-auto">Your Toronto wedding photographer and filmmaker, telling real love stories.</h1>
      <h2 class="text-display-lg text-on-dark char-reveal order-1" data-fade-prefix-count="12" data-fade-prefix-opacity="0.4">Moments fade. Memories don't.</h2>
    </div>

    <script is:inline>
      // On first visit the hero tagline is driven by the GSAP entrance timeline,
      // not by char-reveal.ts. Strip the class before the module script picks it up.
      if (
        typeof sessionStorage !== 'undefined' &&
        sessionStorage.getItem('kk-splash-seen') !== 'true'
      ) {
        const heroTag = document.querySelector('.home-hero__copy h2.char-reveal');
        if (heroTag) {
          heroTag.classList.remove('char-reveal');
          heroTag.setAttribute('data-entrance-defer', 'true');
        }
      }
    </script>

    <!-- Caption -->
    <div class="hidden md:block absolute bottom-20 left-8 md:left-16 gallery-caption text-on-dark/90">
      <p class="font-medium">Mehak & Manal</p>
      <p class="text-on-dark/60">Kelowna, BC 2026</p>
    </div>

    <!-- Hero CTA anchored above the scroll rail -->
    <div class="absolute left-1/2 -translate-x-1/2 hero-cta z-10">
      <a
        href="/contact"
        class="magnetic inline-flex items-center justify-center whitespace-nowrap px-9 py-3.5 border border-on-dark/70 text-on-dark font-sans text-[0.8125rem] tracking-[0.12em] uppercase hover:bg-on-dark hover:text-on-surface cubic-ease"
        style="transition-duration: var(--duration-hover);"
      >
        Begin Your Story
      </a>
    </div>

    <!-- Scroll indicator: hairline rail with a travelling dot -->
    <div class="absolute left-1/2 -translate-x-1/2 scroll-rail-wrap" aria-hidden="true">
      <span class="scroll-rail"></span>
    </div>
  </section>

  <!-- ═══ 2. SIGNATURE STYLE — PHOTO PAIR ═══ -->
  <section class="py-[var(--spacing-section)]">
    <div class="container-editorial" style="margin-bottom: var(--spacing-block);">
      <div class="grid-editorial items-end">
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted eyebrow-rule mb-4">Signature Style</p>
          <h2 class="text-display-md text-on-surface measure-tight" data-gsap-chars>Quiet moments, real connection.</h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 mt-6 md:mt-0 reveal stagger-2">
          <p class="text-quote text-on-surface-variant measure-wide">
            No posing, no pretending. Just the in-between moments that end up meaning the most.
          </p>
        </div>
      </div>
    </div>
    <div class="grid-editorial">
      <div class="col-span-12 md:col-span-7 gallery-frame hover-zoom reveal-left">
        <Image
          src={signatureLeft}
          alt="Candid Toronto wedding photography, Ayushi and Parth"
          class="parallax-img"
          widths={[640, 960, 1280]}
          sizes="(max-width: 768px) 100vw, 58vw"
          quality={80}
        />
        <div class="gallery-caption text-on-surface">
          <p class="font-medium">Ayushi + Parth</p>
          <p class="text-on-surface-variant">Toronto</p>
        </div>
      </div>
      <div class="col-span-12 md:col-span-5 mt-3 md:mt-24 gallery-frame hover-zoom reveal-right stagger-2">
        <Image
          src={signatureRight}
          alt="Toronto pre-wedding portrait, Alex and Aziz"
          class="parallax-img"
          widths={[640, 960]}
          sizes="(max-width: 768px) 100vw, 42vw"
          quality={80}
        />
        <div class="gallery-caption text-on-surface">
          <p class="font-medium">Alex + Aziz</p>
          <p class="text-on-surface-variant">Toronto</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BREAKER · THE KIT ═══
       Two independent components per the mobile/desktop separation rule.
       GearBreaker renders ≥1024px (asymmetric chapter-page layout).
       MobileGearBreaker renders <1024px (vertical stack on hairline rail). -->
  <GearBreaker />
  <MobileGearBreaker />

  <!-- ═══ 3. INVESTMENT ═══ -->
  <InvestmentSection
    image={investmentImage}
    imageAlt="Full-day wedding photography coverage in Toronto by AD Photography"
  />

  <!-- ═══ 4. TESTIMONIAL ═══ -->
  <section class="py-[var(--spacing-section)] bg-white">
    <div class="container-editorial text-center max-w-3xl mx-auto">
      <p class="text-label-md text-on-surface-muted reveal eyebrow-rule eyebrow-rule-center mb-10">Kind Words</p>
      <blockquote class="text-quote text-on-surface mb-8 reveal stagger-1">
        "{testimonial.quote}"
      </blockquote>
      <p class="text-label-md text-on-surface-variant reveal stagger-2">
        {testimonial.name} &middot; {testimonial.event}
      </p>
    </div>
  </section>

  <!-- ═══ 5. RECENT WORK ═══
       Editorial chapter: numbered, gridded, dated. Reads like a curated
       monograph spread — a hairline column grid with corner ticks sits
       behind the work, each story is indexed with a large serif numeral,
       framed by location + season metadata, and the whole section is
       bracketed by running head + foot rules. -->
  <section class="recent-work py-[var(--spacing-section)] bg-surface-dim relative overflow-hidden">
    <div class="recent-work__grid" aria-hidden="true"></div>
    <div class="recent-work__ticks" aria-hidden="true">
      <span class="recent-work__tick recent-work__tick--tl"></span>
      <span class="recent-work__tick recent-work__tick--tr"></span>
      <span class="recent-work__tick recent-work__tick--bl"></span>
      <span class="recent-work__tick recent-work__tick--br"></span>
    </div>

    <div class="container-editorial relative">
      <!-- Running head: volume mark · chapter rule · edition mark -->
      <div class="recent-work__runhead reveal" aria-hidden="true">
        <span class="recent-work__runhead-mark">
          <span class="recent-work__runhead-roman">V</span>
          <span class="recent-work__runhead-label">Volume</span>
        </span>
        <span class="recent-work__runhead-rule"></span>
        <span class="recent-work__runhead-ornament">&#10022;</span>
        <span class="recent-work__runhead-rule"></span>
        <span class="recent-work__runhead-mark recent-work__runhead-mark--end">
          <span class="recent-work__runhead-label">Edition</span>
          <span class="recent-work__runhead-roman">MMXXVI</span>
        </span>
      </div>

      <div class="grid-editorial items-end recent-work__intro">
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted eyebrow-rule mb-4">Recent Work</p>
          <h2 class="text-display-md text-on-surface measure-medium" data-gsap-chars>Stories from the last few months.</h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 mt-6 md:mt-0 reveal stagger-2">
          <p class="text-quote text-on-surface-variant measure-wide">
            A few recent afternoons with couples who trusted me with their day.
          </p>
          <dl class="recent-work__specs">
            <div>
              <dt>Selection</dt>
              <dd>Three of twelve</dd>
            </div>
            <div>
              <dt>Period</dt>
              <dd>2025 &mdash; 2026</dd>
            </div>
            <div>
              <dt>Format</dt>
              <dd>Film &amp; Stills</dd>
            </div>
          </dl>
        </div>
      </div>

      <!-- Story 01 — Featured film -->
      <article class="recent-work__story recent-work__story--feature reveal">
        <header class="recent-work__meta">
          <span class="recent-work__plate">Plate I</span>
          <span class="recent-work__meta-rule"></span>
          <span class="recent-work__loc">Toronto &middot; Harbourfront</span>
          <span class="recent-work__dot" aria-hidden="true"></span>
          <span class="recent-work__date">Autumn 2025</span>
        </header>
        <div class="recent-work__frame recent-work__frame--feature">
          <span class="recent-work__numeral" aria-hidden="true">01</span>
          <a href="/portfolio/meghna-puneeth" class="gallery-frame hover-zoom scale-reveal mx-auto !w-full image-caption block group relative" data-caption="Meghna & Puneeth, Toronto" aria-label="View the Meghna and Puneeth album and film">
            <span class="absolute top-4 left-4 md:top-6 md:left-6 z-10 inline-flex items-center gap-2 text-[0.6875rem] tracking-[0.14em] uppercase font-sans text-on-dark bg-black/40 backdrop-blur-[2px] px-3 py-1.5">
              <svg width="9" height="9" viewBox="0 0 9 9" fill="currentColor" aria-hidden="true"><path d="M1.5 0.5l7 4-7 4z" /></svg>
              Film
            </span>
            <Image
              src={recentWide}
              alt="Candid pre-wedding photography at Toronto Harbourfront, Meghna and Puneeth"
              class="parallax-img !w-full !max-h-none aspect-[16/9] object-cover"
              widths={[960, 1440, 1920]}
              sizes="(max-width: 768px) 100vw, 90vw"
              quality={80}
            />
          </a>
        </div>
        <footer class="recent-work__footer">
          <div class="recent-work__caption">
            <p class="recent-work__couple">Meghna <em>&amp;</em> Puneeth</p>
            <p class="recent-work__sub">Pre-wedding film &middot; Cinematic story</p>
          </div>
          <dl class="recent-work__exif">
            <div><dt>Format</dt><dd>4K Film</dd></div>
            <div><dt>Runtime</dt><dd>3:42</dd></div>
          </dl>
          <a href="/portfolio/meghna-puneeth" class="recent-work__view" aria-label="View Meghna and Puneeth's story">
            View Story <span aria-hidden="true">&rarr;</span>
          </a>
        </footer>
      </article>
    </div>

    <div class="grid-editorial relative recent-work__pair">
      <!-- Story 02 -->
      <article class="recent-work__story col-span-12 md:col-span-5 reveal-left">
        <header class="recent-work__meta">
          <span class="recent-work__plate">Plate II</span>
          <span class="recent-work__meta-rule"></span>
          <span class="recent-work__loc">Toronto</span>
          <span class="recent-work__dot" aria-hidden="true"></span>
          <span class="recent-work__date">Summer 2025</span>
        </header>
        <div class="recent-work__frame">
          <span class="recent-work__numeral" aria-hidden="true">02</span>
          <a href="/portfolio" class="gallery-frame hover-zoom !w-full block group" aria-label="Browse the full portfolio">
            <Image
              src={recentPortraitLeft}
              alt="Pre-wedding portrait session, Swathi and Saksham in Toronto"
              class="parallax-img !w-full !max-h-none aspect-[3/4] object-cover"
              widths={[480, 640, 960]}
              sizes="(max-width: 768px) 100vw, 42vw"
              quality={80}
            />
          </a>
        </div>
        <footer class="recent-work__footer">
          <div class="recent-work__caption">
            <p class="recent-work__couple">Swathi <em>&amp;</em> Saksham</p>
            <p class="recent-work__sub">Pre-wedding portraits</p>
          </div>
          <a href="/portfolio" class="recent-work__view" aria-label="Browse the full portfolio">
            View Story <span aria-hidden="true">&rarr;</span>
          </a>
        </footer>
      </article>

      <!-- Story 03 -->
      <article class="recent-work__story col-span-12 md:col-span-5 md:col-start-7 mt-12 md:mt-24 reveal-right stagger-2">
        <header class="recent-work__meta">
          <span class="recent-work__plate">Plate III</span>
          <span class="recent-work__meta-rule"></span>
          <span class="recent-work__loc">Italy</span>
          <span class="recent-work__dot" aria-hidden="true"></span>
          <span class="recent-work__date">Spring 2026</span>
        </header>
        <div class="recent-work__frame">
          <span class="recent-work__numeral" aria-hidden="true">03</span>
          <a href="/portfolio/nora-ali" class="gallery-frame hover-zoom !w-full block group" aria-label="View the Nora and Ali album">
            <Image
              src={recentPortraitRight}
              alt="Destination wedding portrait in Italy, Nora and Ali"
              class="parallax-img !w-full !max-h-none aspect-[3/4] object-cover"
              widths={[480, 640, 960]}
              sizes="(max-width: 768px) 100vw, 42vw"
              quality={80}
            />
          </a>
        </div>
        <footer class="recent-work__footer">
          <div class="recent-work__caption">
            <p class="recent-work__couple">Nora <em>&amp;</em> Ali</p>
            <p class="recent-work__sub">Destination wedding</p>
          </div>
          <a href="/portfolio/nora-ali" class="recent-work__view" aria-label="View Nora and Ali's story">
            View Story <span aria-hidden="true">&rarr;</span>
          </a>
        </footer>
      </article>
    </div>

    <!-- Running foot: page-number style closer -->
    <div class="container-editorial relative mt-[var(--spacing-block)]">
      <div class="recent-work__runfoot reveal">
        <span class="recent-work__runfoot-folio">&#8212; iii &#8212;</span>
        <span class="recent-work__runfoot-rule"></span>
        <a href="/portfolio" class="recent-work__runfoot-link magnetic">
          Continue to the full portfolio <span aria-hidden="true">&rarr;</span>
        </a>
        <span class="recent-work__runfoot-rule recent-work__runfoot-rule--r"></span>
        <span class="recent-work__runfoot-folio">&#8212; xii &#8212;</span>
      </div>
    </div>
  </section>

  <style>
    /* ── Recent Work — editorial monograph treatment ────────────────
       Section reads like a curated book spread: running-head rule with
       volume + edition marks, a hairline column grid behind the work,
       corner crop-ticks at the page bounds, large serif numerals set
       alongside each plate, and a running-foot with folio numerals.
       The bg tonal shift to surface-dim gives the section its own
       paper stock so the hairline rules can read clearly. */
    .recent-work {
      isolation: isolate;
      background:
        radial-gradient(ellipse at top, color-mix(in srgb, var(--color-surface) 60%, transparent) 0%, transparent 55%),
        var(--color-surface-dim);
    }

    /* Subtle paper grain — adds depth without texture noise */
    .recent-work::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background:
        linear-gradient(180deg,
          color-mix(in srgb, var(--color-on-surface) 3%, transparent) 0%,
          transparent 12%,
          transparent 88%,
          color-mix(in srgb, var(--color-on-surface) 4%, transparent) 100%);
    }

    /* Column grid — 4 hairline verticals rendered as repeating
       background, only shown on tablet+ where column rhythm reads. */
    .recent-work__grid {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      opacity: 0;
      transition: opacity 1.4s var(--ease-gallery) 0.2s;
      max-width: 1440px;
      margin-inline: auto;
      padding-inline: clamp(1.5rem, 4vw, 6rem);
    }

    .recent-work__grid::before {
      content: '';
      position: absolute;
      inset: 0;
      margin-inline: clamp(1.5rem, 4vw, 6rem);
      background-image:
        linear-gradient(to right,
          color-mix(in srgb, var(--color-on-surface-muted) 24%, transparent) 0,
          color-mix(in srgb, var(--color-on-surface-muted) 24%, transparent) 1px,
          transparent 1px);
      background-size: 25% 100%;
      background-repeat: repeat-x;
      mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
    }

    .recent-work__grid::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      right: clamp(1.5rem, 4vw, 6rem);
      width: 1px;
      background: color-mix(in srgb, var(--color-on-surface-muted) 24%, transparent);
      mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 8%, black 92%, transparent 100%);
    }

    @media (min-width: 768px) {
      .recent-work__grid {
        opacity: 1;
      }
    }

    /* Corner crop-ticks — tiny right-angle marks at the four section
       corners, like a printer's trim reference. */
    .recent-work__ticks {
      position: absolute;
      inset: clamp(1.5rem, 3vw, 3.5rem) clamp(1.5rem, 4vw, 6rem);
      pointer-events: none;
      z-index: 1;
      max-width: calc(1440px - clamp(3rem, 8vw, 12rem));
      margin-inline: auto;
    }

    .recent-work__tick {
      position: absolute;
      width: 18px;
      height: 18px;
      opacity: 0.5;
    }

    .recent-work__tick::before,
    .recent-work__tick::after {
      content: '';
      position: absolute;
      background: var(--color-on-surface-variant);
    }

    .recent-work__tick::before {
      width: 1px;
      height: 100%;
    }

    .recent-work__tick::after {
      width: 100%;
