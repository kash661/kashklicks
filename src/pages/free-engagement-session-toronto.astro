  <!-- ═══════════════════════════════════════════════════════════════════
       Tracking · Clarity variant + scroll-depth pixel events
       Mirror of intimate-wedding LP gating pattern.
       ═══════════════════════════════════════════════════════════════════ -->
  <script is:inline>
    (function () {
      // Google Ads conversion ID (set when LP-specific conversion action lands)
      window.EOF_GADS_CONVERSION_ID = null;

      // Clarity segmentation
      if (typeof window.clarity === 'function') {
        window.clarity('set', 'variant', 'free-engagement-session-toronto');
        var params = new URLSearchParams(window.location.search);
        var utmSource = params.get('utm_source');
        if (utmSource) window.clarity('set', 'utm_source', utmSource);
        var utmCampaign = params.get('utm_campaign');
        if (utmCampaign) window.clarity('set', 'utm_campaign', utmCampaign);
      }

      // Pixel scroll-depth events (gated qualified-engagement signal)
      var firedViewContent = false;
      var firedQualifiedEngagement = false;

      function onScroll() {
        var h = document.documentElement;
        var total = h.scrollHeight - h.clientHeight;
        if (total <= 0) return;
        var pct = h.scrollTop / total;

        if (!firedViewContent && pct >= 0.25) {
          firedViewContent = true;
          if (typeof window.fbq === 'function') {
            window.fbq('track', 'ViewContent', {
              content_name: 'free-engagement-session-toronto',
              content_category: 'wedding-lp',
            });
          }
        }
        if (!firedQualifiedEngagement && pct >= 0.40) {
          firedQualifiedEngagement = true;
          if (typeof window.fbq === 'function') {
            window.fbq('trackCustom', 'QualifiedEngagement', { source: 'scroll' });
          }
          try { sessionStorage.setItem('ad_qualified_engagement', 'true'); } catch (_) {}
        }
        if (firedViewContent && firedQualifiedEngagement) {
          window.removeEventListener('scroll', onScroll);
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════
       Sticky mobile CTA controller (matches intimate-wedding LP)
       ═══════════════════════════════════════════════════════════════════ -->
  <script is:inline>
    (function () {
      function initStickyCta() {
        var cta = document.getElementById('lp-sticky-cta');
        var hero = document.getElementById('lp-hero');
        var inquire = document.getElementById('inquire');
        var colophon = document.getElementById('lp-colophon');
        if (!cta || !hero || !inquire) return;
        if (!('IntersectionObserver' in window)) return;

        var arrowEl = cta.querySelector('[data-lp-sticky-arrow]');
        var heroVisible = true;
        var inquireVisible = false;
        var colophonVisible = false;

        function update() {
          // Hide on hero, on form, and on the closing colophon (which has its own Reserve)
          var shouldShow = !heroVisible && !inquireVisible && !colophonVisible;
          if (shouldShow) {
            cta.classList.add('is-shown');
            cta.setAttribute('aria-hidden', 'false');
          } else {
            cta.classList.remove('is-shown');
            cta.setAttribute('aria-hidden', 'true');
          }
        }

        // Dynamic arrow · ↓ when form is below current scroll, ↑ when above
        var arrowState = '';
        var arrowTicking = false;
        function updateArrow() {
          arrowTicking = false;
          if (!arrowEl) return;
          var rect = inquire.getBoundingClientRect();
          var midpoint = window.innerHeight / 2;
          var next = rect.top > midpoint ? '↓' : '↑';
          if (next !== arrowState) {
            arrowState = next;
            arrowEl.textContent = next;
          }
        }
        function onScroll() {
          if (arrowTicking) return;
          arrowTicking = true;
          window.requestAnimationFrame(updateArrow);
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        updateArrow();

        // Hero observer · trigger when hero is fully out of view
        var heroIo = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { heroVisible = e.isIntersecting; });
          update();
        }, { threshold: 0, rootMargin: '0px 0px -80px 0px' });
        heroIo.observe(hero);

        // Inquire observer · hide once form scrolls into view
        var inquireIo = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) { inquireVisible = e.isIntersecting; });
          update();
        }, { threshold: 0.15 });
        inquireIo.observe(inquire);

        // Colophon observer · hide once the closing section is in view (own Reserve CTA there)
        if (colophon) {
          var colophonIo = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) { colophonVisible = e.isIntersecting; });
            update();
          }, { threshold: 0.15 });
          colophonIo.observe(colophon);
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initStickyCta);
      } else {
        initStickyCta();
      }
    })();
  </script>
