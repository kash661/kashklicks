---
import BaseLayout from '../layouts/BaseLayout.astro';
import EngagementOfferForm from '../components/forms/EngagementOfferForm.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import Button from '../components/ui/Button.astro';
import { Image } from 'astro:assets';

import packages from '../data/packages.json';
import faqData from '../data/faq.json';

import heroImage from '../assets/images/portfolio/vanika-mayank/26.jpg';

const noraAliCover = (await import('../assets/images/portfolio/nora-ali/38.jpg')).default;
const noraAliHover = (await import('../assets/images/portfolio/nora-ali/DSCF6387-Enhanced-SR.jpg')).default;
const alexAzizCover = (await import('../assets/images/portfolio/alex-aziz-cover.jpg')).default;
const alexAzizHover = (await import('../assets/images/portfolio/alex-aziz/DSCF5919.jpg')).default;
const natalieShavarCover = (await import('../assets/images/portfolio/natalie-shavar-cover.jpg')).default;
const natalieShavarHover = (await import('../assets/images/portfolio/natalie-shavar/22.jpg')).default;
const anushkaAnthonyCover = (await import('../assets/images/portfolio/anushka-anthony/21.jpg')).default;
const anushkaAnthonyHover = (await import('../assets/images/portfolio/anushka-anthony/DSCF7610.jpg')).default;
const shubaRobCover = (await import('../assets/images/portfolio/shuba-rob-cover.jpg')).default;
const shubaRobHover = (await import('../assets/images/portfolio/shuba-rob/03.jpg')).default;
const ayushiParthCover = (await import('../assets/images/portfolio/ayushi-parth-cover.jpg')).default;
const ayushiParthHover = (await import('../assets/images/portfolio/ayushi-parth/03.jpg')).default;

const torontoWork = [
  { couple: 'Nora & Ali', venue: 'Backyard, Toronto', image: noraAliCover, hover: noraAliHover, plate: 'i.' },
  { couple: 'Alex & Aziz', venue: 'TD Centre, Toronto', image: alexAzizCover, hover: alexAzizHover, plate: 'ii.' },
  { couple: 'Natalie & Shavar', venue: 'The Glenerin Inn', image: natalieShavarCover, hover: natalieShavarHover, plate: 'iii.' },
  { couple: 'Anushka & Anthony', venue: 'Toronto City Hall', image: anushkaAnthonyCover, hover: anushkaAnthonyHover, plate: 'iv.' },
  { couple: 'Shuba & Rob', venue: 'RC Harris, Toronto Beaches', image: shubaRobCover, hover: shubaRobHover, plate: 'v.' },
  { couple: 'Ayushi & Parth', venue: 'Toronto Harbour & Guild Park', image: ayushiParthCover, hover: ayushiParthHover, plate: 'vi.' },
];

const lpFaq = faqData.filter((q: any) =>
  Array.isArray(q.pages) && q.pages.includes('free-engagement-session-toronto')
);

const qualifyingTiers = packages
  .filter((p: any) => p.includesEngagementSession === true)
  .sort((a: any, b: any) => (a.order ?? 0) - (b.order ?? 0));

const minPrice = Math.min(...qualifyingTiers.map((p: any) => p.price));
const maxPrice = Math.max(...qualifyingTiers.map((p: any) => p.price));

const venueMarquee = [
  'Toronto City Hall',
  'TD Centre',
  'The Glenerin Inn',
  'Casa Loma',
  'Distillery District',
  'Backyards across the GTA',
  '2026',
  '2027',
];

const meta = {
  title: 'Free Engagement Session | Toronto Wedding Photographer | AD Photography',
  description: "For 2026 and 2027 Toronto couples. Book any wedding collection, the engagement session is on me. A tasting before your wedding day.",
  canonicalUrl: 'https://kashklicks.ca/free-engagement-session-toronto/',
  robots: 'noindex, follow',
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonicalUrl={meta.canonicalUrl}
  robots={meta.robots}
>
  <!-- flatpickr · Digital Curator themed calendar (matches intimate-wedding LP) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css" />
  <script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13"></script>
  <style is:global>
    .flatpickr-calendar {
      border-radius: 0 !important;
      border: 1px solid var(--color-surface-container, #e4e2e1) !important;
      box-shadow: 0 8px 32px rgba(26, 26, 24, 0.08) !important;
      font-family: var(--font-sans, 'Inter', system-ui, sans-serif) !important;
      background: #ffffff !important;
    }
    .flatpickr-day,
    .flatpickr-day.today,
    .flatpickr-day.selected,
    .flatpickr-day.startRange,
    .flatpickr-day.endRange { border-radius: 0 !important; }
    .flatpickr-day.selected,
    .flatpickr-day.selected:hover {
      background: #1a1a18 !important;
      border-color: #1a1a18 !important;
      color: #faf9f6 !important;
    }
    .flatpickr-day.today { border-color: #5f5e5e !important; }
    .flatpickr-day:hover { background: #f4f4f0 !important; }
    .flatpickr-months .flatpickr-month,
    .flatpickr-weekdays {
      background: #ffffff !important;
      color: #1a1a18 !important;
    }
    .flatpickr-current-month .flatpickr-monthDropdown-months,
    .flatpickr-current-month input.cur-year {
      color: #1a1a18 !important;
      font-weight: 500 !important;
    }
    .flatpickr-weekday {
      color: #5c605c !important;
      font-weight: 500 !important;
      text-transform: uppercase !important;
      letter-spacing: 0.08em !important;
      font-size: 0.6875rem !important;
    }
    .flatpickr-input[readonly] { cursor: pointer; }
  </style>

  <!-- ═══════════════════════════════════════════════════════════════════
       1 · COVER · editorial split hero
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="lp-hero" style="padding-top: var(--spacing-block); padding-bottom: var(--spacing-block);">
    <div class="container-editorial">
      <div class="grid-editorial items-center md:min-h-[82vh] fe-hero-grid">

        <!-- Cover copy -->
        <div class="col-span-12 md:col-span-5 reveal fe-hero-copy">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">
            Toronto · 2026 / 27 Weddings
          </p>

          <h1 class="text-display-lg char-reveal" style="max-width: 14ch;">
            Your engagement session, on me.
          </h1>

          <p class="text-body-lg text-on-surface-variant mt-8" style="max-width: 44ch;">
            Book any wedding collection. I'll photograph your engagement
            session as a tasting before your wedding day. If the photos
            aren't a fit, your retainer is refundable.
          </p>

          <p class="text-label-sm text-on-surface-muted mt-6 tracking-widest uppercase">
            Wedding collections from ${minPrice.toLocaleString('en-CA')} · Solo · Photo only
          </p>

          <div class="mt-10 flex flex-col items-start gap-5">
            <span class="magnetic inline-block">
              <a
                href="#inquire"
                class="fe-cta-primary group cubic-ease"
                style="transition-duration: var(--duration-hover);"
              >
                <span>Reserve</span>
                <span class="fe-cta-primary__arrow" aria-hidden="true">→</span>
              </a>
            </span>
            <a
              href="#how-the-gift-works"
              class="fe-cta-secondary group cubic-ease"
              style="transition-duration: var(--duration-hover);"
            >
              <span class="fe-cta-secondary__label">How the tasting works</span>
              <span class="fe-cta-secondary__arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <!-- Cover plate -->
        <div class="col-span-12 md:col-span-6 md:col-start-7 aspect-[3/4] overflow-hidden reveal-right stagger-2 hover-zoom md:mt-0 fe-hero-plate">
          <Image
            src={heroImage}
            alt="Bride in a sweeping red gown looks back at her partner as they walk down the stone steps of a Toronto landmark, photographed by AD Photography"
            widths={[640, 960, 1280, 1600]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={78}
            format="avif"
            class="w-full h-full object-cover parallax-img"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       BREAKER · venue marquee (editorial pattern break)
       ═══════════════════════════════════════════════════════════════════ -->
  <div class="breaker-marquee" role="presentation" aria-hidden="true">
    <div class="breaker-marquee__track">
      <div class="breaker-marquee__set">
        {venueMarquee.map((item, i) => (
          <>
            <span>{item}</span>
            {i < venueMarquee.length - 1 && <span class="breaker-marquee__dot">●</span>}
          </>
        ))}
        <span class="breaker-marquee__dot">●</span>
      </div>
      <div class="breaker-marquee__set" aria-hidden="true">
        {venueMarquee.map((item, i) => (
          <>
            <span>{item}</span>
            {i < venueMarquee.length - 1 && <span class="breaker-marquee__dot">●</span>}
          </>
        ))}
        <span class="breaker-marquee__dot">●</span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════
       2 · THE TASTING · offer explanation, sticky 2-column on desktop
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="how-the-gift-works"
    class="bg-background"
    style="padding: var(--spacing-section) 0;"
  >
    <div class="container-editorial">
      <div class="grid-editorial items-start">

        <!-- Left column: title + lead (sticky on desktop) -->
        <div class="col-span-12 md:col-span-5 fe-sticky">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule reveal">
            The Offer
          </p>
          <h2 class="section-title reveal stagger-1">
            Think of it like a <em>cake tasting</em>.
          </h2>
          <p class="text-body-lg text-on-surface-variant mt-8 reveal stagger-2" style="max-width: 44ch;">
            Most couples meet their wedding photographer for the first time
            on the wedding day. That's a lot of trust to hand over, and a
            lot to lose if the chemistry's off. So I built the engagement
            session in as a tasting. We shoot together first. You see the
            photos. Then you decide.
          </p>
        </div>

        <!-- Right column: 3 numbered steps -->
        <ol class="col-span-12 md:col-span-6 md:col-start-7 mt-12 md:mt-0 fe-steps">
          <li class="fe-step reveal">
            <div class="fe-step__head">
              <span class="fe-step__num">i.</span>
              <h3 class="fe-step__title">Book your collection</h3>
            </div>
            <p class="fe-step__body">
              Wedding collections from ${minPrice.toLocaleString('en-CA')} to
              ${maxPrice.toLocaleString('en-CA')}. Editorial photography.
              Engagement session included with every one.
            </p>
          </li>
          <li class="fe-step reveal stagger-1">
            <div class="fe-step__head">
              <span class="fe-step__num">ii.</span>
              <h3 class="fe-step__title">We shoot your tasting</h3>
            </div>
            <p class="fe-step__body">
              Two hours. One Toronto location. Fifty plus edited photos
              delivered within a week.
            </p>
          </li>
          <li class="fe-step reveal stagger-2">
            <div class="fe-step__head">
              <span class="fe-step__num">iii.</span>
              <h3 class="fe-step__title">You decide</h3>
            </div>
            <p class="fe-step__body">
              Love the work? We're locked in for your wedding day,
              and the photos are yours. Not a fit? You owe nothing.
              Your retainer comes back in full, the session was on me,
              and we part ways.
            </p>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       BREAKER · the trial promise dramatized
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="breaker-stats">
    <div class="breaker-stats__inner">
      <span class="breaker-stats__rule"></span>
      <p class="breaker-stats__number">$0</p>
      <p class="breaker-stats__unit">Your risk</p>
      <p class="breaker-stats__caption">
        If the photos aren't a fit, the session is on me. Your wedding
        retainer comes back in full. You walk away owing nothing.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       3 · RESERVATIONS · the form
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="inquire"
    class="bg-background fe-inquire"
    style="padding: var(--spacing-section) 0;"
  >
    <div style="max-width: 520px; margin-inline: auto; padding-inline: 1.5rem;">
      <p class="text-label-md text-on-surface-muted mb-10 eyebrow-rule reveal">
        Reservations
      </p>
      <div class="reveal stagger-1">
        <EngagementOfferForm />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       4 · RECENT COUPLES · gallery with editorial plaques
       ═══════════════════════════════════════════════════════════════════ -->
  <section
    id="work"
    class="bg-surface-dim section-frame"
    style="padding: var(--spacing-section) 0;"
  >
    <div class="container-editorial">

      <div class="grid-editorial items-end" style="margin-bottom: var(--spacing-block);">
        <div class="col-span-12 md:col-span-5">
          <p class="text-label-md text-on-surface-muted reveal eyebrow-rule">Recent Couples</p>
          <h2 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element); max-width: 12ch;">
            Toronto, <em>here</em>.
          </h2>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 mt-6 md:mt-0">
          <p class="text-body-lg text-on-surface-variant reveal stagger-2" style="max-width: 50ch;">
            A small selection of couples I've photographed across the city.
            Church. City Hall. Backyard. Each one a quiet day, photographed.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        {torontoWork.map((item, i) => (
          <>
            {/* Primary figure · hover-swap on desktop, plain image on mobile */}
            <figure class={`reveal stagger-${(i % 4) + 1} fe-album-figure fe-album-figure--cover`}>
              <div class="fe-album-frame">
                <Image
                  src={item.image}
                  alt={`${item.couple} wedding photography, ${item.venue}, by AD Photography`}
                  widths={[320, 480, 640, 960]}
                  sizes="(max-width: 768px) 50vw, 33vw"
                  quality={75}
                  format="avif"
                  class="fe-album-frame__img fe-album-frame__img--cover"
                  loading="lazy"
                />
                <Image
                  src={item.hover}
                  alt=""
                  widths={[320, 480, 640, 960]}
                  sizes="(max-width: 768px) 50vw, 33vw"
                  quality={75}
                  format="avif"
                  class="fe-album-frame__img fe-album-frame__img--hover"
                  loading="lazy"
                  aria-hidden="true"
                />
              </div>
              <figcaption class="gallery-plaque">
                <div class="gallery-plaque__row">
                  <p class="gallery-plaque__title">
                    <em>{item.plate}</em>&nbsp;{item.couple}
                  </p>
                </div>
                <div class="gallery-plaque__line">
                  <span class="gallery-plaque__rule"></span>
                  <span>{item.venue}</span>
                </div>
              </figcaption>
            </figure>

            {/* Mobile-only second figure · the hover image as its own item */}
            <figure class={`reveal stagger-${((i + 1) % 4) + 1} fe-album-figure fe-album-figure--mobile-extra`} aria-hidden="true">
              <div class="fe-album-frame">
                <Image
                  src={item.hover}
                  alt=""
                  widths={[320, 480, 640]}
                  sizes="50vw"
                  quality={75}
                  format="avif"
                  class="fe-album-frame__img fe-album-frame__img--cover"
                  loading="lazy"
                />
              </div>
            </figure>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       BREAKER · brand pull-quote
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="breaker-quote">
    <div class="breaker-quote__inner">
      <span class="breaker-rule"></span>
      <p class="breaker-quote__text">
        The wedding day deserves a photographer who already knows you.
      </p>
      <p class="breaker-quote__attribution">AD</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       5 · NOTES · FAQ
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial max-w-3xl">
      <div class="text-center mb-12 reveal">
        <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule eyebrow-rule-center">Notes</p>
        <h2 class="text-display-md">Questions before the tasting.</h2>
      </div>
      <div class="reveal stagger-1">
        <FAQAccordion items={lpFaq} defaultOpen />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       6 · GOOD TO KNOW · two-column hairline grid
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial max-w-5xl">
      <div class="text-center mb-16 reveal">
        <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule eyebrow-rule-center">Before You Book</p>
        <h2 class="text-display-md">Good to know.</h2>
      </div>

      <div class="good-to-know-grid">
        <div class="good-to-know-item reveal">
          <p class="text-heading-md font-serif italic mb-3">Coverage</p>
          <p class="text-body-md text-on-surface-variant" style="max-width: 42ch;">
            One wedding per weekend. Solo editorial photographer.
            Church, civil, backyard, intimate venues. Photo only on the wedding day.
          </p>
        </div>
        <div class="good-to-know-item reveal stagger-1">
          <p class="text-heading-md font-serif italic mb-3">Delivery</p>
          <p class="text-body-md text-on-surface-variant" style="max-width: 42ch;">
            Wedding gallery in one to two months. Engagement session
            within a week. Priority two-to-three week wedding delivery
            available.
          </p>
        </div>
        <div class="good-to-know-item reveal stagger-2">
          <p class="text-heading-md font-serif italic mb-3">Logistics</p>
          <p class="text-body-md text-on-surface-variant" style="max-width: 42ch;">
            Based in Mississauga, shoot across the GTA. Travel for the
            engagement session inside the GTA is included. Outside the GTA,
            let's talk.
          </p>
        </div>
        <div class="good-to-know-item reveal stagger-3">
          <p class="text-heading-md font-serif italic mb-3">The collections</p>
          <p class="text-body-md text-on-surface-variant" style="max-width: 42ch;">
            Wedding collections from ${minPrice.toLocaleString('en-CA')}
            to ${maxPrice.toLocaleString('en-CA')}. Engagement session
            ($350 value) included with every one.
            <a href="/services/wedding/" class="underline underline-offset-4 decoration-1 hover:text-on-surface cubic-ease block mt-3 text-label-sm tracking-widest uppercase">
              See the collections
              <span aria-hidden="true">→</span>
            </a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       7 · COLOPHON · editorial end-plate, fade to black
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="lp-colophon" class="fe-colophon" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial max-w-3xl text-center">

      <!-- Issue mark -->
      <p class="fe-colophon__issue reveal">Issue No. 01 &nbsp;·&nbsp; Toronto &nbsp;·&nbsp; 2026</p>

      <!-- Tagline (char-reveal) -->
      <h2 class="fe-colophon__tagline char-reveal">
        Moments fade. Memories don't.
      </h2>

      <!-- Animated hairline -->
      <div class="fe-colophon__hr reveal stagger-2" aria-hidden="true">
        <span class="fe-colophon__hr-fill"></span>
      </div>

      <!-- A note -->
      <p class="fe-colophon__eyebrow reveal stagger-2">A note</p>
      <p class="fe-colophon__letter reveal stagger-3">
        Most wedding photographers ask for a deposit before they've held
        a camera in front of you. I don't. Send me a note.
        The tasting is how we begin.
      </p>
      <p class="fe-colophon__signature reveal stagger-4">AD</p>

      <!-- Reserve CTA (ghost on dark) -->
      <div class="reveal stagger-5 fe-colophon__cta-wrap">
        <a
          href="#inquire"
          class="fe-cta-primary magnetic group cubic-ease"
          style="transition-duration: var(--duration-hover);"
        >
          <span>Reserve</span>
          <span class="fe-cta-primary__arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Footer rule -->
      <div class="fe-colophon__footrule reveal" aria-hidden="true">
        <span class="fe-colophon__hr-fill"></span>
      </div>

      <!-- Contact -->
      <div class="fe-colophon__contact reveal">
        <a
          href="https://instagram.com/kashklicks"
          target="_blank"
          rel="noopener"
          class="fe-colophon__link"
          style="transition-duration: var(--duration-hover);"
        >
          @kashklicks
        </a>
        <span class="fe-colophon__dot" aria-hidden="true">·</span>
        <a
          href="mailto:info@kashklicks.ca"
          class="fe-colophon__link"
          style="transition-duration: var(--duration-hover);"
        >
          info@kashklicks.ca
        </a>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════
       Sticky mobile CTA · appears after hero, hides at form
       ═══════════════════════════════════════════════════════════════════ -->
  <div
    id="lp-sticky-cta"
    class="fe-sticky-cta md:hidden"
    aria-hidden="true"
  >
    <div class="fe-sticky-cta__inner">
      <a href="#inquire" class="fe-sticky-cta__btn">
        <span>Reserve your tasting</span>
        <span class="fe-sticky-cta__arrow" data-lp-sticky-arrow aria-hidden="true">↓</span>
      </a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════
       Page-specific styles · sticky tasting column + numbered steps
       ═══════════════════════════════════════════════════════════════════ -->
  <style>
    /* ─── Hero CTA · editorial primary + quiet secondary ─────────────── */
    .fe-cta-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.875rem;
      background: var(--color-on-surface);
      color: var(--color-on-dark);
      padding: 1.25rem 2.75rem;
      font-family: var(--font-sans);
      font-size: 0.8125rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      white-space: nowrap;
      transition: background-color var(--duration-hover) var(--ease-gallery);
    }
    .fe-cta-primary:hover,
    .fe-cta-primary:focus-visible {
      background: var(--color-surface-dark);
      color: var(--color-on-dark);
    }
    .fe-cta-primary__arrow {
      display: inline-block;
      transition: transform var(--duration-hover) var(--ease-gallery);
    }
    .fe-cta-primary:hover .fe-cta-primary__arrow,
    .fe-cta-primary:focus-visible .fe-cta-primary__arrow {
      transform: translateX(6px);
    }

    .fe-cta-secondary {
      display: inline-flex;
      align-items: center;
