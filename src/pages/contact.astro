---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import BookingLink from '../components/ui/BookingLink.astro';
import { Image } from 'astro:assets';

import faq from '../data/faq.json';
import site from '../data/site.json';
import heroImage from '../assets/images/homepage/homepage-02.jpg';

// Dedupe FAQ by question — contact page shows the general set; service-specific
// variants live on the individual service pages.
const seen = new Set<string>();
const contactFaq = faq.filter((item) => {
  if (seen.has(item.question)) return false;
  seen.add(item.question);
  return true;
});

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: contactFaq.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
};

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact AD Photography',
  description: 'Book your Toronto wedding or pre-wedding photography session',
  url: `${site.url}/contact`,
  mainEntity: {
    '@type': 'LocalBusiness',
    name: site.name,
    email: site.email,
    address: {
      '@type': 'PostalAddress',
      addressLocality: site.location.city,
      addressRegion: site.location.regionCode,
      addressCountry: site.location.countryCode,
    },
    areaServed: site.areasServed,
  },
};
---

<BaseLayout
  title="Book a Toronto Wedding Photographer"
  description="Book a Toronto wedding photographer. Pre-wedding, wedding, and civil ceremony coverage across the GTA. Free consultation, 24-hour reply."
  jsonLd={[faqSchema, contactPageSchema]}
>
  <div class="sr-only">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Contact', href: '/contact/' },
    ]} />
  </div>

  <!-- ═══ HERO ═══ -->
  <section style="padding-top: var(--spacing-block);">
    <div class="container-editorial">
      <div class="grid-editorial items-center" style="min-height: 70vh;">
        <div class="col-span-12 md:col-span-5">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule reveal">Inquiry</p>
          <h1 class="text-display-md char-reveal reveal stagger-1">
            Book a Toronto <em>wedding photographer.</em>
          </h1>
          <p class="font-serif italic text-heading-md text-on-surface-variant mt-4 reveal stagger-2" style="max-width: 20ch;">
            Let's capture the fleeting moments.
          </p>
          <p class="text-body-lg text-on-surface-variant mt-6 reveal stagger-3" style="max-width: 45ch;">
            Currently booking for 2026 and beyond. Pre-wedding, wedding, and civil ceremony coverage across the GTA and Canada-wide. Reply within 24 hours.
          </p>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 aspect-[3/4] overflow-hidden reveal-right stagger-2 image-caption" data-caption="A Quiet Conversation">
          <Image
            src={heroImage}
            alt="Toronto wedding couple portrait by AD Photography"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={75}
            format="avif"
            class="w-full h-full object-cover parallax-img"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>

      <!-- Scroll cue -->
      <div class="flex flex-col items-center mt-20 reveal stagger-4">
        <p class="text-label-sm text-on-surface-muted mb-3">Tell Me About Your Day</p>
        <div class="scroll-chevron">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-on-surface-muted" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ INVITATION ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-center">
        <!-- Left: Brand statement + studio colophon -->
        <div class="col-span-12 lg:col-span-5">
          <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule reveal">Tell Me About Your Day</p>
          <h2 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element); max-width: 14ch;">
            The conversation <em>starts here.</em>
          </h2>
          <p class="text-body-lg text-on-surface-variant mt-6 reveal stagger-2" style="max-width: 42ch;">
            Share a little about your day, your vision, and the moments you want to remember. I'll take it from there.
          </p>

          <!-- Studio Colophon -->
          <div class="mt-16">
            <div class="flex items-center gap-4 mb-8 reveal">
              <span class="text-label-sm text-on-surface-muted uppercase tracking-widest whitespace-nowrap">Studio Notes</span>
              <span class="h-px flex-1 bg-on-surface-muted/25"></span>
              <span class="font-serif italic text-label-sm text-on-surface-muted">№ 01</span>
            </div>

            <dl class="border-y border-on-surface-muted/25">
              <div class="flex items-baseline gap-6 py-5 border-b border-on-surface-muted/15 reveal stagger-1">
                <dt class="text-label-sm text-on-surface-muted uppercase tracking-widest w-24 shrink-0">Based</dt>
                <dd class="text-body-lg text-on-surface">Toronto, Ontario</dd>
              </div>
              <div class="flex items-baseline gap-6 py-5 border-b border-on-surface-muted/15 reveal stagger-2">
                <dt class="text-label-sm text-on-surface-muted uppercase tracking-widest w-24 shrink-0">Serving</dt>
                <dd class="text-body-lg text-on-surface">Greater Toronto Area<br /><span class="text-on-surface-variant">and Canada-wide</span></dd>
              </div>
              <div class="flex items-baseline gap-6 py-5 border-b border-on-surface-muted/15 reveal stagger-3">
                <dt class="text-label-sm text-on-surface-muted uppercase tracking-widest w-24 shrink-0">Email</dt>
                <dd class="text-body-lg text-on-surface">
                  <a
                    href={`mailto:${site.email}`}
                    class="inline-flex items-center gap-2 hover:text-on-surface-variant cubic-ease group"
                    style="transition-duration: var(--duration-hover);"
                  >
                    {site.email}
                    <svg class="w-3.5 h-3.5 cubic-ease group-hover:translate-x-0.5 group-hover:-translate-y-0.5 text-on-surface-muted" style="transition-duration: var(--duration-hover);" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
                    </svg>
                  </a>
                </dd>
              </div>
              <div class="flex items-baseline gap-6 py-5 reveal stagger-4">
                <dt class="text-label-sm text-on-surface-muted uppercase tracking-widest w-24 shrink-0">Instagram</dt>
                <dd class="text-body-lg text-on-surface">
                  <a
                    href={site.social.instagram}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 hover:text-on-surface-variant cubic-ease group"
                    style="transition-duration: var(--duration-hover);"
                  >
                    {site.social.instagramHandle}
                    <svg class="w-3.5 h-3.5 cubic-ease group-hover:translate-x-0.5 group-hover:-translate-y-0.5 text-on-surface-muted" style="transition-duration: var(--duration-hover);" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
                    </svg>
                  </a>
                  <span class="text-label-sm font-serif italic text-on-surface-muted ml-3 signature-pulse">fastest reply</span>
                </dd>
              </div>
            </dl>

            <p class="font-serif italic text-body-lg text-on-surface-variant mt-10 reveal stagger-5" style="max-width: 32ch;">
              A solo practice. Quiet, intentional work.
            </p>
            <p class="text-label-sm text-on-surface-muted uppercase tracking-widest mt-4 reveal stagger-5">— AD</p>
          </div>
        </div>

        <!-- Right: Invitation card with modal trigger -->
        <div class="col-span-12 lg:col-span-6 lg:col-start-7 mt-16 lg:mt-0">
          <div class="bg-surface-dark text-on-dark p-10 lg:p-14 relative overflow-hidden reveal-right invitation-card">
            <!-- Ambient corner hairlines that draw in -->
            <span class="invitation-corner invitation-corner-tl" aria-hidden="true"></span>
            <span class="invitation-corner invitation-corner-br" aria-hidden="true"></span>

            <p class="text-label-md text-on-dark-variant eyebrow-rule eyebrow-rule-on-dark reveal stagger-1">Ready When You Are</p>
            <h3 class="text-heading-lg text-on-dark mt-8 reveal stagger-2" style="max-width: 14ch;">
              Begin the <em class="font-serif italic">inquiry.</em>
            </h3>
            <p class="text-body-lg text-on-dark-variant mt-6 reveal stagger-3" style="max-width: 38ch;">
              A quiet, one-page form. A few details about your day and your vision. I reply within 24 hours, every time.
            </p>

            <div class="mt-12 reveal stagger-4">
              <button
                type="button"
                data-open-modal="contact-modal"
                class="magnetic cta-pulse inline-flex items-center gap-4 whitespace-nowrap px-10 py-5 bg-background text-on-surface font-sans text-label-md hover:bg-surface-dim cubic-ease group relative"
                style="transition-duration: var(--duration-hover);"
              >
                <span>Open the Form</span>
                <svg class="w-4 h-4 cubic-ease group-hover:translate-x-1 arrow-nudge" style="transition-duration: var(--duration-hover);" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </button>
              <p class="text-label-sm text-on-dark-variant opacity-60 mt-6">
                Takes about two minutes.
              </p>
              <div class="mt-8 pt-8 border-t border-on-dark-variant/15">
                <p class="text-label-sm text-on-dark-variant opacity-60 mb-3">
                  Or speak with AD directly
                </p>
                <BookingLink variant="text" class="text-on-dark-variant hover:text-on-dark">
                  Book a 30-min consultation
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17" />
                  </svg>
                </BookingLink>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="text-center mb-16">
        <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule eyebrow-rule-center reveal">Before You Book</p>
        <h2 class="text-display-md reveal stagger-1">Toronto Wedding Photography · Frequently Asked</h2>
      </div>
      <div class="max-w-3xl mx-auto faq-stagger reveal">
        <FAQAccordion items={contactFaq} />
      </div>
      <p class="text-label-sm text-on-surface-muted text-center mt-12 reveal">
        Looking for package-specific answers? Visit my <a href="/services" class="underline hover:text-on-surface cubic-ease" style="transition-duration: var(--duration-hover);">services</a> pages.
      </p>
    </div>
  </section>

  <!-- ═══ CLOSING: SOCIAL PROOF ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-center">
        <div class="col-span-12 md:col-span-7">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule reveal">What Couples Say</p>
          <p class="text-quote text-on-surface italic reveal stagger-1" style="max-width: 28ch;">
            "They made us feel like the only two people in the room."
          </p>
          <p class="text-label-md text-on-surface mt-8 reveal stagger-2">Natalie & Shavar</p>
          <p class="text-label-sm text-on-surface-variant opacity-60 reveal stagger-3">The Glenerin Inn, Mississauga</p>
        </div>
        <div class="col-span-12 md:col-span-4 md:col-start-9 mt-12 md:mt-0">
          <p class="text-label-sm text-on-surface-muted uppercase tracking-widest mb-4 reveal">While You Wait</p>
          <p class="text-body-md text-on-surface-variant reveal stagger-1" style="max-width: 30ch;">
            Browse recent stories from weddings and pre-wedding shoots across the GTA.
          </p>
          <div class="mt-8 reveal stagger-2">
            <a
              href="/portfolio"
              class="magnetic inline-flex items-center gap-3 whitespace-nowrap px-8 py-4 bg-surface-dark text-on-dark text-label-md hover:bg-primary-hover cubic-ease group"
              style="transition-duration: var(--duration-hover);"
            >
              <span>View Portfolio</span>
              <svg class="w-4 h-4 cubic-ease group-hover:translate-x-1" style="transition-duration: var(--duration-hover);" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT MODAL ═══ -->
  <dialog
    id="contact-modal"
    class="contact-modal"
    aria-labelledby="contact-modal-title"
  >
    <div class="contact-modal-inner">
      <div class="contact-modal-header">
        <div>
          <p class="text-label-md text-on-surface-muted eyebrow-rule revealed">Inquiry</p>
          <h2 id="contact-modal-title" class="text-heading-lg mt-4" style="max-width: 18ch;">
            Tell me about your <em class="font-serif italic">day.</em>
          </h2>
        </div>
        <button
          type="button"
          data-close-modal
          class="contact-modal-close"
          aria-label="Close inquiry form"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="contact-modal-body">
        <ContactForm />
      </div>
    </div>
  </dialog>
</BaseLayout>

<style>
  /* ── Invitation card: hairlines that draw in with the card ── */
  .invitation-card {
    position: relative;
  }
  .invitation-corner {
    position: absolute;
    background: rgba(250, 249, 246, 0.25);
    transition: transform var(--duration-page) var(--ease-gallery);
  }
  .invitation-corner-tl {
    top: 0;
    left: 0;
    width: 48px;
    height: 1px;
    transform: scaleX(0);
    transform-origin: left;
  }
  .invitation-corner-br {
    bottom: 0;
    right: 0;
    width: 48px;
    height: 1px;
    transform: scaleX(0);
    transform-origin: right;
  }
  .invitation-card.revealed .invitation-corner-tl,
  .invitation-card.revealed .invitation-corner-br {
    transform: scaleX(1);
    transition-delay: 600ms;
  }

  /* ── CTA button: soft ambient pulse on the edge ── */
  .cta-pulse::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(250, 249, 246, 0.35);
    pointer-events: none;
    animation: cta-breath 3.2s var(--ease-gallery) infinite;
  }
  @keyframes cta-breath {
    0%, 100% { transform: scale(1); opacity: 0; }
    50% { transform: scale(1.06); opacity: 1; }
  }

  /* ── "fastest reply" signature: slow opacity breath ── */
  .signature-pulse {
    animation: signature-breath 4s var(--ease-gallery) infinite;
  }
  @keyframes signature-breath {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }

  /* ── FAQ accordion items: stagger each question as the section reveals ── */
  .faq-stagger > div > details {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity var(--duration-page) var(--ease-gallery),
                transform var(--duration-page) var(--ease-gallery);
  }
  .faq-stagger.revealed > div > details { opacity: 1; transform: translateY(0); }
  .faq-stagger.revealed > div > details:nth-child(1) { transition-delay: 0ms; }
  .faq-stagger.revealed > div > details:nth-child(2) { transition-delay: 80ms; }
  .faq-stagger.revealed > div > details:nth-child(3) { transition-delay: 160ms; }
  .faq-stagger.revealed > div > details:nth-child(4) { transition-delay: 240ms; }
  .faq-stagger.revealed > div > details:nth-child(5) { transition-delay: 320ms; }
  .faq-stagger.revealed > div > details:nth-child(6) { transition-delay: 400ms; }
  .faq-stagger.revealed > div > details:nth-child(7) { transition-delay: 480ms; }
  .faq-stagger.revealed > div > details:nth-child(8) { transition-delay: 560ms; }

  @media (prefers-reduced-motion: reduce) {
    .invitation-corner,
    .cta-pulse::after,
    .signature-pulse,
    .faq-stagger > div > details {
      animation: none;
      transition: none;
      opacity: 1;
      transform: none;
    }
    .invitation-corner-tl,
    .invitation-corner-br {
      transform: scaleX(1);
    }
  }

  .contact-modal {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100dvh;
    margin: 0;
    overflow: hidden;
    color: inherit;
  }

  .contact-modal::backdrop {
    background: rgba(26, 26, 24, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .contact-modal[open] {
    animation: contact-modal-fade var(--duration-page) var(--ease-gallery);
  }

  .contact-modal[open]::backdrop {
    animation: contact-modal-backdrop var(--duration-slow) var(--ease-gallery);
  }

  @keyframes contact-modal-fade {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes contact-modal-backdrop {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .contact-modal-inner {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: 820px;
    margin: 0 auto;
    background: var(--color-background);
    display: flex;
    flex-direction: column;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.3);
  }

  @media (min-width: 768px) {
    .contact-modal {
      padding: 3rem 1.5rem;
    }
    .contact-modal-inner {
      height: auto;
      max-height: calc(100dvh - 6rem);
    }
  }

  .contact-modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid rgba(175, 179, 174, 0.15);
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .contact-modal-header {
      padding: 2.5rem 3rem 2rem;
    }
  }

  .contact-modal-close {
    flex-shrink: 0;
    padding: 0.5rem;
    color: var(--color-on-surface-variant);
    transition: color var(--duration-hover) var(--ease-gallery);
    cursor: pointer;
    background: transparent;
    border: none;
  }

  .contact-modal-close:hover,
  .contact-modal-close:focus-visible {
    color: var(--color-on-surface);
    outline: none;
  }

  .contact-modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 2rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-surface-container) var(--color-background);
  }

  @media (min-width: 768px) {
    .contact-modal-body {
      padding: 2.5rem 3rem 3rem;
    }
  }

  /* Lock body scroll when modal is open */
  body.modal-open {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-modal[open],
    .contact-modal[open]::backdrop {
      animation: none;
    }
  }
</style>

<script>
  function initContactModal() {
    const modal = document.getElementById('contact-modal') as HTMLDialogElement | null;
    if (!modal) return;

    const openers = document.querySelectorAll<HTMLButtonElement>('[data-open-modal="contact-modal"]');
    const closers = modal.querySelectorAll<HTMLButtonElement>('[data-close-modal]');
    let lastFocused: HTMLElement | null = null;

    function openModal(trigger?: HTMLElement) {
      lastFocused = trigger ?? (document.activeElement as HTMLElement | null);
      if (typeof modal!.showModal === 'function') {
        modal!.showModal();
      } else {
        modal!.setAttribute('open', '');
      }
      document.body.classList.add('modal-open');
      // Focus the first field after the dialog renders
      requestAnimationFrame(() => {
        const firstField = modal!.querySelector<HTMLElement>('input, textarea, select, button:not([data-close-modal])');
        firstField?.focus();
      });
    }

    function closeModal() {
      if (typeof modal!.close === 'function') {
        modal!.close();
      } else {
        modal!.removeAttribute('open');
      }
      document.body.classList.remove('modal-open');
      lastFocused?.focus();
    }

    openers.forEach((btn) => {
      btn.addEventListener('click', () => openModal(btn));
    });

    closers.forEach((btn) => {
      btn.addEventListener('click', closeModal);
    });

    // Click on backdrop closes modal
    modal.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === modal) closeModal();
    });

    // ESC key is handled natively by <dialog>, but clean up body class
    modal.addEventListener('close', () => {
      document.body.classList.remove('modal-open');
    });
  }

  initContactModal();
  document.addEventListener('astro:after-swap', initContactModal);
</script>
