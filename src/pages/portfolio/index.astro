---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PortfolioCard from '../../components/ui/PortfolioCard.astro';
import Button from '../../components/ui/Button.astro';
import FinalCTA from '../../components/global/FinalCTA.astro';
import { Image } from 'astro:assets';

import portfolio from '../../data/portfolio.json';
import site from '../../data/site.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const heroImage = (await import('../../assets/images/homepage/portfolio-hero-raman.jpg')).default;
const ctaImage = (await import('../../assets/images/homepage/homepage-01.jpg')).default;
const weddingFeature = (await import('../../assets/images/homepage/wedding-hero-natalie.jpg')).default;
const preWeddingFeature = (await import('../../assets/images/homepage/prewedding-service-detail.jpg')).default;
const civilFeature = (await import('../../assets/images/homepage/civil-ceremony-hero.jpg')).default;
const filmsFeature = (await import('../../assets/images/homepage/homepage-04.jpg')).default;

const chapters = [
  {
    eyebrow: 'Chapter I',
    title: 'Weddings',
    description: 'Full-day coverage of your wedding, unobtrusive and cinematic. From getting ready to the last dance.',
    href: '/portfolio/weddings',
    image: weddingFeature,
    caption: 'Wedding Day Stories',
    alt: 'Toronto wedding photography portfolio preview by AD Photography',
  },
  {
    eyebrow: 'Chapter II',
    title: 'Pre-Weddings',
    description: 'Engagement and pre-wedding sessions at Toronto\'s most stunning locations. Your love story, before the big day.',
    href: '/portfolio/pre-weddings',
    image: preWeddingFeature,
    caption: 'Before The Big Day',
    alt: 'Toronto pre-wedding photography portfolio preview',
  },
  {
    eyebrow: 'Chapter III',
    title: 'Civil Ceremony',
    description: 'Intimate courthouse and city hall stories. Small ceremonies, same attention to every detail.',
    href: '/portfolio/civil-ceremony',
    image: civilFeature,
    caption: 'Intimate. Uncomplicated.',
    alt: 'Toronto civil ceremony photography portfolio preview',
  },
  {
    eyebrow: 'Chapter IV',
    title: 'Films',
    description: 'Motion, sound, and feeling brought together. Cinematic wedding and pre-wedding films.',
    href: '/portfolio/films',
    image: filmsFeature,
    caption: 'Love, In Motion',
    alt: 'Toronto wedding films portfolio reel preview',
  },
];

const allEntries = portfolio;

const businessRef = { '@id': `${site.url}/#business` };

const gallerySchema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'AD Photography Portfolio',
  description: 'Toronto wedding, pre-wedding, civil ceremony, and film portfolio by AD Photography.',
  url: new URL('/portfolio', Astro.site).href,
  creator: { '@type': 'LocalBusiness', name: 'AD Photography', ...businessRef },
  image: allEntries.map((entry) => ({
    '@type': 'ImageObject',
    name: `${entry.couple}, ${entry.category}`,
    description: `${entry.couple} at ${entry.location}`,
    contentLocation: { '@type': 'Place', name: entry.location },
  })),
};
---

<BaseLayout
  title="Toronto Wedding Photography Portfolio"
  description="Browse my full Toronto wedding, pre-wedding, civil ceremony, and film portfolio. Love stories captured across the GTA by AD Photography."
  jsonLd={gallerySchema}
>
  <div class="sr-only">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/portfolio' },
    ]} />
  </div>

  <!-- ═══ HERO ═══ -->
  <section style="padding-top: var(--spacing-block);">
    <div class="container-editorial">
      <div class="grid-editorial items-center" style="min-height: 80svh;">
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">Portfolio</p>
          <h1 class="text-display-md char-reveal measure-medium">
            Toronto wedding <em>photography portfolio.</em>
          </h1>
          <p class="text-body-lg text-on-surface-variant mt-8 measure-wide">
            The glances that say everything. The hands that hold on a little tighter. The moments between the moments. Every story is a chapter, and each one deserves its own voice.
          </p>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 aspect-[3/4] overflow-hidden hover-zoom reveal-right stagger-2 image-caption" data-caption="From The Archive">
          <Image
            src={heroImage}
            alt="Toronto wedding photography portfolio by AD Photography"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={75}
            format="avif"
            class="w-full h-full object-cover parallax-img"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>

      <div class="flex flex-col items-center mt-16 reveal stagger-3">
        <p class="text-label-sm text-on-surface-muted mb-3">Explore By Chapter</p>
        <div class="scroll-chevron">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-on-surface-muted" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EXPLORE BY CHAPTER ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="text-center mb-20 reveal">
        <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule eyebrow-rule-center">Explore By Chapter</p>
        <h2 class="text-display-md">Every story has a setting.</h2>
      </div>

      <div class="space-y-24 md:space-y-32">
        {chapters.map((chapter, i) => (
          <div class="grid-editorial items-center">
            <div class:list={[
              'col-span-12 lg:col-span-6 aspect-[3/4] overflow-hidden hover-zoom image-caption',
              i % 2 === 0 ? 'reveal-left' : 'reveal-right',
              i % 2 === 1 ? 'lg:col-start-7 lg:row-start-1' : '',
            ]} data-caption={chapter.caption}>
              <Image
                src={chapter.image}
                alt={chapter.alt}
                widths={[640, 960, 1280]}
                sizes="(max-width: 1024px) 100vw, 50vw"
                quality={85}
                class="w-full h-full object-cover parallax-img"
                loading="lazy"
              />
            </div>
            <div class:list={[
              'col-span-12 lg:col-span-5 reveal stagger-2',
              i % 2 === 1 ? 'lg:col-start-1' : 'lg:col-start-8',
            ]}>
              <p class="text-label-md text-on-surface-muted eyebrow-rule">{chapter.eyebrow}</p>
              <h3 class="text-display-md mt-4">{chapter.title}</h3>
              <p class="text-body-lg text-on-surface-variant mt-6 measure-wide">{chapter.description}</p>
              <div class="mt-10">
                <a
                  href={chapter.href}
                  class="inline-flex items-center gap-3 text-label-md text-on-surface hover:text-on-surface-variant cubic-ease group"
                  style="transition-duration: var(--duration-hover);"
                >
                  View Gallery
                  <svg class="w-4 h-4 cubic-ease group-hover:translate-x-1" style="transition-duration: var(--duration-hover);" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ BREAKER · YEARS ═══
       Editorial credibility stamp between Chapters (curated) and Recent
       Work (full grid). Palette shifts to surface-dark; big serif
       numeral paired with a tight caption. No image, no reveal stagger
       — a pure typographic moment. -->
  <section class="breaker-stats" aria-label="Years of practice">
    <div class="breaker-stats__inner">
      <span class="breaker-stats__rule" aria-hidden="true"></span>
      <p class="breaker-stats__number">5</p>
      <p class="breaker-stats__unit">Years</p>
      <p class="breaker-stats__caption">
        of photographing real love stories across Toronto and beyond.
      </p>
    </div>
  </section>

  <!-- ═══ RECENT WORK ═══ -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-end mb-16">
        <div class="col-span-12 md:col-span-7 reveal">
          <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule">Every Story</p>
          <h2 class="text-display-md">Recent work.</h2>
        </div>
        <div class="col-span-12 md:col-span-4 md:col-start-9 mt-6 md:mt-0 reveal stagger-2">
          <p class="text-body-md text-on-surface-variant measure-wide">
            A curated selection across every chapter, in order of release.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-16">
        {allEntries.map((entry, i) => {
          const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
          const img = portfolioImages[imgPath]?.default;
          return img ? (
            <div class:list={['reveal', `stagger-${(i % 5) + 1}`, i % 3 === 1 ? 'lg:mt-24' : '']}>
              <PortfolioCard
                couple={entry.couple}
                location={entry.location}
                category={entry.category}
                coverImage={img}
                href={`/portfolio/${entry.slug ?? entry.id}`}
              />
            </div>
          ) : null;
        })}
      </div>
    </div>
  </section>

  <!-- ═══ BREAKER · IN THEIR WORDS ═══
       Dark-band couple testimonial. Palette inversion + pure typography
       interrupt the gallery-grid rhythm before the final CTA. Matches
       the homepage Breaker 1 grammar but sourced from a real couple
       voice rather than Kash's. -->
  <section class="breaker-quote" aria-label="Testimonial from a couple">
    <div class="breaker-quote__inner">
      <span class="breaker-rule" aria-hidden="true"></span>
      <blockquote class="breaker-quote__text">
        Captured every moment so beautifully without ever making it feel staged or forced. The photos feel so natural and real, exactly what we wanted.
      </blockquote>
      <p class="breaker-quote__attribution">Shania &amp; Vishal, Pre-Wedding</p>
    </div>
  </section>

  <FinalCTA
    title="Your story, next."
    body="Every season fills quickly. If my work speaks to you, let's start a conversation before your date is gone."
    ctaLabel="Begin Your Journey"
    background="background"
    image={ctaImage}
    imageAlt="Toronto wedding couple portrait by AD Photography"
    imageCaption="Begin Your Journey"
  />
</BaseLayout>
