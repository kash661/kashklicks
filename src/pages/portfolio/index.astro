---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { Image } from 'astro:assets';

import portfolio from '../../data/portfolio.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const categories = [
  { id: 'all', label: 'All' },
  { id: 'pre-wedding', label: 'Pre-Weddings' },
  { id: 'wedding', label: 'Weddings' },
  { id: 'event', label: 'Events' },
  { id: 'portrait', label: 'Portraits' },
  { id: 'civil-ceremony', label: 'Civil Ceremony' },
];

const gallerySchema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'KashKlicks Studios Portfolio',
  description: 'Wedding, pre-wedding, and event photography portfolio by KashKlicks Studios in Toronto.',
  url: new URL('/portfolio', Astro.site).href,
};
---

<BaseLayout
  title="Portfolio"
  description="Browse our wedding, pre-wedding, and event photography portfolio. Cinematic love stories captured across Toronto and the GTA."
  jsonLd={gallerySchema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/portfolio' },
    ]} />

    <SectionHeading
      title="Our Work"
      subtitle="Every couple, every moment — uniquely yours"
    />

    <!-- Filter Bar -->
    <div class="flex flex-wrap justify-center gap-3 mb-12" id="portfolio-filters">
      {categories.map((cat) => (
        <button
          class="filter-btn px-4 py-2 text-sm rounded-full border border-border text-text-secondary hover:text-accent hover:border-accent transition-colors data-[active]:bg-accent data-[active]:text-bg data-[active]:border-accent"
          data-filter={cat.id}
          data-active={cat.id === 'all' ? '' : undefined}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Portfolio Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4" id="portfolio-grid">
      {portfolio.map((entry) => {
        const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
        const img = portfolioImages[imgPath]?.default;
        const categorySlug = entry.category === 'pre-wedding' ? 'pre-weddings' : entry.category === 'civil-ceremony' ? 'civil-ceremony' : `${entry.category}s`;
        return img ? (
          <a
            href={`/portfolio/${categorySlug}`}
            class="portfolio-item group block"
            data-category={entry.category}
          >
            <div class="relative overflow-hidden rounded-lg aspect-[2/3]">
              <Image
                src={img}
                alt={`${entry.couple} — ${entry.location}`}
                widths={[300, 500]}
                sizes="(max-width: 640px) 100vw, (max-width: 1280px) 50vw, 20vw"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-bg/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
              <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
                <h3 class="font-heading text-lg font-bold">{entry.couple}</h3>
                <p class="text-xs text-text-secondary">{entry.location}</p>
              </div>
            </div>
          </a>
        ) : null;
      })}
    </div>
  </div>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.portfolio-item');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.removeAttribute('data-active'));
        btn.setAttribute('data-active', '');

        const filter = btn.getAttribute('data-filter');
        items.forEach((item) => {
          if (filter === 'all' || item.getAttribute('data-category') === filter) {
            (item as HTMLElement).style.display = '';
          } else {
            (item as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
