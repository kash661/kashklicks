---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PortfolioCard from '../../components/ui/PortfolioCard.astro';
import Button from '../../components/ui/Button.astro';
import { Image } from 'astro:assets';

import portfolio from '../../data/portfolio.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const categories = [
  { id: 'all', label: 'All Work' },
  { id: 'pre-wedding', label: 'Pre-Weddings' },
  { id: 'wedding', label: 'Weddings' },
  { id: 'civil-ceremony', label: 'Civil Ceremony' },
  { id: 'films', label: 'Films' },
];

const gallerySchema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'AD Photography Portfolio',
  description: 'Wedding, pre-wedding, and event photography portfolio by AD Photography in Toronto.',
  url: new URL('/portfolio', Astro.site).href,
  creator: {
    '@type': 'LocalBusiness',
    name: 'AD Photography',
  },
};
---

<BaseLayout
  title="Portfolio"
  description="Browse our wedding, pre-wedding, and civil ceremony photography portfolio. Love stories captured across Toronto and the GTA."
  jsonLd={gallerySchema}
>
  <!-- Hero -->
  <section class="py-[var(--spacing-section)]">
    <div class="container-editorial">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Portfolio', href: '/portfolio' },
      ]} />

      <div class="mt-[var(--spacing-block)] max-w-3xl reveal">
        <h1 class="text-display-md">Capturing the Unspoken</h1>
        <p class="text-body-lg text-on-surface-variant mt-[var(--spacing-element)]">
          The glances that say everything. The hands that hold on a little tighter.
          The moments between the moments. This is where we live.
        </p>
      </div>
    </div>
  </section>

  <!-- Filter + Grid -->
  <section class="pb-[var(--spacing-section)]">
    <div class="container-editorial">

      <!-- Filter Tabs -->
      <div class="flex flex-wrap gap-6 mb-[var(--spacing-block)]" id="portfolio-filters" role="group" aria-label="Filter portfolio by category">
        {categories.map((cat) => (
          <button
            class="filter-btn text-label-md text-on-surface-muted cubic-ease pb-2 border-b-2 border-transparent data-[active]:text-on-surface data-[active]:border-on-surface"
            style="transition-duration: var(--duration-hover);"
            data-filter={cat.id}
            data-active={cat.id === 'all' ? '' : undefined}
            aria-pressed={cat.id === 'all' ? 'true' : 'false'}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Portfolio Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 reveal" id="portfolio-grid">
        {portfolio.map((entry, i) => {
          const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
          const img = portfolioImages[imgPath]?.default;
          const hasFilm = entry.hasFilm === true || (entry.youtubeUrl && entry.youtubeUrl !== null);
          return img ? (
            <div
              class={`portfolio-item stagger-${(i % 5) + 1}`}
              data-category={entry.category}
              data-film={hasFilm ? '' : undefined}
            >
              <PortfolioCard
                couple={entry.couple}
                location={entry.location}
                category={entry.category}
                coverImage={img}
                href={`/portfolio/${entry.slug ?? entry.id}`}
              />
            </div>
          ) : null;
        })}
      </div>
    </div>
  </section>

  <!-- Philosophy Quote -->
  <section class="py-[var(--spacing-section)] bg-surface">
    <div class="container-editorial">
      <div class="max-w-3xl mx-auto text-center reveal">
        <p class="text-quote">
          "A photograph is not about what you see. It is about what you felt in the fraction of a second
          before you pressed the shutter."
        </p>
      </div>
    </div>
  </section>

  <!-- Reserve CTA -->
  <section class="bg-surface-dark py-[var(--spacing-section)]">
    <div class="container-editorial">
      <div class="max-w-2xl mx-auto text-center reveal">
        <h2 class="text-display-md text-on-dark">Reserve your date</h2>
        <p class="text-body-lg text-on-dark-variant mt-[var(--spacing-element)]">
          Every season fills up. If our work speaks to you, let's start a conversation
          before your date is gone.
        </p>
        <div class="mt-[var(--spacing-block)]">
          <Button href="/contact" variant="primary">Get in Touch</Button>
        </div>
      </div>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.portfolio-item');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => {
          b.removeAttribute('data-active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.setAttribute('data-active', '');
        btn.setAttribute('aria-pressed', 'true');

        const filter = btn.getAttribute('data-filter');
        items.forEach((item) => {
          const el = item as HTMLElement;
          if (filter === 'all') {
            el.style.display = '';
          } else if (filter === 'films') {
            el.style.display = el.hasAttribute('data-film') ? '' : 'none';
          } else if (item.getAttribute('data-category') === filter) {
            el.style.display = '';
          } else {
            el.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
