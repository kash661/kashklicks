---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PortfolioCard from '../../components/ui/PortfolioCard.astro';
import Button from '../../components/ui/Button.astro';

import portfolio from '../../data/portfolio.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const entries = portfolio.filter((p) => p.category === 'civil-ceremony');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Civil Ceremony Photography, AD Photography',
  description: 'Intimate civil ceremony photography in Toronto by AD Photography.',
  url: new URL('/portfolio/civil-ceremony', Astro.site).href,
  creator: {
    '@type': 'LocalBusiness',
    name: 'AD Photography',
  },
  image: entries.map((entry) => ({
    '@type': 'ImageObject',
    name: `${entry.couple}, Civil Ceremony`,
    description: `Civil ceremony photography of ${entry.couple} at ${entry.location}`,
    contentLocation: {
      '@type': 'Place',
      name: entry.location,
    },
  })),
};
---

<BaseLayout
  title="Civil Ceremony Photography"
  description="Intimate civil ceremony photography in Toronto. Capturing the beauty of your courthouse or city hall wedding."
  jsonLd={schema}
>
  <!-- Hero -->
  <section class="py-[var(--spacing-section)]">
    <div class="container-editorial">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Portfolio', href: '/portfolio' },
        { label: 'Civil Ceremony', href: '/portfolio/civil-ceremony' },
      ]} />

      <div class="mt-[var(--spacing-block)] max-w-3xl reveal">
        <h1 class="text-display-md">Civil Ceremonies</h1>
        <p class="text-body-lg text-on-surface-variant mt-[var(--spacing-element)]">
          Intimate, beautiful moments, no matter the venue. Small ceremonies deserve
          the same attention to detail as the grandest celebrations.
        </p>
      </div>
    </div>
  </section>

  <!-- Grid -->
  <section class="pb-[var(--spacing-section)]">
    <div class="container-editorial">
      {entries.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 reveal">
          {entries.map((entry, i) => {
            const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
            const img = portfolioImages[imgPath]?.default;
            return img ? (
              <div class={`stagger-${(i % 5) + 1}`}>
                <PortfolioCard
                  couple={entry.couple}
                  location={entry.location}
                  category={entry.category}
                  coverImage={img}
                  href={`/portfolio/${entry.slug ?? entry.id}`}
                />
              </div>
            ) : null;
          })}
        </div>
      ) : (
        <div class="text-center py-[var(--spacing-section)]">
          <p class="text-body-lg text-on-surface-muted">New work coming soon. Check back or browse our other galleries.</p>
          <div class="mt-[var(--spacing-element)]">
            <Button href="/portfolio" variant="secondary">View All Work</Button>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Philosophy Quote -->
  <section class="py-[var(--spacing-section)] bg-surface">
    <div class="container-editorial">
      <div class="max-w-3xl mx-auto text-center reveal">
        <p class="text-quote">
          "The size of the ceremony has nothing to do with the size of the love."
        </p>
      </div>
    </div>
  </section>

  <!-- Reserve CTA -->
  <section class="bg-surface-dark py-[var(--spacing-section)]">
    <div class="container-editorial">
      <div class="max-w-2xl mx-auto text-center reveal">
        <h2 class="text-display-md text-on-dark">Reserve your date</h2>
        <p class="text-body-lg text-on-dark-variant mt-[var(--spacing-element)]">
          Planning a civil ceremony? Let's make sure every moment is preserved.
        </p>
        <div class="mt-[var(--spacing-block)]">
          <Button href="/contact" variant="primary">Book Coverage</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
