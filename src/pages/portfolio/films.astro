---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PortfolioCard from '../../components/ui/PortfolioCard.astro';
import Button from '../../components/ui/Button.astro';
import FinalCTA from '../../components/global/FinalCTA.astro';
import { Image } from 'astro:assets';

import portfolio from '../../data/portfolio.json';
import site from '../../data/site.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const ctaImage = (await import('../../assets/images/homepage/homepage-07.jpg')).default;

const entries = portfolio.filter(
  (p: any) =>
    p.hasFilm === true ||
    (p.youtubeUrl && p.youtubeUrl !== null) ||
    (Array.isArray(p.youtubeUrls) && p.youtubeUrls.length > 0)
);

const businessRef = { '@id': `${site.url}/#business` };

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Toronto Wedding Films, AD Photography',
  description: 'Cinematic wedding and pre-wedding films by AD Photography in Toronto and the GTA.',
  url: new URL('/portfolio/films', Astro.site).href,
  creator: { '@type': 'LocalBusiness', name: 'AD Photography', ...businessRef },
  image: entries.map((entry) => ({
    '@type': 'ImageObject',
    name: `${entry.couple}, Film`,
    description: `Cinematic film of ${entry.couple} at ${entry.location}`,
    contentLocation: { '@type': 'Place', name: entry.location },
  })),
};
---

<BaseLayout
  title="Toronto Wedding Films Portfolio"
  description="Cinematic Toronto wedding and pre-wedding films by AD Photography. Motion, sound, and feeling. Watch love stories unfold."
  jsonLd={schema}
>
  <div class="sr-only">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Films', href: '/portfolio/films' },
    ]} />
  </div>

  <!-- ═══ GALLERY ═══ -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-end mb-16">
        <div class="col-span-12 md:col-span-7 reveal">
          <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule">Films</p>
          <h1 class="text-display-md char-reveal">Toronto Wedding Films Collection</h1>
        </div>
        <div class="col-span-12 md:col-span-4 md:col-start-9 mt-6 md:mt-0 reveal stagger-2">
          <p class="text-body-md text-on-surface-variant" style="max-width: 32ch;">
            Short-form cinematic edits. Click through to watch the reel for each story.
          </p>
        </div>
      </div>

      {entries.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-16">
          {entries.map((entry, i) => {
            const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
            const img = portfolioImages[imgPath]?.default;
            return img ? (
              <div class:list={['reveal', `stagger-${(i % 5) + 1}`, i % 3 === 1 ? 'lg:mt-24' : '']}>
                <PortfolioCard
                  couple={entry.couple}
                  location={entry.location}
                  category={entry.category}
                  coverImage={img}
                  href={`/portfolio/${entry.slug ?? entry.id}`}
                />
              </div>
            ) : null;
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-body-lg text-on-surface-muted">New films coming soon. I'm currently editing some beautiful stories. Check back or browse my photography portfolio.</p>
          <div class="mt-8">
            <span class="magnetic inline-block"><Button href="/portfolio" variant="secondary">View All Work</Button></span>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ PHILOSOPHY ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="max-w-3xl mx-auto text-center reveal">
        <p class="text-quote">
          "Film lets you hear the laugh, feel the wind, and remember the silence between the words."
        </p>
      </div>
    </div>
  </section>

  <FinalCTA
    title="Want a film of your story?"
    body="Films are offered as an add-on to my wedding and pre-wedding coverage. Let's talk about what your reel could look like."
    ctaLabel="Begin The Conversation"
    ctaHref="/contact?service=film"
    background="background"
    image={ctaImage}
    imageAlt="Toronto wedding film still by AD Photography"
    imageCaption="In Motion"
  />
</BaseLayout>
