---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PortfolioCard from '../../components/ui/PortfolioCard.astro';
import Button from '../../components/ui/Button.astro';

import portfolio from '../../data/portfolio.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const entries = portfolio.filter((p) => p.hasFilm === true || (p.youtubeUrl && p.youtubeUrl !== null));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Wedding Films, AD Photography',
  description: 'Cinematic wedding and pre-wedding films by AD Photography in Toronto and the GTA.',
  url: new URL('/portfolio/films', Astro.site).href,
  creator: {
    '@type': 'LocalBusiness',
    name: 'AD Photography',
  },
  image: entries.map((entry) => ({
    '@type': 'ImageObject',
    name: `${entry.couple}, Film`,
    description: `Cinematic film of ${entry.couple} at ${entry.location}`,
    contentLocation: {
      '@type': 'Place',
      name: entry.location,
    },
  })),
};
---

<BaseLayout
  title="Films"
  description="Cinematic wedding and pre-wedding films by AD Photography. Watch love stories unfold from Toronto and the GTA."
  jsonLd={schema}
>
  <!-- Hero -->
  <section class="py-[var(--spacing-section)]">
    <div class="container-editorial">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Portfolio', href: '/portfolio' },
        { label: 'Films', href: '/portfolio/films' },
      ]} />

      <div class="mt-[var(--spacing-block)] max-w-3xl reveal">
        <h1 class="text-display-md">Our Films</h1>
        <p class="text-body-lg text-on-surface-variant mt-[var(--spacing-element)]">
          Cinematic stories from our sessions. Motion, sound, and feeling brought together
          in a way that still photography alone cannot capture.
        </p>
      </div>
    </div>
  </section>

  <!-- Grid -->
  <section class="pb-[var(--spacing-section)]">
    <div class="container-editorial">
      {entries.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 reveal">
          {entries.map((entry, i) => {
            const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
            const img = portfolioImages[imgPath]?.default;
            return img ? (
              <div class={`stagger-${(i % 5) + 1}`}>
                <PortfolioCard
                  couple={entry.couple}
                  location={entry.location}
                  category={entry.category}
                  coverImage={img}
                  href={`/portfolio/${entry.slug ?? entry.id}`}
                />
              </div>
            ) : null;
          })}
        </div>
      ) : (
        <div class="text-center py-[var(--spacing-section)]">
          <p class="text-body-lg text-on-surface-muted">New films coming soon. We're currently editing some beautiful stories. Check back soon or browse our photography portfolio.</p>
          <div class="mt-[var(--spacing-element)]">
            <Button href="/portfolio" variant="secondary">View All Work</Button>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Philosophy Quote -->
  <section class="py-[var(--spacing-section)] bg-surface">
    <div class="container-editorial">
      <div class="max-w-3xl mx-auto text-center reveal">
        <p class="text-quote">
          "Film lets you hear the laugh, feel the wind, and remember the silence between the words."
        </p>
      </div>
    </div>
  </section>

  <!-- Reserve CTA -->
  <section class="bg-surface-dark py-[var(--spacing-section)]">
    <div class="container-editorial">
      <div class="max-w-2xl mx-auto text-center reveal">
        <h2 class="text-display-md text-on-dark">Reserve your date</h2>
        <p class="text-body-lg text-on-dark-variant mt-[var(--spacing-element)]">
          Want a cinematic film of your story? Let's talk.
        </p>
        <div class="mt-[var(--spacing-block)]">
          <Button href="/contact" variant="primary">Book a Consultation</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
