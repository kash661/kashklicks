---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import GalleryGrid from '../../components/gallery/GalleryGrid.astro';
import Lightbox from '../../components/gallery/Lightbox.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';

import portfolio from '../../data/portfolio.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const entries = portfolio.filter((p) => p.category === 'pre-wedding');
const galleryImages = entries.flatMap((entry) =>
  entry.images.map((imgName) => {
    const imgPath = `/src/assets/images/portfolio/${imgName}`;
    const img = portfolioImages[imgPath]?.default;
    return img ? { src: img, alt: `${entry.couple} — pre-wedding photography at ${entry.location}` } : null;
  }).filter(Boolean)
) as { src: ImageMetadata; alt: string }[];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Pre-Wedding Photography Gallery — KashKlicks Studios',
  description: 'Pre-wedding and engagement photography in Toronto and the GTA.',
  url: new URL('/portfolio/pre-weddings', Astro.site).href,
};
---

<BaseLayout
  title="Pre-Wedding Photography"
  description="Cinematic pre-wedding and engagement photography in Toronto. View our portfolio of love stories captured at iconic GTA locations."
  jsonLd={schema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Pre-Weddings', href: '/portfolio/pre-weddings' },
    ]} />

    <SectionHeading
      title="Pre-Wedding Stories"
      subtitle="Cinematic engagement and pre-wedding sessions across Toronto and beyond"
    />

    {galleryImages.length > 0 ? (
      <GalleryGrid images={galleryImages} gallery="pre-weddings" columns={3} />
    ) : (
      <p class="text-center text-text-muted py-12">Gallery coming soon — check back for our latest pre-wedding sessions.</p>
    )}

    <div class="text-center mt-16">
      <p class="text-text-secondary mb-6">Ready to plan your pre-wedding session?</p>
      <Button href="/contact" variant="primary">Book a Consultation</Button>
    </div>
  </div>

  <Lightbox />
</BaseLayout>
