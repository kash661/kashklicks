---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PortfolioCard from '../../components/ui/PortfolioCard.astro';
import Button from '../../components/ui/Button.astro';
import PortfolioFinalCTA from '../../components/global/PortfolioFinalCTA.astro';
import { Image } from 'astro:assets';

import portfolio from '../../data/portfolio.json';
import site from '../../data/site.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const ctaImage = (await import('../../assets/images/homepage/homepage-06.jpg')).default;

const entries = portfolio.filter((p) => p.category === 'pre-wedding');

const businessRef = { '@id': `${site.url}/#business` };

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Toronto Pre-Wedding Photography Gallery, AD Photography',
  description: 'Pre-wedding and engagement photography portfolio in Toronto and the GTA by AD Photography.',
  url: new URL('/portfolio/pre-weddings', Astro.site).href,
  creator: { '@type': 'LocalBusiness', name: 'AD Photography', ...businessRef },
  image: entries.map((entry) => ({
    '@type': 'ImageObject',
    name: `${entry.couple}, Pre-Wedding`,
    description: `Pre-wedding photography of ${entry.couple} at ${entry.location}`,
    contentLocation: { '@type': 'Place', name: entry.location },
  })),
};
---

<BaseLayout
  title="Toronto Pre-Wedding & Engagement Photography Portfolio"
  description="Browse my Toronto pre-wedding and engagement photography portfolio. Cinematic sessions at the city's most beautiful locations."
  jsonLd={schema}
>
  <div class="sr-only">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Pre-Weddings', href: '/portfolio/pre-weddings' },
    ]} />
  </div>

  <!-- ═══ GALLERY ═══ -->
  <section class="section-frame bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-end" style="margin-bottom: var(--spacing-block);">
        <div class="col-span-12 md:col-span-7 reveal">
          <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">Pre-Weddings</p>
          <h1 class="section-title char-reveal">Toronto pre-wedding <em>collection.</em></h1>
        </div>
        <div class="col-span-12 md:col-span-5 md:col-start-8 mt-6 md:mt-0 reveal stagger-2">
          <p class="section-deck text-on-surface-variant measure-wide">
            Sessions across Toronto, the GTA, and beyond. Each love story, in its own setting.
          </p>
        </div>
      </div>

      {entries.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-20">
          {entries.map((entry, i) => {
            const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
            const img = portfolioImages[imgPath]?.default;
            return img ? (
              <div class:list={['reveal', `stagger-${(i % 5) + 1}`, i % 3 === 1 ? 'lg:mt-24' : '']}>
                <PortfolioCard
                  couple={entry.couple}
                  location={entry.location}
                  category={entry.category}
                  coverImage={img}
                  href={`/portfolio/${entry.slug ?? entry.id}`}
                  date={entry.date ?? null}
                />
              </div>
            ) : null;
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-body-lg text-on-surface-muted">New sessions coming soon. Check back or browse my other chapters.</p>
          <div class="mt-8">
            <span class="magnetic inline-block"><Button href="/portfolio" variant="secondary">View All Work</Button></span>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ PHILOSOPHY ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="max-w-3xl mx-auto text-center reveal">
        <p class="text-quote">
          "Before the big day, there is a quieter one. The light is softer, the pace is slower, and the photos tell the part of the story that no one sees coming."
        </p>
      </div>
    </div>
  </section>

  <PortfolioFinalCTA
    title="Plan your session."
    body="From location scouting to outfit guidance, I walk through every detail with you. Let's plan a session that feels like you."
    ctaLabel="Begin The Conversation"
    ctaHref="/contact?service=pre-wedding"
    background="background"
    image={ctaImage}
    imageAlt="Toronto pre-wedding couple portrait by AD Photography"
    imageCaption="Your Session"
  />
</BaseLayout>
