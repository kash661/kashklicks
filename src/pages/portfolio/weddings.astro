---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import PortfolioCard from '../../components/ui/PortfolioCard.astro';
import Button from '../../components/ui/Button.astro';
import { Image } from 'astro:assets';

import portfolio from '../../data/portfolio.json';
import site from '../../data/site.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const ctaImage = (await import('../../assets/images/homepage/homepage-01.jpg')).default;

const entries = portfolio.filter((p) => p.category === 'wedding');

const businessRef = { '@id': `${site.url}/#business` };

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Toronto Wedding Photography Gallery, AD Photography',
  description: 'Wedding day photography portfolio in Toronto and the GTA by AD Photography.',
  url: new URL('/portfolio/weddings', Astro.site).href,
  creator: { '@type': 'LocalBusiness', name: 'AD Photography', ...businessRef },
  image: entries.map((entry) => ({
    '@type': 'ImageObject',
    name: `${entry.couple}, Wedding`,
    description: `Wedding photography of ${entry.couple} at ${entry.location}`,
    contentLocation: { '@type': 'Place', name: entry.location },
  })),
};
---

<BaseLayout
  title="Toronto Wedding Photography Portfolio"
  description="Browse my Toronto wedding day photography portfolio. Timeless, cinematic coverage of ceremonies and receptions across the GTA."
  jsonLd={schema}
>
  <div class="sr-only">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Weddings', href: '/portfolio/weddings' },
    ]} />
  </div>

  <!-- ═══ GALLERY ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-end mb-16">
        <div class="col-span-12 md:col-span-7 reveal">
          <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule">Weddings</p>
          <h1 class="text-display-md char-reveal">Toronto Wedding Day Gallery</h1>
        </div>
        <div class="col-span-12 md:col-span-4 md:col-start-9 mt-6 md:mt-0 reveal stagger-2">
          <p class="text-body-md text-on-surface-variant" style="max-width: 32ch;">
            Full-day coverage, honest moments, one couple at a time.
          </p>
        </div>
      </div>

      {entries.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-16">
          {entries.map((entry, i) => {
            const imgPath = `/src/assets/images/portfolio/${entry.coverImage}`;
            const img = portfolioImages[imgPath]?.default;
            return img ? (
              <div class:list={['reveal', `stagger-${(i % 5) + 1}`, i % 3 === 1 ? 'lg:mt-24' : '']}>
                <PortfolioCard
                  couple={entry.couple}
                  location={entry.location}
                  category={entry.category}
                  coverImage={img}
                  href={`/portfolio/${entry.slug ?? entry.id}`}
                />
              </div>
            ) : null;
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-body-lg text-on-surface-muted">New work coming soon. Check back or browse my other chapters.</p>
          <div class="mt-8">
            <span class="magnetic inline-block"><Button href="/portfolio" variant="secondary">View All Work</Button></span>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ PHILOSOPHY ═══ -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="max-w-3xl mx-auto text-center reveal">
        <p class="text-quote">
          "Your wedding day moves fast. The images should make you stop and feel it all over again."
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial items-center">
        <div class="col-span-12 md:col-span-5 reveal">
          <p class="text-label-md text-on-surface-muted mb-4 eyebrow-rule">Ready?</p>
          <h2 class="text-display-md text-on-surface">Reserve your date.</h2>
          <p class="text-body-lg text-on-surface-variant mt-4" style="max-width: 40ch;">
            Looking for wedding day coverage? Let's talk about your vision and find the right fit.
          </p>
          <div class="mt-8">
            <span class="magnetic inline-block"><Button href="/contact?service=wedding" variant="primary">Begin The Conversation</Button></span>
          </div>
        </div>
        <div class="col-span-12 md:col-span-6 md:col-start-7 aspect-[3/4] overflow-hidden hover-zoom reveal-right stagger-2 image-caption" data-caption="Begin The Conversation">
          <Image
            src={ctaImage}
            alt="Toronto wedding couple portrait by AD Photography"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            quality={90}
            class="w-full h-full object-cover parallax-img"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
