---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import GalleryGrid from '../../components/gallery/GalleryGrid.astro';
import Lightbox from '../../components/gallery/Lightbox.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';

import portfolio from '../../data/portfolio.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const entries = portfolio.filter((p) => p.category === 'wedding');
const galleryImages = entries.flatMap((entry) =>
  entry.images.map((imgName) => {
    const imgPath = `/src/assets/images/portfolio/${imgName}`;
    const img = portfolioImages[imgPath]?.default;
    return img ? { src: img, alt: `${entry.couple} — wedding photography at ${entry.location}` } : null;
  }).filter(Boolean)
) as { src: ImageMetadata; alt: string }[];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Wedding Photography Gallery — KashKlicks Studios',
  description: 'Wedding day photography in Toronto and the GTA by KashKlicks Studios.',
  url: new URL('/portfolio/weddings', Astro.site).href,
};
---

<BaseLayout
  title="Wedding Photography"
  description="Beautiful wedding day photography in Toronto and the GTA. Timeless, cinematic coverage of your most important day."
  jsonLd={schema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Weddings', href: '/portfolio/weddings' },
    ]} />

    <SectionHeading
      title="Wedding Day Stories"
      subtitle="Timeless coverage of your most important day"
    />

    {galleryImages.length > 0 ? (
      <GalleryGrid images={galleryImages} gallery="weddings" columns={3} />
    ) : (
      <p class="text-center text-text-muted py-12">Wedding gallery coming soon — stay tuned for our latest work.</p>
    )}

    <div class="text-center mt-16">
      <p class="text-text-secondary mb-6">Looking for wedding day coverage?</p>
      <Button href="/contact" variant="primary">Let's Talk</Button>
    </div>
  </div>

  <Lightbox />
</BaseLayout>
