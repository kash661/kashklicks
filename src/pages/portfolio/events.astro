---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import GalleryGrid from '../../components/gallery/GalleryGrid.astro';
import Lightbox from '../../components/gallery/Lightbox.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import Button from '../../components/ui/Button.astro';

import portfolio from '../../data/portfolio.json';

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/*.jpg',
  { eager: true }
);

const entries = portfolio.filter((p) => p.category === 'event');
const galleryImages = entries.flatMap((entry) =>
  entry.images.map((imgName) => {
    const imgPath = `/src/assets/images/portfolio/${imgName}`;
    const img = portfolioImages[imgPath]?.default;
    return img ? { src: img, alt: `${entry.couple} — event photography at ${entry.location}` } : null;
  }).filter(Boolean)
) as { src: ImageMetadata; alt: string }[];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: 'Event Photography Gallery — KashKlicks Studios',
  description: 'Birthday, bridal shower, baby shower, and celebration photography in Toronto.',
  url: new URL('/portfolio/events', Astro.site).href,
};
---

<BaseLayout
  title="Event Photography"
  description="Celebration and event photography in Toronto. Birthdays, bridal showers, baby showers, and more — captured with style."
  jsonLd={schema}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Events', href: '/portfolio/events' },
    ]} />

    <SectionHeading
      title="Celebrations"
      subtitle="Birthdays, showers, parties — every celebration deserves great photos"
    />

    {galleryImages.length > 0 ? (
      <GalleryGrid images={galleryImages} gallery="events" columns={3} />
    ) : (
      <p class="text-center text-text-muted py-12">Event gallery coming soon — check back for our latest celebrations.</p>
    )}

    <div class="text-center mt-16">
      <p class="text-text-secondary mb-6">Have an event coming up?</p>
      <Button href="/contact" variant="primary">Get a Quote</Button>
    </div>
  </div>

  <Lightbox />
</BaseLayout>
