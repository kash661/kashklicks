---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import GalleryImage from '../../components/gallery/GalleryImage.astro';
import Lightbox from '../../components/gallery/Lightbox.astro';
import YouTubeEmbed from '../../components/gallery/YouTubeEmbed.astro';
import RelatedGalleries from '../../components/portfolio/RelatedGalleries.astro';
import Button from '../../components/ui/Button.astro';
import FinalCTA from '../../components/global/FinalCTA.astro';
import portfolio from '../../data/portfolio.json';
import site from '../../data/site.json';
import { Image } from 'astro:assets';

export function getStaticPaths() {
  return portfolio.map((entry) => ({
    params: { slug: entry.slug ?? entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/**/*.jpg',
  { eager: true }
);

// Resolve images - try subfolder first, then flat
const galleryImages = entry.images.map((imgName: string) => {
  const subfolderPath = `/src/assets/images/portfolio/${entry.id}/${imgName}`;
  const flatPath = `/src/assets/images/portfolio/${imgName}`;
  const img = portfolioImages[subfolderPath]?.default || portfolioImages[flatPath]?.default;
  return img ? { src: img, alt: `${entry.couple}, ${entry.location} photography by AD Photography` } : null;
}).filter(Boolean) as { src: ImageMetadata; alt: string }[];

// Category label mapping
const categoryLabels: Record<string, string> = {
  'pre-wedding': 'Pre-Weddings',
  'wedding': 'Weddings',
  'civil-ceremony': 'Civil Ceremony',
};
const categoryLabel = categoryLabels[entry.category] || entry.category;
const categorySlug = entry.category === 'pre-wedding' ? 'pre-weddings' : entry.category;

// Singular form for the gallery plate label
const plateLabels: Record<string, string> = {
  'pre-wedding': 'Pre-Wedding',
  'wedding': 'Wedding',
  'civil-ceremony': 'Civil Ceremony',
};
const platePrimary = plateLabels[entry.category] || entry.category;
const plateLabel = entry.hasFilm ? `${platePrimary} · Film` : platePrimary;

const coupleParts = entry.couple.split(/\s*[+&]\s*/);
const coupleHasAmp = coupleParts.length === 2 && coupleParts[0] && coupleParts[1];

// SEO
const pageTitle = `${entry.couple} | ${categoryLabel} Photography`;
const pageDescription = entry.story?.body?.slice(0, 155) ||
  `${categoryLabel} photography of ${entry.couple} at ${entry.location}. View the full gallery by AD Photography, Toronto wedding photographer.`;

// Format date
const formattedDate = entry.date
  ? new Date(entry.date + 'T00:00:00').toLocaleDateString('en-CA', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

// Structured data
const schemas: any[] = [{
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: `${entry.couple}, ${categoryLabel} Photography at ${entry.location}`,
  description: pageDescription,
  url: `${site.url}/portfolio/${entry.slug ?? entry.id}`,
  datePublished: entry.date,
  creator: { '@type': 'LocalBusiness', name: 'AD Photography', url: site.url },
  contentLocation: {
    '@type': 'Place',
    name: entry.location,
    address: { '@type': 'PostalAddress', addressRegion: 'ON', addressCountry: 'CA' }
  },
}];

// Films can be a single youtubeUrl (legacy) or a youtubeUrls array.
const films: string[] = (entry as any).youtubeUrls?.length
  ? (entry as any).youtubeUrls
  : entry.youtubeUrl
    ? [entry.youtubeUrl]
    : [];

films.forEach((film, i) => {
  const videoId = film.includes('youtu.be/')
    ? film.split('youtu.be/')[1]?.split('?')[0]
    : new URL(film).searchParams.get('v');
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'VideoObject',
    name: films.length > 1
      ? `${entry.couple}, Film ${i + 1}`
      : `${entry.couple}, Pre-Wedding Film`,
    description: `Film of ${entry.couple} at ${entry.location} by AD Photography.`,
    thumbnailUrl: galleryImages[0]?.src?.src ? `${site.url}${galleryImages[0].src.src}` : undefined,
    embedUrl: `https://www.youtube-nocookie.com/embed/${videoId}`,
    uploadDate: entry.date,
  });
});

// Split gallery images for bento layout
const remainingImages = galleryImages;
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={schemas}>

  <!-- Collection Header -->
  <section class="py-[var(--spacing-section)]">
    <div class="container-editorial">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Portfolio', href: '/portfolio' },
        { label: categoryLabel, href: `/portfolio/${categorySlug}` },
        { label: entry.couple, href: `/portfolio/${entry.slug ?? entry.id}` },
      ]} />

      <figure class="gallery-plaque gallery-plaque--standalone reveal mt-[var(--spacing-block)]">
        <figcaption class="gallery-plaque__line">
          <span class="gallery-plaque__plate">{plateLabel}</span>
          <span class="gallery-plaque__rule" aria-hidden="true"></span>
          <span class="gallery-plaque__meta">
            {entry.location}{formattedDate ? ` · ${formattedDate}` : ''}
          </span>
        </figcaption>
        <h1 class="gallery-plaque__title gallery-plaque__title--display">
          {coupleHasAmp ? (
            <>{coupleParts[0]} <em>&amp;</em> {coupleParts[1]}</>
          ) : entry.couple}
        </h1>
      </figure>
    </div>
  </section>

  <!-- Story sidebar + Gallery, side-by-side on desktop -->
  <section class="pb-[var(--spacing-section)]">
    <div class="container-editorial">
      <div class="grid-editorial">
        <!-- Gallery column (film + masonry) on the LEFT -->
        <div class={((entry.story || entry.locationDescription) ? 'col-span-12 lg:col-span-8 lg:col-start-1' : 'col-span-12')}>
          {entry.hasFilm && films.length > 0 && (
            <div class="mb-[var(--spacing-block)] reveal">
              <h2 class="text-heading-md mb-[var(--spacing-element)]">{films.length > 1 ? 'The Films' : 'The Film'}</h2>
              <div class="space-y-[var(--spacing-element)]">
                {films.map((url, i) => (
                  <YouTubeEmbed
                    url={url}
                    title={films.length > 1
                      ? `${entry.couple}, Film ${i + 1} by AD Photography`
                      : `${entry.couple}, Film by AD Photography`}
                  />
                ))}
              </div>
            </div>
          )}
          {remainingImages.length > 0 && (
            <div class="columns-2 lg:columns-3" style="column-gap: var(--spacing-tight);">
              {remainingImages.map((img) => (
                <div class="mb-[var(--spacing-tight)] break-inside-avoid">
                  <GalleryImage
                    src={img.src}
                    alt={img.alt}
                    gallery={entry.id}
                  />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Sidebar: story, pull quote, location blurb on the RIGHT -->
        {(entry.story || entry.locationDescription) && (
          <aside class="col-span-12 lg:col-span-4 lg:col-start-9 lg:sticky lg:top-28 lg:self-start lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto mt-[var(--spacing-block)] lg:mt-0 reveal">
            {entry.story && (
              <div>
                <h2 class="text-heading-lg">{entry.story.headline}</h2>
                <div class="mt-[var(--spacing-element)] space-y-4">
                  {entry.story.body.split('\n\n').map((paragraph: string) => (
                    <p class="text-body-md text-on-surface-variant">{paragraph}</p>
                  ))}
                </div>
                {entry.story.pullQuote && (
                  <blockquote class="text-quote mt-[var(--spacing-block)]">
                    "{entry.story.pullQuote}"
                  </blockquote>
                )}
              </div>
            )}
            {entry.locationDescription && (
              <div class="mt-[var(--spacing-block)]">
                <span class="text-label-md text-on-surface-muted">About the Location</span>
                <p class="text-body-md text-on-surface-variant mt-[var(--spacing-tight)]">{entry.locationDescription}</p>
              </div>
            )}
          </aside>
        )}
      </div>
    </div>
  </section>

  <!-- Related Galleries -->
  <div class="container-editorial">
    <RelatedGalleries currentId={entry.id} category={entry.category} />
  </div>

  <FinalCTA
    title="Reserve your date."
    body="Every session is unique, just like yours. Let's create something beautiful together."
    ctaLabel="Get in Touch"
    background="surface-dim"
  />

  <Lightbox />
</BaseLayout>
