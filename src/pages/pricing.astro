---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import PricingCard from '../components/ui/PricingCard.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import Button from '../components/ui/Button.astro';
import { Image } from 'astro:assets';

import packages from '../data/packages.json';
import faqData from '../data/faq.json';
import site from '../data/site.json';

import heroImage from '../assets/images/hero/hero-main.jpg';

const preWeddingPackages = packages.filter((p) => p.category === 'Pre-Wedding').sort((a, b) => a.order - b.order);
const weddingPackages = packages.filter((p) => p.category === 'Wedding').sort((a, b) => a.order - b.order);
const eventPackages = packages.filter((p) => p.category === 'Events');

const offerCatalogSchema = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: 'AD Photography Packages',
  description: 'Wedding, pre-wedding, and event photography packages by AD Photography in Toronto.',
  url: `${site.url}/pricing`,
  offeredBy: {
    '@type': 'LocalBusiness',
    name: 'AD Photography',
    url: site.url,
  },
  itemListElement: packages.filter((p) => p.price !== null).map((p) => ({
    '@type': 'Offer',
    name: p.name,
    description: p.description,
    price: p.salePrice || p.price,
    priceCurrency: p.currency,
    availability: 'https://schema.org/InStock',
    seller: {
      '@type': 'LocalBusiness',
      name: 'AD Photography',
    },
  })),
};
---

<BaseLayout
  title="Investment"
  description="AD Photography pricing and packages. Wedding day coverage from $1,200, pre-wedding sessions from $350. View all packages, add-ons, and book your free consultation."
  jsonLd={offerCatalogSchema}
>
  <!-- Hero -->
  <section class="container-editorial" style="padding-top: var(--spacing-section);">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: 'Investment', href: '/pricing' },
    ]} />

    <div class="grid-editorial items-end" style="margin-top: var(--spacing-block);">
      <div class="col-span-5">
        <p class="text-label-md text-on-surface-muted reveal">The Investment</p>
        <h1 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element);">Investment</h1>
      </div>
      <div class="col-span-6 col-start-7">
        <p class="text-body-lg italic text-on-surface-variant reveal stagger-2" style="max-width: 48ch;">
          "Every frame is a decision to preserve something fleeting. The investment is not in photographs. It is in the weight of a moment you will want to hold forever."
        </p>
      </div>
    </div>
  </section>

  <!-- Full-width hero image -->
  <section style="margin-top: var(--spacing-block);">
    <div class="w-full overflow-hidden" style="max-height: 56vh;">
      <Image
        src={heroImage}
        alt="AD Photography editorial wedding session"
        widths={[800, 1200, 1920, 2560]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>
  </section>

  <!-- Pre-Wedding Packages -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <p class="text-label-md text-on-surface-muted reveal">Curated Collections</p>
      <h2 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element);">Pre-Wedding</h2>

      <div class="grid grid-cols-1 md:grid-cols-12 reveal stagger-2" style="margin-top: var(--spacing-block); gap: 2px;">
        {preWeddingPackages.map((pkg, i) => (
          <div class={i === 0 ? 'md:col-span-7' : i === 1 ? 'md:col-span-5' : 'md:col-span-4'}>
            <PricingCard
              id={pkg.id}
              name={pkg.name}
              price={pkg.price}
              salePrice={pkg.salePrice}
              description={pkg.description}
              highlights={pkg.highlights}
              popular={pkg.popular}
              featured={!!pkg.salePrice}
              custom={!!pkg.custom}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wedding Packages -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <p class="text-label-md text-on-surface-muted reveal">Curated Collections</p>
      <h2 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element);">Wedding Day</h2>

      <div class="grid grid-cols-1 md:grid-cols-12 reveal stagger-2" style="margin-top: var(--spacing-block); gap: 2px;">
        {weddingPackages.map((pkg, i) => (
          <div class={i === 0 ? 'md:col-span-4' : i === 1 ? 'md:col-span-5' : 'md:col-span-3'}>
            <PricingCard
              id={pkg.id}
              name={pkg.name}
              price={pkg.price}
              salePrice={pkg.salePrice}
              description={pkg.description}
              highlights={pkg.highlights}
              popular={pkg.popular}
              featured={!!pkg.salePrice}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Events Packages -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <p class="text-label-md text-on-surface-muted reveal">Curated Collections</p>
      <h2 class="text-display-md reveal stagger-1" style="margin-top: var(--spacing-element);">Events & Celebrations</h2>

      <div class="grid grid-cols-1 md:grid-cols-12 reveal stagger-2" style="margin-top: var(--spacing-block); gap: 2px;">
        {eventPackages.map((pkg) => (
          <div class="md:col-span-5">
            <PricingCard
              id={pkg.id}
              name={pkg.name}
              price={pkg.price}
              salePrice={pkg.salePrice}
              description={pkg.description}
              highlights={pkg.highlights}
              featured={!!pkg.salePrice}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Add-Ons -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial">
        <div class="col-span-4">
          <p class="text-label-md text-on-surface-muted reveal">Enhancements</p>
          <h2 class="text-heading-lg reveal stagger-1" style="margin-top: var(--spacing-element);">Add-Ons</h2>
        </div>
        <div class="col-span-7 col-start-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 reveal stagger-2" style="gap: var(--spacing-block);">
            <div>
              <p class="text-label-md text-on-surface-muted">+$35</p>
              <p class="text-heading-md" style="margin-top: 4px;">Raw Photo Files</p>
              <p class="text-body-md text-on-surface-variant" style="margin-top: var(--spacing-element);">All unedited photo files delivered digitally</p>
            </div>
            <div>
              <p class="text-label-md text-on-surface-muted">+$50</p>
              <p class="text-heading-md" style="margin-top: 4px;">Raw Video Files</p>
              <p class="text-body-md text-on-surface-variant" style="margin-top: var(--spacing-element);">All unedited video footage delivered digitally</p>
            </div>
            <div>
              <p class="text-label-md text-on-surface-muted">+$100/hr</p>
              <p class="text-heading-md" style="margin-top: 4px;">Second Photographer</p>
              <p class="text-body-md text-on-surface-variant" style="margin-top: var(--spacing-element);">Additional coverage from a second angle</p>
            </div>
            <div>
              <p class="text-label-md text-on-surface-muted">Custom</p>
              <p class="text-heading-md" style="margin-top: 4px;">Custom Package</p>
              <p class="text-body-md text-on-surface-variant" style="margin-top: var(--spacing-element);">Need something specific? Let's build your perfect package</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Good to Know -->
  <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial">
        <div class="col-span-4">
          <h2 class="text-heading-lg reveal">Good to Know</h2>
        </div>
        <div class="col-span-7 col-start-6">
          <ul class="reveal stagger-1" style="display: flex; flex-direction: column; gap: var(--spacing-element);">
            <li class="text-body-lg text-on-surface-variant">
              <strong class="text-on-surface">Free consultation</strong> included with every booking. No pressure, just a conversation about your vision.
            </li>
            <li class="text-body-lg text-on-surface-variant">
              <strong class="text-on-surface">Location guidance</strong> is part of the process. We help you find the perfect spot for your session.
            </li>
            <li class="text-body-lg text-on-surface-variant">
              <strong class="text-on-surface">Travel within the GTA</strong> is typically included. We will discuss any additional fees upfront.
            </li>
            <li class="text-body-lg text-on-surface-variant">
              <strong class="text-on-surface">Available Canada-wide.</strong> Based in Toronto, but we travel for love.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-background" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial">
      <div class="grid-editorial">
        <div class="col-span-4">
          <p class="text-label-md text-on-surface-muted reveal">Common Questions</p>
          <h2 class="text-heading-lg reveal stagger-1" style="margin-top: var(--spacing-element);">FAQ</h2>
        </div>
        <div class="col-span-7 col-start-6 reveal stagger-2">
          <FAQAccordion items={faqData} />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-surface-dark" style="padding: var(--spacing-section) 0;">
    <div class="container-editorial text-center">
      <p class="text-label-md text-on-dark-variant reveal">Not sure which collection?</p>
      <h2 class="text-display-md text-on-dark reveal stagger-1" style="margin-top: var(--spacing-element);">Let's find the right fit.</h2>
      <p class="text-body-lg text-on-dark-variant reveal stagger-2" style="margin-top: var(--spacing-element); max-width: 50ch; margin-left: auto; margin-right: auto;">
        Book a free consultation. We will walk through your vision, recommend the right package, and handle the rest.
      </p>
      <div class="flex flex-wrap justify-center reveal stagger-3" style="margin-top: var(--spacing-block); gap: var(--spacing-element);">
        <Button href="/contact?package=custom" variant="primary">Inquire for Custom</Button>
        <Button href="/contact" variant="secondary">Book Free Consultation</Button>
      </div>
    </div>
  </section>
</BaseLayout>
