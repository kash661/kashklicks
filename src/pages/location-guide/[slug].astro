---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import Button from '../../components/ui/Button.astro';
import LocationCarousel from '../../components/ui/LocationCarousel.astro';
import FinalCTA from '../../components/global/FinalCTA.astro';
import { Image } from 'astro:assets';
import locationsData from '../../data/locations.json';
import site from '../../data/site.json';

export const getStaticPaths = (() => {
  return locationsData.map((loc) => ({
    params: { slug: loc.id },
    props: { loc },
  }));
}) satisfies GetStaticPaths;

const locationImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/locations/*.jpg',
  { eager: true }
);

const galleryImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/locations-gallery/**/*.{jpg,jpeg,JPG,JPEG}',
  { eager: true }
);

const { loc } = Astro.props;
const coverImg = locationImages[`/src/assets/images/locations/${loc.image}`]?.default;

const galleryForThis = Object.entries(galleryImages)
  .filter(([path]) => path.includes(`/locations-gallery/${loc.id}/`))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default);

const landscapeFromGallery = galleryForThis.find((i) => i.width > i.height);
const img = landscapeFromGallery ?? coverImg;

const others = locationsData
  .filter((l) => l.id !== loc.id)
  .sort((a, b) => a.name.localeCompare(b.name));

const canonicalUrl = `${site.url}/location-guide/${loc.id}`;

const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  '@id': canonicalUrl,
  name: loc.name,
  description: loc.vibe,
  url: canonicalUrl,
  address: {
    '@type': 'PostalAddress',
    addressLocality: loc.area,
    addressRegion: 'ON',
    addressCountry: 'CA',
  },
};

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Location Guide', href: '/location-guide' },
  { label: loc.name, href: `/location-guide/${loc.id}` },
];

// Split long detail strings into headline + supporting text
const split = (value: string): { head: string; rest: string } => {
  const m = value.match(/^([^,.;]+)(?:[,.;]\s*)?(.*)$/);
  if (m) return { head: m[1].trim(), rest: m[2].trim() };
  return { head: value, rest: '' };
};

const walking = { head: loc.walkingLevel, rest: loc.walkingNote };
const permits = split(loc.permits);
const parking = split(loc.parking);
const travel = split(loc.travelTime);

const essentials = [
  { num: '01', label: 'Walking', ...walking },
  { num: '02', label: 'Permits', ...permits },
  { num: '03', label: 'Parking', ...parking },
  { num: '04', label: 'Travel', ...travel },
  { num: '05', label: 'Season', head: loc.season.join(', '), rest: '' },
];
---

<BaseLayout
  title={`${loc.name}, Toronto Photography Location`}
  description={`Photography at ${loc.name} in ${loc.area}. ${loc.vibe}. Parking, permits, walking level, and best seasons for pre-wedding, engagement, and couples shoots.`}
  canonicalUrl={canonicalUrl}
  jsonLd={[placeSchema]}
>
  <article>
    <!-- Intro -->
    <section style="padding-top: var(--spacing-block);">
      <div class="container-editorial">
        <Breadcrumbs items={breadcrumbItems} />

        <div class="grid-editorial items-end" style="margin-top: var(--spacing-block); margin-bottom: var(--spacing-block);">
          <div class="col-span-12 md:col-span-5 reveal">
            <p class="text-label-md text-on-surface-muted eyebrow-rule mb-4">{loc.area}</p>
            <h1 class="text-display-md font-serif char-reveal">{loc.name}</h1>
          </div>
          <div class="col-span-12 md:col-span-6 md:col-start-7 reveal stagger-2 mt-6 md:mt-0">
            <p class="text-quote text-on-surface-variant italic" style="font-family: var(--font-serif); max-width: 45ch;">
              "{loc.vibe}"
            </p>
          </div>
        </div>
      </div>

      {img && (
        <div class="reveal" style="margin-bottom: var(--spacing-section);">
          <Image
            src={img}
            alt={`${loc.name} photography location in ${loc.area}`}
            widths={[800, 1280, 1920]}
            sizes="100vw"
            class="w-full object-cover parallax-img"
            style="max-height: 80vh;"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      )}
    </section>

    <!-- Carousel (session frames at this location) -->
    <LocationCarousel images={galleryForThis} locationName={loc.name} />

    <!-- Ideal If + Tags -->
    <section class="container-editorial" style="padding: var(--spacing-section) 0 var(--spacing-block);">
      <div class="grid-editorial">
        <div class="col-span-12 md:col-span-8 md:col-start-3 reveal text-center">
          <p class="text-label-md text-on-surface-muted eyebrow-rule eyebrow-rule-center mb-6">Ideal if</p>
          <p class="text-quote font-serif italic text-on-surface" style="max-width: 32ch; margin: 0 auto;">
            "{loc.idealIf}"
          </p>
        </div>
      </div>

      <div class="grid-editorial" style="margin-top: var(--spacing-block);">
        <div class="col-span-12 md:col-span-10 md:col-start-2 reveal stagger-1">
          <div class="flex flex-wrap items-baseline justify-center gap-x-6 gap-y-3">
            <span class="text-label-sm text-on-surface-muted tracking-wider">Good for</span>
            {loc.bestFor.map((tag) => (
              <span class="text-label-md text-on-surface" style="font-family: var(--font-serif); font-style: italic;">{tag}</span>
            ))}
          </div>
          {loc.setting && loc.setting.length > 0 && (
            <div class="flex flex-wrap items-baseline justify-center gap-x-6 gap-y-3 mt-4">
              <span class="text-label-sm text-on-surface-muted tracking-wider">Setting</span>
              {loc.setting.map((s) => (
                <span class="text-label-md text-on-surface-variant">{s}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- The Essentials -->
    <section style="padding: var(--spacing-block) 0 var(--spacing-section); background: var(--color-background);">
      <div class="container-editorial">
        <div class="grid-editorial items-end" style="margin-bottom: var(--spacing-block);">
          <div class="col-span-12 md:col-span-7 reveal">
            <p class="text-label-md text-on-surface-muted eyebrow-rule mb-4">The Essentials</p>
            <h2 class="text-display-md font-serif">What to know before the shoot.</h2>
          </div>
        </div>

        <ol class="essentials-list reveal stagger-2">
          {essentials.map((e, i) => (
            <li class="essentials-row" style={`--stagger: ${i * 60}ms;`}>
              <div class="essentials-num">
                <span class="text-label-sm text-on-surface-muted tracking-wider">{e.num}</span>
              </div>
              <div class="essentials-label">
                <p class="text-label-md text-on-surface-variant tracking-wider">{e.label}</p>
              </div>
              <div class="essentials-value">
                <p class="text-heading-md font-serif">{e.head}</p>
                {e.rest && <p class="text-body-md text-on-surface-variant mt-2">{e.rest}</p>}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Also worth scouting -->
    <section class="bg-surface-dim" style="padding: var(--spacing-section) 0;">
      <div class="container-editorial">
        <div class="grid-editorial items-end" style="margin-bottom: var(--spacing-block);">
          <div class="col-span-12 md:col-span-5 reveal">
            <p class="text-label-md text-on-surface-muted eyebrow-rule mb-4">Also worth scouting</p>
            <h2 class="text-display-md font-serif">More places I love.</h2>
          </div>
          <div class="col-span-12 md:col-span-6 md:col-start-7 reveal stagger-2 mt-6 md:mt-0">
            <p class="text-body-lg text-on-surface-variant" style="max-width: 50ch;">
              Each one scouted for light, variety, and feel. Not just for the photo, but for how the day flows.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-10">
          {others.map((other, i) => {
            const otherImg = locationImages[`/src/assets/images/locations/${other.image}`]?.default;
            return otherImg ? (
              <a
                href={`/location-guide/${other.id}`}
                class="group block reveal"
                style={`transition-delay: ${(i % 3) * 80 + 100}ms;`}
              >
                <div class="aspect-[4/5] overflow-hidden bg-surface-container">
                  <Image
                    src={otherImg}
                    alt={`${other.name}, photography location in ${other.area}`}
                    widths={[400, 640]}
                    sizes="(max-width: 768px) 100vw, 33vw"
                    class="w-full h-full object-cover cubic-ease group-hover:scale-[1.03]"
                    style="transition-duration: var(--duration-slow);"
                    loading="lazy"
                  />
                </div>
                <div class="mt-4">
                  <h3 class="text-heading-md font-serif">{other.name}</h3>
                  <p class="text-label-sm text-on-surface-muted mt-1">{other.area}</p>
                </div>
              </a>
            ) : null;
          })}
        </div>

        <div class="mt-16 flex justify-center">
          <a
            href="/location-guide"
            class="text-label-md text-on-surface-variant hover:text-on-surface cubic-ease underline underline-offset-4"
            style="transition-duration: var(--duration-hover);"
          >
            Back to the full guide
          </a>
        </div>
      </div>
    </section>

    <FinalCTA
      title={`Let's shoot at ${loc.name}.`}
      body="Let's talk about your vision and map the perfect session."
      ctaLabel="Start the Conversation"
      ctaHref={`/contact?location=${loc.id}`}
      background="background"
    />
  </article>
</BaseLayout>

<style>
  .essentials-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: essentials;
  }

  .essentials-row {
    display: grid;
    grid-template-columns: 60px 160px 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 32px 0;
    border-top: 1px solid var(--color-surface-container);
  }

  .essentials-row:last-child {
    border-bottom: 1px solid var(--color-surface-container);
  }

  .essentials-num {
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .essentials-row {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
      gap: 4px 8px;
      padding: 24px 0;
    }
    .essentials-num {
      grid-row: 1;
      grid-column: 1;
    }
    .essentials-label {
      grid-row: 1;
      grid-column: 2;
    }
    .essentials-value {
      grid-row: 2;
      grid-column: 1 / -1;
    }
  }
</style>
