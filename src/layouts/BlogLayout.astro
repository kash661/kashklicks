---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  author?: string;
  coverImage?: ImageMetadata;
  coverImageAlt?: string;
  tags?: string[];
}

const {
  title,
  description,
  publishDate,
  updatedDate,
  author = 'AD',
  coverImage,
  coverImageAlt,
  tags = [],
} = Astro.props;

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: author,
  },
  datePublished: publishDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  ...(coverImage && { image: coverImage.src }),
  publisher: {
    '@type': 'Organization',
    name: 'AD Photography',
    url: 'https://kashklicks.ca',
  },
};

const formattedDate = publishDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  jsonLd={blogPostSchema}
  article={{
    publishedTime: publishDate.toISOString(),
    modifiedTime: updatedDate?.toISOString(),
    author,
    tags,
  }}
>
  <article class="container-editorial" style="padding-top: var(--spacing-block); padding-bottom: var(--spacing-section);">
    <div class="max-w-3xl mx-auto">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Blog', href: '/blog' },
        { label: title, href: Astro.url.pathname },
      ]} />

      <header style="margin-bottom: var(--spacing-block);">
        <p class="text-label-md text-on-surface-muted reveal eyebrow-rule mb-6">{tags[0] ?? 'Story'}</p>
        <h1 class="text-display-md leading-tight">{title}</h1>
        <p class="text-body-lg text-on-surface-variant mt-4" style="max-width: 55ch;">{description}</p>
        <div class="flex items-center gap-3 text-label-sm text-on-surface-muted mt-8">
          <time datetime={publishDate.toISOString()}>{formattedDate}</time>
          {tags.length > 1 && (
            <>
              <span aria-hidden="true">/</span>
              <div class="flex gap-2">
                {tags.slice(1).map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            </>
          )}
        </div>
        {coverImage && (
          <div class="mt-10 aspect-[16/9] overflow-hidden reveal image-caption" data-caption={tags[0] ?? 'Read'}>
            <Image
              src={coverImage}
              alt={coverImageAlt || title}
              widths={[600, 900, 1200]}
              sizes="(max-width: 768px) 100vw, 720px"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              format="avif"
              quality={75}
              class="w-full h-full object-cover"
            />
          </div>
        )}
      </header>

      <div class="prose-editorial">
        <slot />
      </div>

      <footer class="mt-16 pt-8 border-t border-ghost">
        <p class="text-label-sm text-on-surface-muted">Written by {author}</p>
        <span class="magnetic inline-block mt-4">
          <a href="/blog" class="text-label-md text-on-surface-variant hover:text-on-surface cubic-ease" style="transition-duration: var(--duration-hover);">
            Back to Blog
          </a>
        </span>
      </footer>
    </div>
  </article>
</BaseLayout>
