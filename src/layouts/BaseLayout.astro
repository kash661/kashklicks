---
import SEO from '../components/seo/SEO.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import SplashOverlay from '../components/global/SplashOverlay.astro';
import MobileSplashOverlay from '../components/global/MobileSplashOverlay.astro';
import site from '../data/site.json';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonicalUrl?: string;
  noIndex?: boolean;
  robots?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  transparentHeader?: boolean;
  showSplash?: boolean;
  article?: {
    publishedTime: string;
    modifiedTime?: string;
    author: string;
    tags?: string[];
  };
}

const {
  title,
  description,
  ogImage,
  ogType,
  canonicalUrl,
  noIndex,
  robots,
  jsonLd,
  transparentHeader = false,
  showSplash = false,
  article,
} = Astro.props;

const organizationSchema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site.url}/#business`,
  name: site.name,
  url: site.url,
  image: `${site.url}/og-default.jpg`,
  description: site.description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.location.city,
    addressRegion: site.location.regionCode,
    addressCountry: site.location.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.location.lat,
    longitude: site.location.lng,
  },
  priceRange: site.priceRange,
  email: site.email,
  areaServed: site.areasServed.map((name) => ({ '@type': 'City', name })),
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: site.hours.days,
      opens: site.hours.opens,
      closes: site.hours.closes,
    },
  ],
  sameAs: [site.social.instagram, site.social.pinterest, site.social.youtube],
};

if (site.phone) {
  organizationSchema.telephone = site.phone;
}
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#faf9f6" />
    <meta name="author" content="AD Photography" />
    <meta name="facebook-domain-verification" content="mc68kqvbgdmd62i02mv8ni82r7955o" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect to external media -->
    <link rel="preconnect" href="https://kashklicks.b-cdn.net" crossorigin />

    <!-- Preload critical fonts — Noir et Blanc Regular (hero/display) +
         Italic (pull quotes) + Medium (section headings) + Inter Regular (body) -->
    <link rel="preload" href="/fonts/NoirEtBlanc-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/NoirEtBlanc-Italic.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonicalUrl={canonicalUrl}
      noIndex={noIndex}
      article={article}
    />

    {robots && <meta name="robots" content={robots} />}

    <!-- Organization Schema (site-wide) -->
    <JsonLd schema={organizationSchema} />

    <!-- Page-specific JSON-LD -->
    {jsonLd && <JsonLd schema={jsonLd} />}

    <!-- ═══ Analytics & ad pixels — gated to production host only ═══
         Dev servers (localhost, *.trycloudflare.com, *.pages.dev previews)
         would otherwise pollute Clarity, Meta Pixel, and Google Ads with
         test traffic. The guard below skips all three tags off-host. -->
    <script is:inline>
      (function () {
        var h = (location.hostname || '').toLowerCase();
        var isProd = h === 'kashklicks.ca' || h === 'www.kashklicks.ca';
        if (!isProd) return;

        // Meta Pixel (1349154153697983)
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
        n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t,s)}(window, document,'script',
        'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', '1349154153697983');
        fbq('track', 'PageView');
        document.addEventListener('astro:after-swap', function () {
          if (typeof window.fbq === 'function') { window.fbq('track', 'PageView'); }
        });

        // Google Ads / gtag (AW-18099849669)
        var g = document.createElement('script');
        g.async = true;
        g.src = 'https://www.googletagmanager.com/gtag/js?id=AW-18099849669';
        document.head.appendChild(g);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'AW-18099849669');
        document.addEventListener('astro:after-swap', function () {
          if (typeof window.gtag === 'function') {
            window.gtag('event', 'page_view', {
              page_path: window.location.pathname + window.location.search
            });
          }
        });

        // Microsoft Clarity (wfh1khoxjx)
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "wfh1khoxjx");
      })();
    </script>
    <noscript>
      <img height="1" width="1" style="display:none" alt=""
        src="https://www.facebook.com/tr?id=1349154153697983&ev=PageView&noscript=1" />
    </noscript>
    <!-- End analytics block -->
  </head>
  <body class="min-h-screen flex flex-col bg-background text-on-surface">
    <div class="scroll-progress" aria-hidden="true"></div>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[60] focus:bg-primary focus:text-on-dark focus:px-4 focus:py-2 focus:outline-none">
      Skip to content
    </a>

    {showSplash && (
      <>
        <SplashOverlay />
        <MobileSplashOverlay />
      </>
    )}

    <Header transparent={transparentHeader} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />


    <script>
      import { initScrollReveal } from '../scripts/scroll-reveal';
      import { initParallax } from '../scripts/parallax';
      import { initScrollProgress } from '../scripts/scroll-progress';
      import { initLazyVideo } from '../scripts/lazy-video';
      import { initSoundState } from '../scripts/sound-manager';
      import { initCharReveal } from '../scripts/char-reveal';
      import { initMagnetic } from '../scripts/magnetic';
      import { initCalendly } from '../scripts/calendly';

      const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 150));

      function initPage() {
        // Critical — run immediately for above-fold motion
        initScrollReveal();
        initParallax();
        initScrollProgress();
        initCharReveal();

        // Deferred — below-fold or interaction-triggered
        onIdle(() => {
          initLazyVideo();
          initMagnetic();
          initSoundState();
          initCalendly();
        });

        const lightboxElements = document.querySelectorAll('.glightbox');
        if (lightboxElements.length > 0) {
          import('glightbox').then(({ default: GLightbox }) => {
            GLightbox({ selector: '.glightbox', loop: true, touchNavigation: true, closeOnOutsideClick: true, skin: 'clean' });
          });
        }
      }

      initPage();
      document.addEventListener('astro:after-swap', initPage);
    </script>

  </body>
</html>
