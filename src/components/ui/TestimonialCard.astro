---
interface Props {
  name: string;
  event: string;
  quote: string;
  rating: number;
}

const { name, event, quote, rating } = Astro.props;
---

<div class="bg-bg-card border border-border rounded-lg p-8 hover:border-border-hover transition-colors">
  <!-- Stars -->
  <div class="flex gap-1 mb-4">
    {Array.from({ length: rating }).map(() => (
      <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <blockquote class="text-text-secondary leading-relaxed mb-6">
    "{quote}"
  </blockquote>

  <div>
    <p class="font-medium text-text-primary">{name}</p>
    <p class="text-sm text-text-muted">{event}</p>
  </div>
</div>
