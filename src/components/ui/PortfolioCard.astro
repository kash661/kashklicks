---
import { Image } from 'astro:assets';

interface Props {
  couple: string;
  location: string;
  category: string;
  coverImage: ImageMetadata;
  href: string;
}

const { couple, location, category, coverImage, href } = Astro.props;
---

<a href={href} class="group block" data-category={category}>
  <div class="relative overflow-hidden rounded-lg aspect-[2/3]">
    <Image
      src={coverImage}
      alt={`${couple} — ${location}`}
      widths={[400, 600, 800]}
      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
    <div class="absolute bottom-0 left-0 right-0 p-6 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-300">
      <h3 class="font-heading text-xl font-bold text-white">{couple}</h3>
      <p class="text-sm text-white/80 mt-1">{location}</p>
    </div>
  </div>
</a>
