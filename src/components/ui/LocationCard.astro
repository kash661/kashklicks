---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  area: string;
  vibe: string;
  bestFor: string[];
  walkingLevel: string;
  walkingNote: string;
  permits: string;
  parking: string;
  idealIf: string;
  image: ImageMetadata;
}

const { name, area, vibe, bestFor, walkingLevel, walkingNote, permits, parking, idealIf, image } = Astro.props;

const walkingColors: Record<string, string> = {
  'Low-Medium': 'text-green-600',
  'Medium': 'text-amber-600',
  'Hard': 'text-red-600',
};
---

<div class="bg-bg-card border border-border rounded-lg overflow-hidden hover:border-border-hover transition-colors">
  <div class="aspect-[3/2] overflow-hidden">
    <Image
      src={image}
      alt={`${name} — photography location in ${area}`}
      widths={[400, 800]}
      sizes="(max-width: 768px) 100vw, 50vw"
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>

  <div class="p-6">
    <h3 class="font-heading text-xl font-bold text-text-primary">{name}</h3>
    <p class="text-sm text-accent mt-1">{area}</p>
    <p class="text-sm text-text-secondary mt-2 italic">"{vibe}"</p>

    <div class="flex flex-wrap gap-2 mt-4">
      {bestFor.map((tag) => (
        <span class="text-xs px-2 py-1 bg-bg-elevated rounded text-text-secondary border border-border">
          {tag}
        </span>
      ))}
    </div>

    <details class="mt-4 group">
      <summary class="cursor-pointer text-sm text-accent hover:text-accent-hover transition-colors">
        View details
      </summary>
      <div class="mt-3 space-y-2 text-sm text-text-secondary">
        <p><span class="text-text-muted">Walking Level:</span> <span class={walkingColors[walkingLevel] || 'text-text-secondary'}>{walkingLevel}</span> — {walkingNote}</p>
        <p><span class="text-text-muted">Permits:</span> {permits}</p>
        <p><span class="text-text-muted">Parking:</span> {parking}</p>
        <p class="pt-2 text-text-primary italic">Ideal if: {idealIf}</p>
      </div>
    </details>
  </div>
</div>
