---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  area: string;
  vibe: string;
  bestFor: string[];
  walkingLevel: string;
  walkingNote: string;
  permits: string;
  parking: string;
  idealIf: string;
  image: ImageMetadata;
}

const { name, area, vibe, bestFor, walkingLevel, walkingNote, permits, parking, idealIf, image } = Astro.props;
---

<div class="bg-surface group">
  <div class="aspect-[3/2] overflow-hidden">
    <Image
      src={image}
      alt={`${name}, photography location in ${area}`}
      widths={[400, 800]}
      sizes="(max-width: 768px) 100vw, 50vw"
      class="w-full h-full object-cover cubic-ease group-hover:scale-[1.02]"
      style="transition-duration: var(--duration-slow);"
      loading="lazy"
    />
  </div>

  <div class="pt-5 pb-6">
    <h3 class="text-heading-md">{name}</h3>
    <p class="text-label-sm text-on-surface-muted mt-1">{area}</p>
    <p class="text-body-lg text-on-surface-variant mt-2 italic" style="font-family: var(--font-serif);">"{vibe}"</p>

    <div class="flex flex-wrap gap-2 mt-4">
      {bestFor.map((tag) => (
        <span class="text-label-sm px-3 py-1 bg-surface-dim text-on-surface-variant">
          {tag}
        </span>
      ))}
    </div>

    <details class="mt-5 group/details">
      <summary class="cursor-pointer text-label-md text-on-surface-variant hover:text-on-surface cubic-ease" style="transition-duration: var(--duration-hover);">
        View details
      </summary>
      <div class="mt-4 space-y-2 text-body-lg text-on-surface-variant">
        <p><span class="text-on-surface-muted">Walking Level:</span> {walkingLevel} / {walkingNote}</p>
        <p><span class="text-on-surface-muted">Permits:</span> {permits}</p>
        <p><span class="text-on-surface-muted">Parking:</span> {parking}</p>
        <p class="pt-2 italic" style="font-family: var(--font-serif);">Ideal if: {idealIf}</p>
      </div>
    </details>
  </div>
</div>
