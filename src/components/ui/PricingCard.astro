---
interface Props {
  name: string;
  price: number | null;
  salePrice?: number;
  description: string;
  highlights: string[];
  popular?: boolean;
  featured?: boolean;
  custom?: boolean;
  id: string;
}

const { name, price, salePrice, description, highlights, custom = false, id } = Astro.props;
---

<div id={id} class="bg-surface p-10 flex flex-col h-full relative card-lift" style="gap: var(--spacing-element); scroll-margin-top: 120px;">
  {salePrice && (
    <span class="absolute top-4 right-4 text-label-sm text-on-surface-variant font-serif italic">Limited offer</span>
  )}
  <!-- Price at top -->
  <div>
    <p class="text-label-sm text-on-surface-muted mb-2">Price</p>
    {custom ? (
      <span class="text-display-md">Custom</span>
    ) : salePrice ? (
      <div class="flex items-baseline gap-3">
        <span class="text-display-md">${salePrice.toLocaleString()}</span>
        <span class="text-body-md text-on-surface-muted line-through">${price?.toLocaleString()}</span>
      </div>
    ) : (
      <span class="text-display-md">${price?.toLocaleString()}</span>
    )}
  </div>

  <div class="flex-1">
    <h3 class="text-heading-md italic">{name}</h3>
    <p class="text-body-md text-on-surface-variant mt-4">{description}</p>
  </div>

  <!-- What's included -->
  {highlights.filter((item) => !item.includes('+$') && !item.includes('available')).length > 0 && (
    <div>
      <p class="text-label-sm text-on-surface-muted mb-3">What's Included</p>
      <ul class="space-y-2">
        {highlights.filter((item) => !item.includes('+$') && !item.includes('available')).map((item) => (
          <li class="text-body-md text-on-surface-variant pl-5 relative">
            <span class="absolute left-0 top-0 text-on-surface-muted" aria-hidden="true">/</span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Add-ons -->
  {highlights.filter((item) => item.includes('+$') || item.includes('available')).length > 0 && (
    <div class="mt-auto">
      <p class="text-label-sm text-on-surface-muted mb-3">Add-Ons</p>
      <ul class="space-y-2">
        {highlights.filter((item) => item.includes('+$') || item.includes('available')).map((item) => (
          <li class="text-body-md text-on-surface-variant pl-5 relative">
            <span class="absolute left-0 top-0 text-on-surface-muted" aria-hidden="true">+</span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  )}


</div>
