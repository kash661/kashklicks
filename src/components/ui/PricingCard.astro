---
interface FilterMeta {
  film?: boolean;
  sale?: boolean;
  custom?: boolean;
  price?: number;
}

interface Props {
  name: string;
  price: number | null;
  salePrice?: number;
  description: string;
  highlights: string[];
  popular?: boolean;
  featured?: boolean;
  custom?: boolean;
  id: string;
  ordinal?: number;
  service?: string;
  ctaLabel?: string;
  filterMeta?: FilterMeta;
}

const {
  name,
  price,
  salePrice,
  description,
  highlights,
  popular,
  featured,
  custom = false,
  id,
  ordinal,
  service,
  ctaLabel = 'Enquire',
  filterMeta,
} = Astro.props;

const romans = ['I', 'II', 'III', 'IV', 'V', 'VI'];
const plateLabel = ordinal != null ? `Package ${romans[ordinal] ?? ordinal + 1}` : 'Package';

// Lift this tier visually — user-flagged popular, on-sale, or explicitly featured.
const isFeatured = !!(featured ?? popular);

// Add-ons live in the shared PackageAddOns section. Cards stay focused on
// "what you get" at this tier.
const isAddOn = (item: string) => item.includes('+$') || item.includes('available');
const includedItems = highlights.filter((item) => !isAddOn(item));

const hasSale = !!salePrice;
const displayPrice = hasSale ? salePrice : price;
---

<article
  id={id}
  class:list={['pricing-card', filterMeta ? 'package-card' : '']}
  data-featured={isFeatured ? 'true' : undefined}
  data-film={filterMeta ? (filterMeta.film ? 'true' : 'false') : undefined}
  data-sale={filterMeta ? (filterMeta.sale ? 'true' : 'false') : undefined}
  data-custom={filterMeta ? (filterMeta.custom ? 'true' : 'false') : undefined}
  data-price={filterMeta?.price}
>
  {popular && !hasSale && (
    <span class="pricing-card__badge">Most Popular</span>
  )}
  {hasSale && (
    <span class="pricing-card__badge">Limited Offer</span>
  )}

  <header class="pricing-card__head">
    <p class="pricing-card__eyebrow">
      <span class="pricing-card__eyebrow-label">{plateLabel}</span>
    </p>
    <h3 class="pricing-card__name">{name}</h3>
    <p class="pricing-card__deck">{description}</p>
  </header>

  {custom ? (
    <div class="pricing-card__price-block">
      <span class="pricing-card__price-kicker">Investment</span>
      <span class="pricing-card__price"><em>Custom</em></span>
    </div>
  ) : (
    <div class="pricing-card__price-block">
      <span class="pricing-card__price-kicker">Starting at</span>
      <span class="pricing-card__price">
        <span>${displayPrice?.toLocaleString()}</span>
        {hasSale && price && (
          <span class="pricing-card__price-strike">${price.toLocaleString()}</span>
        )}
      </span>
    </div>
  )}

  {includedItems.length > 0 && (
    <div class="pricing-card__included">
      <p class="pricing-card__included-label">What's Included</p>
      <ul class="pricing-card__list">
        {includedItems.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  )}

  <button
    type="button"
    class="pricing-card__cta"
    data-open-modal="contact-modal"
    data-service={service}
    data-package={id}
    data-package-name={name}
  >
    {ctaLabel}
    <span class="pricing-card__cta-arrow" aria-hidden="true">&rarr;</span>
  </button>
</article>
