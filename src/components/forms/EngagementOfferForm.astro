---
// Two-stage inquiry form for /free-engagement-session-toronto/
// Stage 1: email + optional wedding month. Stage 2: name + city + story.
// Both stages POST to Google Apps Script independently.
// No redirect on submit — DOM swap in place, IG WebView safe.
---

<div id="eof-wrapper" class="eof-wrapper" data-eof-root>
  <!-- ═══ STAGE 1 ═══ -->
  <div class="eof-stage eof-stage--1" data-eof-stage="1">
    <h2 class="eof-heading">Tell me about your wedding.</h2>
    <p class="eof-subhead">Two quick fields now. Full details on the next step.</p>

    <form
      id="eof-form-1"
      class="eof-form"
      action="https://script.google.com/macros/s/AKfycbw5c2bxZOPov3y9XUgSWZdTmAhwZM9k2E5BBr9AJDiWGp2rDded_RYYrsVaq-HWm7VepQ/exec"
      method="POST"
      target="eof-sink-1"
      novalidate
    >
      <!-- Honeypot — align with ContactForm convention (Apps Script backend filters on _gotcha) -->
      <div class="absolute -left-[9999px] opacity-0 h-0 w-0 overflow-hidden" aria-hidden="true">
        <label for="eof-gotcha">Don't fill this out</label>
        <input type="text" id="eof-gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
      </div>

      <!-- Stage identity -->
      <input type="hidden" name="stage" value="1" />
      <input type="hidden" name="variant" value="free-engagement-session-toronto" />

      <!-- Attribution (filled by JS on submit) -->
      <input type="hidden" name="page_url" data-eof-page-url />
      <input type="hidden" name="referrer" data-eof-referrer />
      <input type="hidden" name="utm_source" data-eof-utm="source" />
      <input type="hidden" name="utm_medium" data-eof-utm="medium" />
      <input type="hidden" name="utm_campaign" data-eof-utm="campaign" />
      <input type="hidden" name="utm_content" data-eof-utm="content" />
      <input type="hidden" name="utm_term" data-eof-utm="term" />
      <input type="hidden" name="fbclid" data-eof-utm="fbclid" />
      <input type="hidden" name="gclid" data-eof-utm="gclid" />
      <input type="hidden" name="user_agent" data-eof-user-agent />
      <input type="hidden" name="submitted_at" data-eof-submitted-at />

      <div class="form-field">
        <label for="eof-email" class="form-field__label">
          Email <span class="form-field__required" aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="eof-email"
          name="email"
          inputmode="email"
          autocomplete="email"
          required
          aria-required="true"
          class="form-field__input"
        />
      </div>

      <div class="form-field">
        <label for="eof-wedding-month" class="form-field__label">
          Ceremony month and year (optional)
        </label>
        <input
          type="text"
          id="eof-wedding-month"
          name="wedding_month"
          autocomplete="off"
          placeholder="e.g. August 2027"
          class="form-field__input"
        />
      </div>

      <button type="submit" class="btn btn--primary eof-submit-1">
        Continue →
      </button>

      <p class="eof-fineprint">No spam. I reply within 24 hours, usually sooner.</p>

      <div class="eof-error" data-eof-error-1 role="alert" aria-live="polite" hidden>
        Something stuck. Email info@kashklicks.ca or DM @kashklicks and we'll sort it.
      </div>
    </form>

    <!-- Invisible submit target — iframe fallback for WebView resilience -->
    <iframe name="eof-sink-1" data-eof-sink-1 style="display:none" aria-hidden="true"></iframe>
  </div>

  <!-- ═══ STAGE 2 (hidden by default, unhidden by JS on stage 1 success) ═══ -->
  <div class="eof-stage eof-stage--2" data-eof-stage="2" hidden>
    <h2 class="eof-heading">Great. A few more details.</h2>

    <form
      id="eof-form-2"
      class="eof-form"
      action="https://script.google.com/macros/s/AKfycbw5c2bxZOPov3y9XUgSWZdTmAhwZM9k2E5BBr9AJDiWGp2rDded_RYYrsVaq-HWm7VepQ/exec"
      method="POST"
      target="eof-sink-2"
      novalidate
    >
      <input type="hidden" name="stage" value="2" />
      <input type="hidden" name="variant" value="free-engagement-session-toronto" />

      <!-- Carried over from stage 1 (populated by JS after stage 1 success) -->
      <input type="hidden" name="email" data-eof-s2-email />
      <input type="hidden" name="wedding_month" data-eof-s2-wedding-month />

      <!-- Attribution -->
      <input type="hidden" name="page_url" data-eof-page-url />
      <input type="hidden" name="referrer" data-eof-referrer />
      <input type="hidden" name="utm_source" data-eof-utm="source" />
      <input type="hidden" name="utm_medium" data-eof-utm="medium" />
      <input type="hidden" name="utm_campaign" data-eof-utm="campaign" />
      <input type="hidden" name="utm_content" data-eof-utm="content" />
      <input type="hidden" name="utm_term" data-eof-utm="term" />
      <input type="hidden" name="fbclid" data-eof-utm="fbclid" />
      <input type="hidden" name="gclid" data-eof-utm="gclid" />
      <input type="hidden" name="user_agent" data-eof-user-agent />
      <input type="hidden" name="submitted_at" data-eof-submitted-at />

      <div class="form-field">
        <label for="eof-name" class="form-field__label">
          Name <span class="form-field__required" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="eof-name"
          name="name"
          autocomplete="given-name"
          required
          aria-required="true"
          class="form-field__input"
        />
      </div>

      <div class="form-field">
        <label for="eof-city" class="form-field__label">
          Ceremony city or venue <span class="form-field__required" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="eof-city"
          name="city"
          autocomplete="off"
          placeholder="Toronto, Casa Loma, Glenerin Inn, etc."
          required
          aria-required="true"
          class="form-field__input"
        />
      </div>

      <div class="form-field">
        <label for="eof-story" class="form-field__label">
          Your story (optional)
        </label>
        <textarea
          id="eof-story"
          name="story"
          rows="3"
          autocomplete="off"
          placeholder="Tell me about your day. Where, who, what does it look like?"
          class="form-field__input"
        ></textarea>
      </div>

      <button type="submit" class="btn btn--primary eof-submit-2">
        Send →
      </button>

      <p class="eof-fineprint">Prefer a DM? <a href="https://instagram.com/kashklicks" target="_blank" rel="noopener">@kashklicks</a> on Instagram.</p>

      <div class="eof-error" data-eof-error-2 role="alert" aria-live="polite" hidden>
        Something stuck. Email info@kashklicks.ca or DM @kashklicks and we'll sort it.
      </div>
    </form>

    <iframe name="eof-sink-2" data-eof-sink-2 style="display:none" aria-hidden="true"></iframe>
  </div>

  <!-- ═══ SUCCESS STATE (hidden by default) ═══ -->
  <div class="eof-stage eof-stage--success" data-eof-stage="success" hidden>
    <!-- Success markup added in Task 9 -->
  </div>
</div>

<style>
  .eof-wrapper {
    max-width: 520px;
    margin-inline: auto;
  }
  .eof-heading {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm, 2rem);
    margin-bottom: 0.5rem;
  }
  .eof-subhead {
    color: var(--color-on-surface-variant);
    margin-bottom: 2rem;
  }
  .eof-form {
    display: grid;
    gap: 1.5rem;
  }
  .eof-submit-1 {
    width: 100%;
    margin-top: 0.5rem;
  }
  .eof-fineprint {
    color: var(--color-on-surface-variant);
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
  .eof-error {
    color: var(--color-error, #b00020);
    font-size: 0.9rem;
    margin-top: 0.75rem;
  }
</style>
