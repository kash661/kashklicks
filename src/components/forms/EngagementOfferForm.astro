---
// Two-stage inquiry form for /free-engagement-session-toronto/
// Stage 1: email + optional wedding month. Stage 2: name + city + story.
// Both stages POST to Google Apps Script independently.
// No redirect on submit — DOM swap in place, IG WebView safe.

const APPS_SCRIPT_URL =
  "https://script.google.com/macros/s/AKfycbw5c2bxZOPov3y9XUgSWZdTmAhwZM9k2E5BBr9AJDiWGp2rDded_RYYrsVaq-HWm7VepQ/exec";
---

<div id="eof-wrapper" class="eof-wrapper" data-eof-root>
  <!-- ═══ STAGE 1 ═══ -->
  <div class="eof-stage eof-stage--1" data-eof-stage="1">
    <h2 class="eof-heading">Tell me about your wedding.</h2>
    <p class="eof-subhead">Two quick fields now. Full details on the next step.</p>

    <form
      id="eof-form-1"
      class="eof-form"
      action={APPS_SCRIPT_URL}
      method="POST"
      target="eof-sink-1"
      novalidate
    >
      <!-- Honeypot — align with ContactForm convention (Apps Script backend filters on _gotcha) -->
      <div class="absolute -left-[9999px] opacity-0 h-0 w-0 overflow-hidden" aria-hidden="true">
        <label for="eof-gotcha">Don't fill this out</label>
        <input type="text" id="eof-gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
      </div>

      <!-- Stage identity -->
      <input type="hidden" name="stage" value="1" />
      <input type="hidden" name="variant" value="free-engagement-session-toronto" />

      <!-- Attribution (filled by JS on submit) -->
      <input type="hidden" name="page_url" data-eof-page-url />
      <input type="hidden" name="referrer" data-eof-referrer />
      <input type="hidden" name="utm_source" data-eof-utm="source" />
      <input type="hidden" name="utm_medium" data-eof-utm="medium" />
      <input type="hidden" name="utm_campaign" data-eof-utm="campaign" />
      <input type="hidden" name="utm_content" data-eof-utm="content" />
      <input type="hidden" name="utm_term" data-eof-utm="term" />
      <input type="hidden" name="fbclid" data-eof-utm="fbclid" />
      <input type="hidden" name="gclid" data-eof-utm="gclid" />
      <input type="hidden" name="user_agent" data-eof-user-agent />
      <input type="hidden" name="submitted_at" data-eof-submitted-at />

      <div class="form-field">
        <label for="eof-email" class="form-field__label">
          Email <span class="form-field__required" aria-hidden="true">*</span>
        </label>
        <input
          type="email"
          id="eof-email"
          name="email"
          inputmode="email"
          autocomplete="email"
          required
          aria-required="true"
          class="form-field__input"
        />
      </div>

      <div class="form-field">
        <label for="eof-wedding-month" class="form-field__label">
          Ceremony month and year (optional)
        </label>
        <input
          type="text"
          id="eof-wedding-month"
          name="wedding_month"
          autocomplete="off"
          placeholder="e.g. August 2027"
          class="form-field__input"
        />
      </div>

      <button type="submit" class="btn btn--primary eof-submit-1">
        Continue →
      </button>

      <p class="eof-fineprint">No spam. I reply within 24 hours, usually sooner.</p>

      <div class="eof-error" data-eof-error-1 role="alert" aria-live="polite" hidden>
        Something stuck. Email info@kashklicks.ca or DM @kashklicks and we'll sort it.
      </div>
    </form>

    <!-- Invisible submit target — iframe fallback for WebView resilience -->
    <iframe name="eof-sink-1" data-eof-sink-1 style="display:none" aria-hidden="true"></iframe>
  </div>

  <!-- ═══ STAGE 2 (hidden by default, unhidden by JS on stage 1 success) ═══ -->
  <div class="eof-stage eof-stage--2" data-eof-stage="2" hidden>
    <h2 class="eof-heading">Great. A few more details.</h2>

    <form
      id="eof-form-2"
      class="eof-form"
      action={APPS_SCRIPT_URL}
      method="POST"
      target="eof-sink-2"
      novalidate
    >
      <input type="hidden" name="stage" value="2" />
      <input type="hidden" name="variant" value="free-engagement-session-toronto" />

      <!-- Carried over from stage 1 (populated by JS after stage 1 success) -->
      <input type="hidden" name="email" data-eof-s2-email />
      <input type="hidden" name="wedding_month" data-eof-s2-wedding-month />

      <!-- Attribution -->
      <input type="hidden" name="page_url" data-eof-page-url />
      <input type="hidden" name="referrer" data-eof-referrer />
      <input type="hidden" name="utm_source" data-eof-utm="source" />
      <input type="hidden" name="utm_medium" data-eof-utm="medium" />
      <input type="hidden" name="utm_campaign" data-eof-utm="campaign" />
      <input type="hidden" name="utm_content" data-eof-utm="content" />
      <input type="hidden" name="utm_term" data-eof-utm="term" />
      <input type="hidden" name="fbclid" data-eof-utm="fbclid" />
      <input type="hidden" name="gclid" data-eof-utm="gclid" />
      <input type="hidden" name="user_agent" data-eof-user-agent />
      <input type="hidden" name="submitted_at" data-eof-submitted-at />

      <div class="form-field">
        <label for="eof-name" class="form-field__label">
          Name <span class="form-field__required" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="eof-name"
          name="name"
          autocomplete="given-name"
          required
          aria-required="true"
          class="form-field__input"
        />
      </div>

      <div class="form-field">
        <label for="eof-city" class="form-field__label">
          Ceremony city or venue <span class="form-field__required" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="eof-city"
          name="city"
          autocomplete="off"
          placeholder="Toronto, Casa Loma, Glenerin Inn, etc."
          required
          aria-required="true"
          class="form-field__input"
        />
      </div>

      <div class="form-field">
        <label for="eof-story" class="form-field__label">
          Your story (optional)
        </label>
        <textarea
          id="eof-story"
          name="story"
          rows="3"
          autocomplete="off"
          placeholder="Tell me about your day. Where, who, what does it look like?"
          class="form-field__input"
        ></textarea>
      </div>

      <button type="submit" class="btn btn--primary eof-submit-2">
        Send →
      </button>

      <p class="eof-fineprint">Prefer a DM? <a href="https://instagram.com/kashklicks" target="_blank" rel="noopener">@kashklicks</a> on Instagram.</p>

      <div class="eof-error" data-eof-error-2 role="alert" aria-live="polite" hidden>
        Something stuck. Email info@kashklicks.ca or DM @kashklicks and we'll sort it.
      </div>
    </form>

    <iframe name="eof-sink-2" data-eof-sink-2 style="display:none" aria-hidden="true"></iframe>
  </div>

  <!-- ═══ SUCCESS STATE (hidden by default) ═══ -->
  <div class="eof-stage eof-stage--success" data-eof-stage="success" hidden>
    <h2 class="eof-heading">Thanks, <span data-eof-success-name>friend</span>.</h2>
    <p class="eof-success-body">
      I'll email you within 24 hours to confirm the free engagement session
      and talk through dates.
    </p>
    <p class="eof-success-body">
      If I'm slow, nudge me on Instagram:
      <a href="https://instagram.com/kashklicks" target="_blank" rel="noopener">@kashklicks</a>.
    </p>
  </div>
</div>

<style>
  .eof-wrapper {
    max-width: 520px;
    margin-inline: auto;
  }
  .eof-heading {
    font-family: var(--font-serif);
    font-size: var(--text-display-sm, 2rem);
    margin-bottom: 0.5rem;
  }
  .eof-subhead {
    color: var(--color-on-surface-variant);
    margin-bottom: 2rem;
  }
  .eof-form {
    display: grid;
    gap: 1.5rem;
  }
  .eof-submit-1,
  .eof-submit-2 {
    width: 100%;
    margin-top: 0.5rem;
  }
  .eof-fineprint {
    color: var(--color-on-surface-variant);
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
  .eof-error {
    color: var(--color-error, #b00020);
    font-size: 0.9rem;
    margin-top: 0.75rem;
  }
  .eof-success-body {
    color: var(--color-on-surface-variant);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .eof-success-body a {
    text-decoration: underline;
    color: inherit;
  }
</style>

<script is:inline>
(function () {
  const root = document.querySelector('[data-eof-root]');
  if (!root) return;

  const stage1 = root.querySelector('[data-eof-stage="1"]');
  const stage2 = root.querySelector('[data-eof-stage="2"]');
  const success = root.querySelector('[data-eof-stage="success"]');

  const form1 = root.querySelector('#eof-form-1');
  const form2 = root.querySelector('#eof-form-2');
  const sink1 = root.querySelector('[data-eof-sink-1]');
  const sink2 = root.querySelector('[data-eof-sink-2]');
  const err1 = root.querySelector('[data-eof-error-1]');
  const err2 = root.querySelector('[data-eof-error-2]');

  // ─── UTM + click-ID capture (session-scoped) ─────────────────────────
  const UTM_KEYS = ['source', 'medium', 'campaign', 'content', 'term', 'fbclid', 'gclid'];
  const STORAGE_KEY = 'eof_attribution';

  function captureAttribution() {
    const params = new URLSearchParams(window.location.search);
    let stored = {};
    try { stored = JSON.parse(sessionStorage.getItem(STORAGE_KEY) || '{}'); } catch (e) {}
    const next = { ...stored };
    UTM_KEYS.forEach((k) => {
      const urlKey = (k === 'fbclid' || k === 'gclid') ? k : 'utm_' + k;
      const val = params.get(urlKey);
      if (val) next[k] = val;
    });
    sessionStorage.setItem(STORAGE_KEY, JSON.stringify(next));
    return next;
  }

  function fillHiddenFields(container, attribution) {
    container.querySelectorAll('[data-eof-utm]').forEach((el) => {
      const key = el.getAttribute('data-eof-utm');
      el.value = attribution[key] || '';
    });
    const pageUrl = container.querySelector('[data-eof-page-url]');
    if (pageUrl) pageUrl.value = window.location.href;
    const referrer = container.querySelector('[data-eof-referrer]');
    if (referrer) referrer.value = document.referrer || '';
    const ua = container.querySelector('[data-eof-user-agent]');
    if (ua) ua.value = navigator.userAgent;
    const ts = container.querySelector('[data-eof-submitted-at]');
    if (ts) ts.value = new Date().toISOString();
  }

  const attribution = captureAttribution();
  fillHiddenFields(stage1, attribution);
  fillHiddenFields(stage2, attribution);

  // ─── Stage 1 submit ──────────────────────────────────────────────────
  let stage1SubmittedAt = 0;

  form1.addEventListener('submit', function (e) {
    // Refresh attribution + timestamp immediately before the native submit.
    // Native form submit goes via the iframe target — no preventDefault.
    fillHiddenFields(stage1, attribution);
    err1.hidden = true;
    stage1SubmittedAt = Date.now();
  });

  sink1.addEventListener('load', function () {
    // iframe load AFTER a submit indicates Apps Script accepted the POST.
    // We consider any load event after a submit attempt as success (no-cors
    // means we can't read the response). Reject events that fire before any
    // submit happened.
    if (!stage1SubmittedAt || Date.now() - stage1SubmittedAt < 100) return;
    onStage1Success();
  });

  function onStage1Success() {
    // Carry stage-1 values into stage-2 hidden inputs
    const emailInput = stage1.querySelector('#eof-email');
    const monthInput = stage1.querySelector('#eof-wedding-month');
    const s2Email = stage2.querySelector('[data-eof-s2-email]');
    const s2Month = stage2.querySelector('[data-eof-s2-wedding-month]');
    if (s2Email) s2Email.value = emailInput ? emailInput.value : '';
    if (s2Month) s2Month.value = monthInput ? monthInput.value : '';

    // Meta Pixel Lead (fire BEFORE DOM swap — pixel calls are synchronous)
    if (typeof window.fbq === 'function') {
      window.fbq('track', 'Lead', {
        content_name: 'free-engagement-session-toronto',
        value: 0,
        currency: 'CAD',
      });
    }
    // Clarity tag
    if (typeof window.clarity === 'function') {
      window.clarity('set', 'stage_1_submitted', 'true');
    }

    // Swap DOM
    stage1.hidden = true;
    stage2.hidden = false;
    fillHiddenFields(stage2, attribution);

    // Focus first stage-2 field for a11y + continuity
    const nameField = stage2.querySelector('#eof-name');
    if (nameField) nameField.focus();

    // Start abandonment tracker
    setTimeout(function () {
      if (!stage2.hidden && success.hidden) {
        if (typeof window.clarity === 'function') {
          window.clarity('set', 'stage_2_abandoned', 'true');
        }
      }
    }, 30000);
  }

  // ─── Stage 2 submit ──────────────────────────────────────────────────
  let stage2SubmittedAt = 0;

  form2.addEventListener('submit', function (e) {
    fillHiddenFields(stage2, attribution);
    err2.hidden = true;
    stage2SubmittedAt = Date.now();
  });

  sink2.addEventListener('load', function () {
    if (!stage2SubmittedAt || Date.now() - stage2SubmittedAt < 100) return;
    onStage2Success();
  });

  function onStage2Success() {
    const nameInput = stage2.querySelector('#eof-name');
    const firstName = nameInput ? nameInput.value.trim().split(' ')[0] : '';
    const nameSlot = success.querySelector('[data-eof-success-name]');
    if (nameSlot && firstName) nameSlot.textContent = firstName;

    // Meta CompleteRegistration
    if (typeof window.fbq === 'function') {
      window.fbq('track', 'CompleteRegistration', {
        content_name: 'free-engagement-session-toronto',
        value: 350,
        currency: 'CAD',
      });
    }
    // Google Ads generate_lead (conversion ID wired in Task 18)
    if (typeof window.gtag === 'function' && window.EOF_GADS_CONVERSION_ID) {
      window.gtag('event', 'conversion', {
        send_to: window.EOF_GADS_CONVERSION_ID,
        value: 350,
        currency: 'CAD',
      });
    }
    // Clarity tag
    if (typeof window.clarity === 'function') {
      window.clarity('set', 'stage_2_submitted', 'true');
    }

    stage2.hidden = true;
    success.hidden = false;
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
})();
</script>
