---
import FloatingInput from '../ui/FloatingInput.astro';
import FloatingSelect from '../ui/FloatingSelect.astro';
import FloatingTextarea from '../ui/FloatingTextarea.astro';
import Button from '../ui/Button.astro';

interface Props {
  formspreeId?: string;
}

// TODO: Replace 'YOUR_FORMSPREE_ID' with your actual Formspree form ID (e.g. 'xrgvalqb')
// Sign up at https://formspree.io and create a form to get your ID
const { formspreeId = 'YOUR_FORMSPREE_ID' } = Astro.props;

const eventTypeOptions = [
  { value: 'pre-wedding', label: 'Pre-Wedding / Engagement' },
  { value: 'wedding', label: 'Wedding' },
  { value: 'civil-ceremony', label: 'Civil Ceremony' },
  { value: 'birthday', label: 'Birthday / Celebration' },
  { value: 'portrait', label: 'Portrait' },
  { value: 'other', label: 'Other' },
];
---

<div id="contact-form-wrapper">
  <form
    id="contact-form"
    action={`https://formspree.io/f/${formspreeId}`}
    method="POST"
    class="space-y-8"
    novalidate
  >
    <!-- Honeypot field -->
    <div class="absolute -left-[9999px] opacity-0 h-0 w-0 overflow-hidden" aria-hidden="true">
      <label for="_gotcha">Don't fill this out</label>
      <input type="text" id="_gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      <FloatingInput id="name" name="name" label="Name" required />
      <FloatingInput id="email" name="email" type="email" label="Email" required />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      <FloatingSelect
        id="event_type"
        name="event_type"
        label="Event Type"
        options={eventTypeOptions}
      />
      <FloatingInput id="date" name="event_date" type="date" label="Event Date" />
    </div>

    <FloatingInput id="location" name="location" label="Location" />

    <FloatingTextarea id="message" name="message" label="Tell us about your vision" required rows={5} />

    <div class="pt-2">
      <Button variant="primary" class="w-full sm:w-auto">Submit Inquiry</Button>
    </div>

    <p class="text-label-sm text-on-surface-muted">We respond within 24 hours.</p>
  </form>

  <!-- Success state -->
  <div id="contact-success" class="hidden bg-surface-dim p-10" role="status" aria-live="polite">
    <h3 class="text-heading-lg">Thank you.</h3>
    <p class="text-body-lg text-on-surface-variant mt-4" style="max-width: 50ch;">
      Your inquiry is on its way. We'll get back to you within 24 hours to start planning something together.
    </p>
    <p class="text-label-sm text-on-surface-muted mt-6">
      In the meantime, feel free to browse our <a href="/portfolio" class="text-on-surface-variant hover:text-on-surface cubic-ease underline" style="transition-duration: var(--duration-hover);">portfolio</a> for inspiration.
    </p>
  </div>

  <!-- Error state -->
  <div id="contact-error" class="hidden bg-surface-dim p-6" role="alert" aria-live="assertive">
    <div class="flex items-start gap-4">
      <svg class="h-5 w-5 mt-0.5 shrink-0 text-on-surface" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <p class="text-label-md text-on-surface">Something went wrong</p>
        <p class="mt-1 text-body-lg text-on-surface-variant">Your message couldn't be sent. Please try again, or reach out directly at <a href="mailto:hello@kashklicks.ca" class="underline hover:text-on-surface cubic-ease" style="transition-duration: var(--duration-hover);">hello@kashklicks.ca</a>.</p>
        <button
          id="contact-retry-btn"
          type="button"
          class="mt-3 text-label-md text-on-surface-variant hover:text-on-surface cubic-ease underline"
          style="transition-duration: var(--duration-hover);"
        >
          Try again
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const successEl = document.getElementById('contact-success');
    const errorEl = document.getElementById('contact-error');
    const retryBtn = document.getElementById('contact-retry-btn');

    if (!form || !submitBtn || !successEl || !errorEl) return;

    const originalBtnText = submitBtn.textContent;

    function clearFieldError(field: HTMLElement) {
      const errMsg = field.closest('.relative')?.querySelector('.form-error-msg') as HTMLElement | null;
      if (errMsg) {
        errMsg.textContent = '';
        errMsg.classList.add('hidden');
      }
      field.removeAttribute('aria-invalid');
    }

    function showFieldError(field: HTMLInputElement | HTMLTextAreaElement, message: string) {
      const errMsg = field.closest('.relative')?.querySelector('.form-error-msg') as HTMLElement | null;
      if (errMsg) {
        errMsg.textContent = message;
        errMsg.classList.remove('hidden');
      }
      field.setAttribute('aria-invalid', 'true');
    }

    function validateForm(): boolean {
      let valid = true;
      let firstInvalid: HTMLElement | null = null;
      const requiredFields = form!.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]');

      requiredFields.forEach((field) => {
        clearFieldError(field);

        if (!field.value.trim()) {
          showFieldError(field, 'This field is required.');
          valid = false;
          if (!firstInvalid) firstInvalid = field;
        } else if (field.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value.trim())) {
          showFieldError(field, 'Please enter a valid email address.');
          valid = false;
          if (!firstInvalid) firstInvalid = field;
        }
      });

      if (firstInvalid) (firstInvalid as HTMLElement).focus();
      return valid;
    }

    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((field) => {
      field.addEventListener('input', () => clearFieldError(field));
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!validateForm()) return;

      const honeypot = form.querySelector<HTMLInputElement>('[name="_gotcha"]');
      if (honeypot && honeypot.value) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      errorEl.classList.add('hidden');

      try {
        const formData = new FormData(form);
        formData.delete('_gotcha');

        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json',
          },
        });

        if (response.ok) {
          form.classList.add('hidden');
          successEl.classList.remove('hidden');
        } else {
          throw new Error(`Form submission failed: ${response.status}`);
        }
      } catch {
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnText;
      }
    });

    retryBtn?.addEventListener('click', () => {
      errorEl.classList.add('hidden');
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
