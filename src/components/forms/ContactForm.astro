---
const eventTypeOptions = [
  { value: 'wedding', label: 'Wedding' },
  { value: 'pre-wedding', label: 'Pre-Wedding / Engagement' },
  { value: 'civil-ceremony', label: 'Civil Ceremony' },
  { value: 'celebration', label: 'Celebration' },
  { value: 'unsure', label: 'Not sure yet' },
];

const referralOptions = [
  { value: 'instagram', label: 'Instagram' },
  { value: 'google', label: 'Google search' },
  { value: 'referral', label: 'A friend or family member' },
  { value: 'planner', label: 'Wedding planner or vendor' },
  { value: 'blog', label: 'Blog, article, or feature' },
  { value: 'other', label: 'Somewhere else' },
];
---

<div id="contact-form-wrapper">
  <form
    id="contact-form"
    action="https://script.google.com/macros/s/AKfycbw5c2bxZOPov3y9XUgSWZdTmAhwZM9k2E5BBr9AJDiWGp2rDded_RYYrsVaq-HWm7VepQ/exec"
    method="POST"
    novalidate
  >
    <!-- Honeypot -->
    <div class="absolute -left-[9999px] opacity-0 h-0 w-0 overflow-hidden" aria-hidden="true">
      <label for="_gotcha">Don't fill this out</label>
      <input type="text" id="_gotcha" name="_gotcha" tabindex="-1" autocomplete="off" />
    </div>

    <!-- Hidden context — auto-filled when Enquire is clicked from a
         specific package so the backend sees which collection the
         couple was looking at. -->
    <input type="hidden" id="package_id" name="package_id" value="" />
    <input type="hidden" id="package_name" name="package_name" value="" />
    <input type="hidden" id="source_page" name="source_page" value="" />

    <!-- ═══ I · ABOUT YOU ═══ -->
    <fieldset class="form-section">
      <legend class="form-section__legend">
        <span class="form-section__number">I</span>
        <span class="form-section__title">About You</span>
      </legend>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-8">
        <div class="form-field">
          <label for="name" class="form-field__label">
            Your Name <span class="form-field__required" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            autocomplete="given-name"
            required
            aria-required="true"
            aria-describedby="name-error"
            class="form-field__input"
          />
          <p id="name-error" class="form-error-msg form-field__error hidden" role="alert"></p>
        </div>

        <div class="form-field">
          <label for="partner_name" class="form-field__label">
            Partner's Name <span class="form-field__optional">(if applicable)</span>
          </label>
          <input
            type="text"
            id="partner_name"
            name="partner_name"
            class="form-field__input"
          />
          <p class="form-error-msg form-field__error hidden" role="alert"></p>
        </div>

        <div class="form-field">
          <label for="email" class="form-field__label">
            Email <span class="form-field__required" aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            autocomplete="email"
            required
            aria-required="true"
            aria-describedby="email-error"
            class="form-field__input"
          />
          <p id="email-error" class="form-error-msg form-field__error hidden" role="alert"></p>
        </div>

        <div class="form-field">
          <label for="phone" class="form-field__label">
            Phone <span class="form-field__required" aria-hidden="true">*</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            autocomplete="tel"
            required
            aria-required="true"
            aria-describedby="phone-error"
            placeholder="(416) 555 0199"
            class="form-field__input"
          />
          <p id="phone-error" class="form-error-msg form-field__error hidden" role="alert"></p>
        </div>
      </div>
    </fieldset>

    <!-- ═══ II · YOUR DAY ═══ -->
    <fieldset class="form-section">
      <legend class="form-section__legend">
        <span class="form-section__number">II</span>
        <span class="form-section__title">Your Day</span>
      </legend>

      <div class="space-y-8">
        <div class="form-field">
          <label for="event_type" class="form-field__label">
            What I'm Capturing <span class="form-field__required" aria-hidden="true">*</span>
          </label>
          <select
            id="event_type"
            name="event_type"
            required
            aria-required="true"
            aria-describedby="event_type-error"
            class="form-field__select"
          >
            <option value="" disabled selected>Select an occasion</option>
            {eventTypeOptions.map((opt) => (
              <option value={opt.value}>{opt.label}</option>
            ))}
          </select>
          <p id="event_type-error" class="form-error-msg form-field__error hidden" role="alert"></p>
        </div>

        <div class="form-field">
          <label for="event_date" class="form-field__label">
            Event Date <span class="form-field__optional">(tentative is fine)</span>
          </label>
          <input
            type="date"
            id="event_date"
            name="event_date"
            class="form-field__input"
          />
          <p class="form-field__help">
            Haven't locked the date? Leave blank, I'll talk through options with you.
          </p>
        </div>

        <div class="form-field">
          <label for="location" class="form-field__label">
            Venue or Location <span class="form-field__optional">(optional)</span>
          </label>
          <input
            type="text"
            id="location"
            name="location"
            placeholder="Venue name, a city, or 'Not sure yet'"
            class="form-field__input"
          />
          <p class="form-field__help">
            Still deciding? No problem. Light first, location second, I help you pick.
          </p>
        </div>

        <div class="form-field">
          <label for="guest_count" class="form-field__label">
            Approximate Guest Count <span class="form-field__optional">(optional)</span>
          </label>
          <input
            type="text"
            id="guest_count"
            name="guest_count"
            placeholder="e.g. 50, 100+, or just the two of us"
            class="form-field__input"
          />
        </div>
      </div>
    </fieldset>

    <!-- ═══ III · THE VISION ═══ -->
    <fieldset class="form-section">
      <legend class="form-section__legend">
        <span class="form-section__number">III</span>
        <span class="form-section__title">The Vision</span>
      </legend>

      <div class="space-y-8">
        <div class="form-field">
          <label for="message" class="form-field__label">
            Tell Me About Your Day <span class="form-field__required" aria-hidden="true">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            aria-required="true"
            aria-describedby="message-error"
            rows="5"
            placeholder="Your story, the mood you're going for, Pinterest or Instagram links. Anything that helps me understand the day."
            class="form-field__textarea"
          ></textarea>
          <p id="message-error" class="form-error-msg form-field__error hidden" role="alert"></p>
        </div>

        <div class="form-field">
          <label for="referral" class="form-field__label">
            How Did You Find Me? <span class="form-field__optional">(optional)</span>
          </label>
          <select
            id="referral"
            name="referral"
            class="form-field__select"
          >
            <option value="" disabled selected>Select one</option>
            {referralOptions.map((opt) => (
              <option value={opt.value}>{opt.label}</option>
            ))}
          </select>
        </div>
      </div>
    </fieldset>

    <!-- Submit -->
    <div class="form-submit">
      <div class="form-submit__break"></div>
      <button type="submit" class="form-submit__button">
        Send Inquiry
        <span class="form-submit__arrow" aria-hidden="true">&rarr;</span>
      </button>
      <p class="form-submit__note">
        <span class="form-field__required not-italic" aria-hidden="true">*</span> required · everything else is optional, share what you can
      </p>
    </div>
  </form>

  <!-- Success state -->
  <div id="contact-success" class="hidden bg-surface-dim p-10" role="status" aria-live="polite">
    <p class="text-label-md text-on-surface-muted eyebrow-rule revealed mb-4">Thank You</p>
    <h3 class="text-heading-lg font-serif">Your note is on its way.</h3>
    <p class="text-body-lg text-on-surface-variant mt-4" style="max-width: 50ch;">
      I'll read it carefully and reply within 24 hours to start planning something with you.
    </p>
    <p class="text-label-sm text-on-surface-muted mt-6">
      In the meantime, browse my <a href="/portfolio" class="text-on-surface hover:text-on-surface-variant cubic-ease underline" style="transition-duration: var(--duration-hover);">portfolio</a> for inspiration.
    </p>
  </div>

  <!-- Error state -->
  <div id="contact-error" class="hidden bg-surface-dim p-6" role="alert" aria-live="assertive">
    <div class="flex items-start gap-4">
      <svg class="h-5 w-5 mt-0.5 shrink-0 text-on-surface" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <p class="text-label-md text-on-surface">Something went wrong</p>
        <p class="mt-1 text-body-lg text-on-surface-variant">Your message couldn't be sent. Please try again, or reach out directly at <a href="mailto:info@kashklicks.ca" class="underline hover:text-on-surface cubic-ease" style="transition-duration: var(--duration-hover);">info@kashklicks.ca</a> or DM me on Instagram for a faster reply.</p>
        <button
          id="contact-retry-btn"
          type="button"
          class="mt-3 text-label-md text-on-surface-variant hover:text-on-surface cubic-ease underline"
          style="transition-duration: var(--duration-hover);"
        >
          Try again
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const successEl = document.getElementById('contact-success');
    const errorEl = document.getElementById('contact-error');
    const retryBtn = document.getElementById('contact-retry-btn');

    if (!form || !submitBtn || !successEl || !errorEl) return;

    const originalBtnText = submitBtn.textContent;

    function clearFieldError(field: HTMLElement) {
      const errMsg = field.closest('.form-field')?.querySelector('.form-error-msg') as HTMLElement | null;
      if (errMsg) {
        errMsg.textContent = '';
        errMsg.classList.add('hidden');
      }
      field.removeAttribute('aria-invalid');
    }

    function showFieldError(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement, message: string) {
      const errMsg = field.closest('.form-field')?.querySelector('.form-error-msg') as HTMLElement | null;
      if (errMsg) {
        errMsg.textContent = message;
        errMsg.classList.remove('hidden');
      }
      field.setAttribute('aria-invalid', 'true');
    }

    function validateForm(): boolean {
      let valid = true;
      let firstInvalid: HTMLElement | null = null;
      const requiredFields = form!.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('[required]');

      requiredFields.forEach((field) => {
        clearFieldError(field);

        if (!field.value.trim()) {
          showFieldError(field, 'This field is required.');
          valid = false;
          if (!firstInvalid) firstInvalid = field;
        } else if (field.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value.trim())) {
          showFieldError(field, 'Please enter a valid email address.');
          valid = false;
          if (!firstInvalid) firstInvalid = field;
        }
      });

      if (firstInvalid) (firstInvalid as HTMLElement).focus();
      return valid;
    }

    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>('input, textarea, select').forEach((field) => {
      field.addEventListener('input', () => clearFieldError(field));
      field.addEventListener('change', () => clearFieldError(field));
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!validateForm()) return;

      const honeypot = form.querySelector<HTMLInputElement>('[name="_gotcha"]');
      if (honeypot && honeypot.value) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      errorEl.classList.add('hidden');

      try {
        const formData = new FormData(form);
        formData.delete('_gotcha');

        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json',
          },
        });

        if (response.ok) {
          form.classList.add('hidden');
          successEl.classList.remove('hidden');
          successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error(`Form submission failed: ${response.status}`);
        }
      } catch {
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = originalBtnText;
      }
    });

    retryBtn?.addEventListener('click', () => {
      errorEl.classList.add('hidden');
      form.classList.remove('hidden');
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
