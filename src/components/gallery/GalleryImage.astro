---
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata;
  alt: string;
  gallery?: string;
}

const { src, alt, gallery = 'gallery' } = Astro.props;
---

<a
  href={src.src}
  class="glightbox block overflow-hidden group cursor-pointer"
  data-gallery={gallery}
  aria-label={`View full size: ${alt}`}
  role="button"
>
  <Image
    src={src}
    alt={alt}
    widths={[400, 600, 800, 1200]}
    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
    class="w-full h-auto object-cover cubic-ease"
    style="transition-duration: var(--duration-slow);"
    loading="lazy"
  />
</a>
