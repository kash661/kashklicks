---
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;

// Extract video ID + optional start time from youtube.com/watch?v= or youtu.be/ formats.
// Supports ?t=2s, ?t=2, &start=2 — the embed honours the start offset.
let videoId = '';
let startSeconds = 0;

function parseStart(value: string | null): number {
  if (!value) return 0;
  // Accept "90", "90s", "1m30s", "1h2m3s"
  if (/^\d+$/.test(value)) return parseInt(value, 10);
  let total = 0;
  const match = value.match(/(?:(\d+)h)?(?:(\d+)m)?(?:(\d+)s)?/);
  if (match) {
    total += (parseInt(match[1] ?? '0', 10) || 0) * 3600;
    total += (parseInt(match[2] ?? '0', 10) || 0) * 60;
    total += (parseInt(match[3] ?? '0', 10) || 0);
  }
  return total;
}

if (url.includes('youtu.be/')) {
  videoId = url.split('youtu.be/')[1]?.split(/[?&#]/)[0] ?? '';
  const query = url.split('?')[1] ?? '';
  startSeconds = parseStart(new URLSearchParams(query).get('t'));
} else {
  try {
    const parsed = new URL(url);
    videoId = parsed.searchParams.get('v') ?? '';
    startSeconds =
      parseStart(parsed.searchParams.get('t')) ||
      parseStart(parsed.searchParams.get('start'));
  } catch {
    videoId = '';
  }
}

const embedParams = new URLSearchParams({ rel: '0' });
if (startSeconds > 0) embedParams.set('start', String(startSeconds));
const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}?${embedParams.toString()}`;
---

{videoId && (
  <div class="aspect-video overflow-hidden bg-surface-container">
    <iframe
      src={embedUrl}
      title={title}
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      class="w-full h-full border-0"
    ></iframe>
  </div>
)}
