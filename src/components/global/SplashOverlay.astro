---
// src/components/global/SplashOverlay.astro
// Full-viewport gateway page. Shows once per session.
// Hidden by default via CSS. JS reveals it only on first visit.
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/hero/hero-main.jpg';
---

<div
  id="splash-overlay"
  class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-surface-dark"
  style="display: none;"
  role="dialog"
  aria-label="Welcome to AD Photography"
  aria-modal="true"
>
  <!-- Background image with Ken Burns -->
  <div class="absolute inset-0 overflow-hidden">
    <Image
      src={heroImage}
      alt=""
      class="w-full h-full object-cover opacity-40"
      style="animation: kenburns 8s var(--ease-gallery) forwards;"
      widths={[768, 1280, 1600]}
      sizes="100vw"
      quality={72}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <!-- Content -->
  <div class="relative text-center px-6">
    <p id="splash-mark" class="logo-mark text-on-dark opacity-0" style="font-size: clamp(3rem, 6vw, 5.5rem); line-height: 1.05;" aria-hidden="true">AD</p>
    <p id="splash-tag" class="text-label-md text-on-dark-variant mt-4 opacity-0">Moments fade. Memories don't.</p>
    <div id="splash-cta" class="mt-12 opacity-0" style="transition: opacity var(--duration-splash) var(--ease-gallery);">
      <button
        id="splash-enter"
        class="inline-flex items-center justify-center whitespace-nowrap px-9 py-3.5 border border-on-dark/70 text-on-dark text-label-md hover:bg-on-dark hover:text-on-surface cubic-ease"
        style="transition-duration: var(--duration-hover);"
      >
        Step Inside
      </button>
    </div>
  </div>
</div>

<style>
  @keyframes kenburns {
    from { transform: scale(1); }
    to { transform: scale(1.08); }
  }
</style>

<script>
  import gsap from 'gsap';
  import { playAmbientLoop, stopAmbient } from '../../scripts/sound-manager';

  function initSplash() {
    const overlay = document.getElementById('splash-overlay');
    const enterBtn = document.getElementById('splash-enter');
    if (!overlay) return;

    // Only show splash if NOT seen this session
    if (sessionStorage.getItem('kk-splash-seen') === 'true') {
      overlay.remove();
      document.dispatchEvent(new CustomEvent('splash:done'));
      return;
    }

    // First visit: show the splash
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    // Start ambient sound if user has opted in
    playAmbientLoop();

    // Reveal CTA after Ken Burns settles in
    const cta = document.getElementById('splash-cta');
    setTimeout(() => {
      if (cta) cta.style.opacity = '1';
    }, 1000);

    // Enter site — tap reveals mark, then types out the tagline
    const mark = document.getElementById('splash-mark');
    const tag = document.getElementById('splash-tag');

    // Split tagline into character spans so we can stagger like a typewriter
    if (tag) {
      const text = tag.textContent || '';
      tag.innerHTML = text
        .split('')
        .map((c) =>
          c === ' '
            ? '<span class="splash-char">&nbsp;</span>'
            : `<span class="splash-char">${c}</span>`
        )
        .join('');
      gsap.set(tag, { opacity: 1 });
      gsap.set(tag.querySelectorAll('.splash-char'), { opacity: 0 });
    }

    let revealed = false;

    enterBtn?.addEventListener('click', () => {
      if (revealed) return;
      revealed = true;
      if (enterBtn instanceof HTMLButtonElement) enterBtn.disabled = true;

      const chars = tag ? tag.querySelectorAll('.splash-char') : [];

      gsap.timeline({ defaults: { overwrite: 'auto' } })
        .to(cta, { opacity: 0, y: -8, duration: 0.5, ease: 'power2.in' })
        .fromTo(
          mark,
          { y: 40, opacity: 0 },
          { y: 0, opacity: 1, duration: 0.9, ease: 'power3.out' },
          '-=0.2'
        )
        .to(
          chars,
          { opacity: 1, duration: 0.25, stagger: 0.04, ease: 'none' },
          '-=0.3'
        )
        .call(
          () => {
            stopAmbient();
            sessionStorage.setItem('kk-splash-seen', 'true');
          },
          [],
          '+=1.2'
        )
        .to(overlay, {
          opacity: 0,
          scale: 1.02,
          duration: 1.0,
          ease: 'power2.inOut',
          onComplete: () => {
            document.body.style.overflow = '';
            overlay.remove();
            document.dispatchEvent(new CustomEvent('splash:done'));
          },
        });
    });

    enterBtn?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') enterBtn.click();
    });
  }

  initSplash();
</script>
