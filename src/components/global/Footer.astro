---
import site from '../../data/site.json';
---

<footer class="bg-bg-elevated border-t border-border mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="font-heading text-2xl font-bold text-text-primary">KashKlicks</a>
        <p class="mt-3 text-text-secondary text-sm leading-relaxed">
          {site.tagline}<br />
          Toronto wedding photographer & videographer specializing in cinematic, honest coverage.
        </p>
        <!-- Social Icons -->
        <div class="flex gap-4 mt-6">
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={site.social.pinterest} target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="text-text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
          </a>
          <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-text-muted hover:text-accent transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading text-lg font-medium text-text-primary mb-4">Explore</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/portfolio" class="text-text-secondary hover:text-accent transition-colors">Portfolio</a></li>
          <li><a href="/services" class="text-text-secondary hover:text-accent transition-colors">Services</a></li>
          <li><a href="/pricing" class="text-text-secondary hover:text-accent transition-colors">Pricing</a></li>
          <li><a href="/blog" class="text-text-secondary hover:text-accent transition-colors">Blog</a></li>
          <li><a href="/location-guide" class="text-text-secondary hover:text-accent transition-colors">Location Guide</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-lg font-medium text-text-primary mb-4">Get in Touch</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/contact" class="text-text-secondary hover:text-accent transition-colors">Contact Us</a></li>
          <li class="text-text-secondary">Toronto & GTA, Ontario, Canada</li>
          <li class="text-text-secondary">Available Canada-wide</li>
        </ul>
        <a
          href="/contact"
          class="inline-block mt-6 px-5 py-2.5 border border-accent text-accent text-sm font-medium rounded hover:bg-accent hover:text-bg transition-colors"
        >
          Free Consultation
        </a>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-text-muted text-xs">
        &copy; {new Date().getFullYear()} KashKlicks Studios. Toronto Wedding Photographer & Videographer.
      </p>
      <p class="text-text-muted text-xs">
        Serving Toronto, Mississauga, Brampton, Markham, Vaughan & the GTA
      </p>
    </div>
  </div>
</footer>
