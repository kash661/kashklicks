---
import site from '../../data/site.json';
---

<footer class="bg-surface-dark" style="padding-top: var(--spacing-section); padding-bottom: var(--spacing-block);">
  <div class="container-editorial">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">
      <!-- Brand -->
      <div class="md:col-span-6">
        <a href="/" class="font-serif text-2xl text-on-dark">KashKlicks</a>
        <p class="text-body-md text-on-dark-variant mt-4 max-w-sm">
          {site.tagline}
        </p>
      </div>

      <!-- Connect -->
      <div class="md:col-span-3">
        <span class="text-label-sm text-on-dark-variant block mb-4">Connect</span>
        <ul class="space-y-3">
          <li>
            <a
              href={site.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="text-body-md text-on-dark-variant hover:text-on-dark cubic-ease"
              style="transition-duration: var(--duration-hover);"
            >
              Instagram
            </a>
          </li>
          <li>
            <a
              href={site.social.pinterest}
              target="_blank"
              rel="noopener noreferrer"
              class="text-body-md text-on-dark-variant hover:text-on-dark cubic-ease"
              style="transition-duration: var(--duration-hover);"
            >
              Pinterest
            </a>
          </li>
        </ul>
      </div>

      <!-- Information -->
      <div class="md:col-span-3">
        <span class="text-label-sm text-on-dark-variant block mb-4">Information</span>
        <ul class="space-y-3">
          <li>
            <a
              href="/services"
              class="text-body-md text-on-dark-variant hover:text-on-dark cubic-ease"
              style="transition-duration: var(--duration-hover);"
            >
              The Experience
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="text-body-md text-on-dark-variant hover:text-on-dark cubic-ease"
              style="transition-duration: var(--duration-hover);"
            >
              Inquiry
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-16">
      <p class="text-label-sm text-on-dark-variant">
        &copy; {new Date().getFullYear()} KashKlicks Studios
      </p>
    </div>
  </div>
</footer>
