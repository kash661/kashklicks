---
import ContactForm from '../forms/ContactForm.astro';
---

<dialog
  id="contact-modal"
  class="contact-modal"
  aria-labelledby="contact-modal-title"
>
  <div class="contact-modal-inner">
    <div class="contact-modal-header">
      <div>
        <p class="text-label-md text-on-surface-muted eyebrow-rule revealed">Inquiry</p>
        <h2 id="contact-modal-title" class="text-heading-lg mt-4" style="max-width: 18ch;">
          Tell me about your <em class="font-serif italic">day.</em>
        </h2>
      </div>
      <button
        type="button"
        data-close-modal
        class="contact-modal-close"
        aria-label="Close inquiry form"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="contact-modal-body">
      <ContactForm />
    </div>
  </div>
</dialog>

<script>
  function initContactModal() {
    const modal = document.getElementById('contact-modal') as HTMLDialogElement | null;
    if (!modal || (modal as any).__bound) return;
    (modal as any).__bound = true;

    const openers = document.querySelectorAll<HTMLButtonElement>('[data-open-modal="contact-modal"]');
    const closers = modal.querySelectorAll<HTMLButtonElement>('[data-close-modal]');
    let lastFocused: HTMLElement | null = null;

    function setField(id: string, value: string) {
      const field = modal!.querySelector<HTMLInputElement | HTMLSelectElement>(`#${id}`);
      if (field) field.value = value;
    }

    function applyPrefill(trigger?: HTMLElement | null) {
      // Always reset hidden context fields on each open so stale
      // values from a previous click don't leak into a fresh inquiry.
      setField('package_id', '');
      setField('package_name', '');
      setField('source_page', window.location.pathname);

      if (!trigger) return;
      const { service, package: packageId, packageName } = trigger.dataset;
      if (service) setField('event_type', service);
      if (packageId) setField('package_id', packageId);
      if (packageName) setField('package_name', packageName);
    }

    function openModal(trigger?: HTMLElement) {
      lastFocused = trigger ?? (document.activeElement as HTMLElement | null);
      applyPrefill(trigger);
      if (typeof modal!.showModal === 'function') {
        modal!.showModal();
      } else {
        modal!.setAttribute('open', '');
      }
      document.body.classList.add('modal-open');
      requestAnimationFrame(() => {
        const firstField = modal!.querySelector<HTMLElement>('input, textarea, select, button:not([data-close-modal])');
        firstField?.focus();
      });
    }

    function closeModal() {
      if (typeof modal!.close === 'function') {
        modal!.close();
      } else {
        modal!.removeAttribute('open');
      }
      document.body.classList.remove('modal-open');
      lastFocused?.focus();
    }

    openers.forEach((btn) => {
      btn.addEventListener('click', () => openModal(btn));
    });

    closers.forEach((btn) => {
      btn.addEventListener('click', closeModal);
    });

    // Click on backdrop closes modal
    modal.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === modal) closeModal();
    });

    modal.addEventListener('close', () => {
      document.body.classList.remove('modal-open');
    });

    // Auto-open when deep-linked from a service package CTA
    // (`/contact#inquiry` or `?open=1&service=wedding`). Honors prefill
    // via `?service=` search param when auto-opening.
    const params = new URLSearchParams(window.location.search);
    const shouldAutoOpen = window.location.hash === '#inquiry' || params.get('open') === '1';
    if (shouldAutoOpen) {
      requestAnimationFrame(() => {
        const anchor = document.getElementById('inquiry');
        if (anchor) anchor.scrollIntoView({ behavior: 'smooth', block: 'start' });
        window.setTimeout(() => {
          setField('package_id', '');
          setField('package_name', '');
          setField('source_page', window.location.pathname);
          const paramService = params.get('service');
          const paramPackage = params.get('package');
          if (paramService) setField('event_type', paramService);
          if (paramPackage) setField('package_id', paramPackage);
          openModal();
        }, 450);
      });
    }
  }

  initContactModal();
  document.addEventListener('astro:after-swap', initContactModal);
</script>

<style>
  .contact-modal {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100dvh;
    margin: 0;
    overflow: hidden;
    color: inherit;
  }

  .contact-modal::backdrop {
    background: rgba(26, 26, 24, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .contact-modal[open] {
    animation: contact-modal-fade var(--duration-page) var(--ease-gallery);
  }

  .contact-modal[open]::backdrop {
    animation: contact-modal-backdrop var(--duration-slow) var(--ease-gallery);
  }

  @keyframes contact-modal-fade {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes contact-modal-backdrop {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .contact-modal-inner {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: 820px;
    margin: 0 auto;
    background: var(--color-background);
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .contact-modal {
      padding: 3rem 1.5rem;
    }
    .contact-modal-inner {
      height: auto;
      max-height: calc(100dvh - 6rem);
    }
  }

  .contact-modal-header {
    position: relative;
    padding: 1.75rem 3.5rem 1.5rem 1.25rem;
    border-bottom: 1px solid rgba(175, 179, 174, 0.15);
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .contact-modal-header {
      padding: 2.5rem 5rem 2rem 3rem;
    }
  }

  .contact-modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1rem;
    padding: 0.5rem;
    color: var(--color-on-surface-variant);
    transition: color var(--duration-hover) var(--ease-gallery);
    cursor: pointer;
    background: transparent;
    border: none;
    line-height: 0;
  }

  @media (min-width: 768px) {
    .contact-modal-close {
      top: 2rem;
      right: 2rem;
    }
  }

  .contact-modal-close:hover,
  .contact-modal-close:focus-visible {
    color: var(--color-on-surface);
    outline: none;
  }

  .contact-modal-body {
    flex: 1;
    overflow-y: auto;
    padding: 2rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-surface-container) var(--color-background);
  }

  @media (min-width: 768px) {
    .contact-modal-body {
      padding: 2.5rem 3rem 3rem;
    }
  }

  body.modal-open {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-modal[open],
    .contact-modal[open]::backdrop {
      animation: none;
    }
  }
</style>
