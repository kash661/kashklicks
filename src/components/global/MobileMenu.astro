---
import navigation from '../../data/navigation.json';
import site from '../../data/site.json';

const currentPath = Astro.url.pathname;

const isActive = (item: { href: string; children?: { href: string }[] }) =>
  currentPath.startsWith(item.href) ||
  (item.children?.some((c) => currentPath.startsWith(c.href)) ?? false);

const pad = (n: number) => String(n).padStart(2, '0');

// Mobile-only menu: fold "About" under "Resources" and drop the standalone About entry
const mobileItems = navigation.items
  .filter((item) => item.href !== '/about')
  .map((item) => {
    if (item.label === 'Resources') {
      return {
        ...item,
        children: [...(item.children ?? []), { label: 'About', href: '/about' }],
      };
    }
    return item;
  });
---

<div
  id="mobile-menu"
  class="fixed inset-0 z-40 lg:hidden invisible"
  role="dialog"
  aria-label="Mobile navigation menu"
  aria-modal="true"
>
  <!-- Backdrop -->
  <div
    id="mobile-menu-backdrop"
    class="absolute inset-0 bg-on-surface/30 opacity-0 cubic-ease"
    style="transition-duration: var(--duration-slow);"
  ></div>

  <!-- Sliding panel -->
  <div
    id="mobile-menu-panel"
    class="relative h-full w-[92%] max-w-[480px] bg-background overflow-y-auto shadow-ambient"
    style="transform: translateX(-100%); transition: transform var(--duration-slow) var(--ease-gallery);"
  >
    <nav aria-label="Mobile navigation" class="flex flex-col min-h-full px-7 pt-20 pb-8">
      <p class="text-label-sm text-on-surface-muted eyebrow-rule revealed mb-6">
        The Studio — 2026
      </p>

      <ul class="menu-list">
        {mobileItems.map((item, idx) => (
          <li class:list={['menu-item', idx > 0 && 'menu-item-divided']}>
            <div class="flex items-baseline gap-4">
              <span class="menu-index text-label-sm text-on-surface-muted tabular-nums">{pad(idx + 1)}</span>
              <a
                href={item.href}
                class:list={[
                  'text-heading-md cubic-ease',
                  currentPath === item.href && 'menu-link-active',
                  isActive(item) ? 'text-on-surface font-semibold' : 'text-on-surface-variant hover:text-on-surface',
                ]}
                style="transition-duration: var(--duration-hover);"
                aria-current={isActive(item) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </div>
            {item.children && (
              <ul class="mt-2 ml-10 space-y-1">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={child.href}
                      class:list={[
                        'text-label-sm cubic-ease inline-block whitespace-nowrap',
                        currentPath === child.href && 'menu-link-active',
                        currentPath === child.href
                          ? 'text-on-surface font-semibold'
                          : 'text-on-surface-variant hover:text-on-surface',
                      ]}
                      style="transition-duration: var(--duration-hover);"
                      aria-current={currentPath === child.href ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>

      <a
        href="/contact"
        class="mt-8 block w-full text-center px-6 py-4 bg-primary text-on-dark text-label-md hover:bg-primary-hover cubic-ease"
        style="transition-duration: var(--duration-hover);"
      >
        Contact Me
      </a>

      <div class="mt-auto pt-8">
        <div class="h-px w-full bg-on-surface/10 mb-5"></div>
        <div class="flex items-center justify-between gap-4">
          <p class="text-quote italic text-on-surface-variant" style="font-size: 1rem; line-height: 1.2;">
            Moments fade.<br/>Memories don't.
          </p>
          <ul class="flex flex-col items-end gap-1 shrink-0">
            <li><a href={site.social.instagram} class="text-label-sm text-on-surface-variant hover:text-on-surface cubic-ease" target="_blank" rel="noopener">Instagram</a></li>
            <li><a href={site.social.pinterest} class="text-label-sm text-on-surface-variant hover:text-on-surface cubic-ease" target="_blank" rel="noopener">Pinterest</a></li>
            <li><a href={site.social.youtube} class="text-label-sm text-on-surface-variant hover:text-on-surface cubic-ease" target="_blank" rel="noopener">YouTube</a></li>
          </ul>
        </div>
      </div>
    </nav>
  </div>
</div>

<style>
  .menu-open {
    visibility: visible !important;
  }
  .menu-open #mobile-menu-backdrop {
    opacity: 1;
  }
  .menu-open #mobile-menu-panel {
    transform: translateX(0) !important;
  }

  .menu-list {
    display: flex;
    flex-direction: column;
  }
  .menu-item {
    position: relative;
    padding-block: 0.75rem;
  }
  .menu-item-divided {
    border-top: 1px solid color-mix(in srgb, var(--color-on-surface) 10%, transparent);
  }
  .menu-link-active {
    position: relative;
  }
  .menu-link-active::before {
    content: '';
    position: absolute;
    left: -0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 0.9em;
    background: currentColor;
  }
  .menu-index {
    font-variant-numeric: tabular-nums;
    min-width: 1.5rem;
  }
</style>
