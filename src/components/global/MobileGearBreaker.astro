---
// src/components/global/MobileGearBreaker.astro
// Mobile gear differentiator. Narrow-viewport tree. Uses pure CSS sticky
// for stacked-card scroll — each card is `position: sticky; top: 0`, later
// cards cover earlier ones as the deck scrolls. Zero JS, zero scroll-hijack.
// Active below min-width: 1024px.
//
// Styled to match the Recent Work gallery-plaque vocabulary: cream stock,
// single champagne hairline beneath each photo, caption beneath like a
// museum wall label. No oversized outlined numerals.
import { Image } from 'astro:assets';
import gear from '../../data/gear.json';

import cardImage01 from '../../assets/images/gear/01-sony.jpg';
import cardImage02 from '../../assets/images/gear/02-fujifilm.jpg';
import cardImage03 from '../../assets/images/gear/03-canon.jpg';
import cardImage04 from '../../assets/images/gear/04-sony-compact.jpg';

const imageMap: Record<string, { src: ImageMetadata; alt: string }> = {
  '01': {
    src: cardImage01,
    alt: 'Editorial gallery frame shot on Sony mirrorless, Toronto wedding photography',
  },
  '02': {
    src: cardImage02,
    alt: 'Fujifilm film-simulation frame with warm Classic Chrome tones and soft grain',
  },
  '03': {
    src: cardImage03,
    alt: 'Vintage Canon point-and-shoot candid with soft flash and disposable-camera feel',
  },
  '04': {
    src: cardImage04,
    alt: 'Candid bridesmaid-angle frame shot on a handheld Sony compact camera',
  },
};

const plates = ['Plate I', 'Plate II', 'Plate III', 'Plate IV'];
const total = gear.length;
---

<section class="gear-stack-m" aria-label="The cameras I shoot with">
  <header class="gear-stack-m__intro">
    <p class="text-label-sm text-on-surface-muted eyebrow-rule eyebrow-rule-center reveal mb-5">The Kit</p>
    <h2 class="reveal stagger-1 gear-stack-m__head">Four cameras.<br />Four looks.<br />One day.</h2>
    <p class="reveal stagger-2 gear-stack-m__lede">
      Most shooters bring one camera. I bring four, so you walk away with four distinct looks from the same day: the polished gallery, the film-grain nostalgia, the throwback candids, and the off-the-cuff shots from your crew.
    </p>
  </header>

  <div class="gear-stack-m__deck">
    {gear.map((item, i) => {
      const img = imageMap[item.num];
      return (
        <article class={`gear-card ${img ? 'gear-card--hasMedia' : ''}`} data-i={i + 1}>
          {img && (
            <figure class="gear-card__media">
              <Image
                src={img.src}
                alt={img.alt}
                class="gear-card__img"
                widths={[480, 720, 960]}
                sizes="100vw"
                quality={78}
                format="avif"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </figure>
          )}
          <div class="gear-card__inner">
            <div class="gear-card__plate-line">
              <span class="gear-card__plate">{plates[i]}</span>
              <span class="gear-card__plate-rule"></span>
              <span class="gear-card__label">{item.camera}</span>
            </div>
            <h3 class="gear-card__role">{item.role}</h3>
            <p class="gear-card__desc">{item.description}</p>
            <p class="gear-card__progress" aria-hidden="true">0{i + 1} &mdash; 0{total}</p>
          </div>
        </article>
      );
    })}
  </div>
</section>

<style>
  .gear-stack-m {
    background: var(--color-surface-dim);
    color: var(--color-on-surface);
    position: relative;
  }

  .gear-stack-m::before,
  .gear-stack-m::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: min(calc(100% - 2rem), 720px);
    height: 1px;
    background: linear-gradient(to right,
      transparent,
      color-mix(in srgb, var(--color-on-surface-variant) 40%, transparent) 18%,
      color-mix(in srgb, var(--color-on-surface-variant) 40%, transparent) 82%,
      transparent);
    pointer-events: none;
    z-index: 2;
  }
  .gear-stack-m::before { top: 0; }
  .gear-stack-m::after  { bottom: 0; }

  .gear-stack-m__intro {
    padding: clamp(4rem, 12vw, 6rem) 1.5rem clamp(2.5rem, 8vw, 4rem);
    text-align: center;
    max-width: 44ch;
    margin-inline: auto;
    position: relative;
    z-index: 1;
  }

  .gear-stack-m__head {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2rem, 9vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-on-surface);
  }

  .gear-stack-m__lede {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-style: italic;
    font-weight: 400;
    line-height: 1.6;
    max-width: 38ch;
    margin-inline: auto;
    margin-top: 1.25rem;
    color: var(--color-on-surface-variant);
  }

  /* The deck: cards stack via position: sticky. Each card sticks at top: 0
     with height 100svh. Later cards cover earlier ones via source order.
     Pure CSS stacking — no JS, no pin, native scroll. */
  .gear-stack-m__deck {
    position: relative;
  }

  .gear-card {
    position: sticky;
    top: 0;
    height: 100svh;
    min-height: 620px;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    padding: clamp(3rem, 9vh, 4.5rem) 1.5rem clamp(2rem, 6vh, 3rem);
    background: var(--color-surface-dim);
    gap: clamp(1.25rem, 3vh, 1.75rem);
  }

  .gear-card__media {
    margin: 0;
    width: 100%;
    height: clamp(260px, 42svh, 360px);
    overflow: hidden;
  }
  .gear-card__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gear-card--hasMedia {
    padding-top: clamp(2rem, 6vh, 3rem);
  }

  /* Caption beneath the photograph — single champagne hairline rule, then
     plate label + camera name on one line, role heading, description. */
  .gear-card__inner {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-width: 32rem;
    width: 100%;
    text-align: left;
    padding-top: 1.25rem;
    border-top: 1px solid color-mix(in srgb, var(--color-on-surface-variant) 42%, transparent);
  }

  .gear-card__plate-line {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
  }

  .gear-card__plate {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--color-on-surface);
    flex-shrink: 0;
  }

  .gear-card__plate-rule {
    width: 1.25rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-on-surface-variant) 55%, transparent);
    flex-shrink: 0;
  }

  .gear-card__label {
    flex: 1;
    min-width: 0;
  }

  .gear-card__role {
    margin: 0.15rem 0 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.5rem, 6vw, 1.875rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-on-surface);
  }

  .gear-card__desc {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-on-surface-variant);
    max-width: 34ch;
  }

  .gear-card__progress {
    margin: 1.5rem 0 0;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-on-surface-muted);
  }

  /* Hidden on desktop — GearBreaker.astro handles 1024px+ */
  @media (min-width: 1024px) {
    .gear-stack-m { display: none !important; }
  }
</style>
