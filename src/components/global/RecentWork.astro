---
// src/components/global/RecentWork.astro
// Desktop Recent Work — minimal editorial treatment on the brand's
// warm-charcoal stock. The hairlines do one job only: frame and
// elevate the photograph (matted-print mounting). No numerals, no
// column grid, no corner ticks, no spec strip. The photos carry the
// section. Active at min-width: 1024px; MobileRecentWork handles below.
import { Image } from 'astro:assets';

import recentWide from '../../assets/images/portfolio/meghna-puneeth/06.jpg';
import recentPortraitLeft from '../../assets/images/homepage/homepage-03.jpg';
import recentPortraitRight from '../../assets/images/homepage/homepage-02.jpg';
---

<section class="rw py-[var(--spacing-section)] bg-surface-dark relative overflow-hidden">
  <div class="container-editorial relative">
    <div class="rw__runhead reveal" aria-hidden="true">
      <span class="rw__runhead-rule"></span>
      <span class="rw__runhead-text">Volume V &nbsp;·&nbsp; Edition MMXXVI</span>
      <span class="rw__runhead-rule"></span>
    </div>

    <div class="grid-editorial items-end rw__intro">
      <div class="col-span-12 md:col-span-7 reveal">
        <p class="text-label-md text-on-dark-variant eyebrow-rule eyebrow-rule-on-dark mb-6">Recent Work</p>
        <h2 class="rw__title text-on-dark" data-gsap-chars>Stories from the last few months.</h2>
      </div>
      <div class="col-span-12 md:col-span-5 md:col-start-8 mt-6 md:mt-0 reveal stagger-2">
        <p class="rw__deck text-on-dark/75">
          A few recent afternoons with couples who trusted me with their day.
        </p>
      </div>
    </div>

    <article class="rw__story rw__story--feature reveal">
      <header class="rw__meta">
        <span class="rw__plate">Plate I</span>
        <span class="rw__meta-dot">·</span>
        <span>Toronto, Harbourfront</span>
        <span class="rw__meta-dot">·</span>
        <span>Autumn 2025</span>
      </header>
      <div class="rw__mat">
        <a href="/portfolio/meghna-puneeth" class="rw__frame gallery-frame hover-zoom scale-reveal mx-auto !w-full image-caption block group relative" data-caption="Meghna & Puneeth, Toronto" aria-label="View the Meghna and Puneeth album and film">
          <span class="rw__badge">
            <svg width="9" height="9" viewBox="0 0 9 9" fill="currentColor" aria-hidden="true"><path d="M1.5 0.5l7 4-7 4z" /></svg>
            Film
          </span>
          <Image
            src={recentWide}
            alt="Candid pre-wedding photography at Toronto Harbourfront, Meghna and Puneeth"
            class="parallax-img !w-full !max-h-none aspect-[16/9] object-cover"
            widths={[960, 1440, 1920]}
            sizes="90vw"
            quality={80}
          />
        </a>
      </div>
      <footer class="rw__cap">
        <div>
          <p class="rw__couple">Meghna <em>&amp;</em> Puneeth</p>
          <p class="rw__sub">Pre-wedding film</p>
        </div>
        <a href="/portfolio/meghna-puneeth" class="rw__view" aria-label="View Meghna and Puneeth's story">
          View Story <span aria-hidden="true">&rarr;</span>
        </a>
      </footer>
    </article>
  </div>

  <div class="grid-editorial relative rw__pair">
    <article class="rw__story col-span-12 md:col-span-5 reveal-left">
      <header class="rw__meta">
        <span class="rw__plate">Plate II</span>
        <span class="rw__meta-dot">·</span>
        <span>Toronto</span>
        <span class="rw__meta-dot">·</span>
        <span>Summer 2025</span>
      </header>
      <div class="rw__mat">
        <a href="/portfolio" class="rw__frame gallery-frame hover-zoom !w-full block group" aria-label="Browse the full portfolio">
          <Image
            src={recentPortraitLeft}
            alt="Pre-wedding portrait session, Swathi and Saksham in Toronto"
            class="parallax-img !w-full !max-h-none aspect-[3/4] object-cover"
            widths={[640, 960]}
            sizes="42vw"
            quality={80}
          />
        </a>
      </div>
      <footer class="rw__cap">
        <div>
          <p class="rw__couple">Swathi <em>&amp;</em> Saksham</p>
          <p class="rw__sub">Pre-wedding portraits</p>
        </div>
        <a href="/portfolio" class="rw__view" aria-label="Browse the full portfolio">
          View Story <span aria-hidden="true">&rarr;</span>
        </a>
      </footer>
    </article>

    <article class="rw__story col-span-12 md:col-span-5 md:col-start-7 mt-12 md:mt-24 reveal-right stagger-2">
      <header class="rw__meta">
        <span class="rw__plate">Plate III</span>
        <span class="rw__meta-dot">·</span>
        <span>Italy</span>
        <span class="rw__meta-dot">·</span>
        <span>Spring 2026</span>
      </header>
      <div class="rw__mat">
        <a href="/portfolio/nora-ali" class="rw__frame gallery-frame hover-zoom !w-full block group" aria-label="View the Nora and Ali album">
          <Image
            src={recentPortraitRight}
            alt="Destination wedding portrait in Italy, Nora and Ali"
            class="parallax-img !w-full !max-h-none aspect-[3/4] object-cover"
            widths={[640, 960]}
            sizes="42vw"
            quality={80}
          />
        </a>
      </div>
      <footer class="rw__cap">
        <div>
          <p class="rw__couple">Nora <em>&amp;</em> Ali</p>
          <p class="rw__sub">Destination wedding</p>
        </div>
        <a href="/portfolio/nora-ali" class="rw__view" aria-label="View Nora and Ali's story">
          View Story <span aria-hidden="true">&rarr;</span>
        </a>
      </footer>
    </article>
  </div>

  <div class="container-editorial relative mt-[var(--spacing-block)]">
    <div class="rw__runfoot reveal">
      <span class="rw__runfoot-rule"></span>
      <a href="/portfolio" class="rw__runfoot-link magnetic">
        Continue to the full portfolio <span aria-hidden="true">&rarr;</span>
      </a>
      <span class="rw__runfoot-rule"></span>
    </div>
  </div>
</section>

<style>
  .rw {
    isolation: isolate;
    color: var(--color-on-dark);
    background:
      radial-gradient(ellipse at top,
        color-mix(in srgb, var(--color-on-dark) 5%, var(--color-surface-dark)) 0%,
        var(--color-surface-dark) 60%),
      var(--color-surface-dark);
  }

  /* Runhead — thin centred rule with era text */
  .rw__runhead {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: var(--spacing-block);
  }

  .rw__runhead-rule {
    flex: 1;
    height: 1px;
    background: color-mix(in srgb, var(--color-on-dark-variant) 40%, transparent);
  }

  .rw__runhead-text {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-on-dark-variant);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Intro */
  .rw__intro {
    margin-bottom: var(--spacing-block);
  }

  .rw__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(3rem, 6.8vw, 6.5rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    max-width: 18ch;
  }

  .rw__deck {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 1.6vw, 1.5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: -0.005em;
    max-width: 34ch;
  }

  .rw__story {
    position: relative;
  }

  /* Meta — a single quiet caption line above the matted frame */
  .rw__meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-on-dark-variant);
  }

  .rw__plate {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    letter-spacing: 0.04em;
    color: var(--color-on-dark);
    text-transform: none;
  }

  .rw__meta-dot {
    font-style: normal;
    color: color-mix(in srgb, var(--color-on-dark-variant) 60%, transparent);
    text-transform: none;
  }

  /* Mat — the one structural hairline. A thin champagne border with
     generous padding creates a "matted print" mount around the photo.
     This is the element that makes every image feel framed and hung. */
  .rw__mat {
    padding: clamp(14px, 1.4vw, 22px);
    border: 1px solid color-mix(in srgb, var(--color-on-dark-variant) 35%, transparent);
    transition: border-color var(--duration-hover) var(--ease-gallery);
  }

  .rw__mat:has(.rw__frame:hover) {
    border-color: color-mix(in srgb, var(--color-on-dark-variant) 65%, transparent);
  }

  .rw__frame {
    display: block;
  }

  .rw__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.8rem;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-on-dark);
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  /* Caption — a restrained single-row footer beneath the mat */
  .rw__cap {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .rw__couple {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 2.4vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--color-on-dark);
    margin: 0;
  }

  .rw__couple em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-on-dark-variant);
    margin: 0 0.1em;
  }

  .rw__sub {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-on-dark-variant);
    margin: 0.75rem 0 0;
  }

  .rw__view {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-on-dark-variant);
    white-space: nowrap;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-on-dark-variant) 45%, transparent);
    transition: color var(--duration-hover) var(--ease-gallery),
                border-color var(--duration-hover) var(--ease-gallery);
  }

  .rw__view span {
    display: inline-block;
    margin-left: 0.5rem;
    transition: transform var(--duration-hover) var(--ease-gallery);
  }

  .rw__view:hover {
    color: var(--color-on-dark);
    border-color: var(--color-on-dark);
  }

  .rw__view:hover span { transform: translateX(4px); }

  /* Runfoot — centred portfolio link between two hairlines */
  .rw__runfoot {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .rw__runfoot-rule {
    flex: 1;
    height: 1px;
    background: color-mix(in srgb, var(--color-on-dark-variant) 40%, transparent);
  }

  .rw__runfoot-link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-on-dark);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color var(--duration-hover) var(--ease-gallery);
  }

  .rw__runfoot-link span {
    display: inline-block;
    margin-left: 0.5rem;
    transition: transform var(--duration-hover) var(--ease-gallery);
  }

  .rw__runfoot-link:hover { color: var(--color-on-dark-variant); }
  .rw__runfoot-link:hover span { transform: translateX(4px); }

  /* Hidden on narrow viewports — MobileRecentWork handles those */
  @media (max-width: 1023px) {
    .rw { display: none !important; }
  }
</style>
