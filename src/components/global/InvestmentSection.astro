---
/**
 * InvestmentSection
 * -----------------
 * Homepage investment/pricing block. Two self-contained DOM trees —
 * desktop and mobile — toggled with responsive visibility utilities.
 * Each tree is authored for exactly one breakpoint and does not share
 * layout utilities with the other. Editing one cannot affect the other.
 */
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';

interface Props {
  image: ImageMetadata;
  imageAlt: string;
}

const { image, imageAlt } = Astro.props;
---

{/* ═══════════════════════════════════════════════
    DESKTOP (md+): side-by-side image + text grid
    ═══════════════════════════════════════════════ */}
<section class="investment-desktop hidden md:block py-[var(--spacing-section)] bg-surface-dim">
  <div class="grid-editorial items-center">
    <div class="md:col-span-6 gallery-frame reveal-left image-caption" data-caption="Full-Day Coverage">
      <Image
        src={image}
        alt={imageAlt}
        class="parallax-img"
        widths={[640, 960, 1280]}
        sizes="50vw"
        quality={80}
      />
    </div>
    <div class="md:col-span-5 md:col-start-8 reveal-right stagger-2">
      <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">Investment</p>
      <h2 class="text-display-md text-on-surface mb-8">Wedding Packages</h2>
      <p class="text-label-md text-on-surface-muted mb-2">Starting at</p>
      <p class="text-display-lg italic text-on-surface mb-10">$1,200</p>
      <p class="text-body-lg text-on-surface-variant mb-10">
        Every package includes a pre-shoot consultation, professionally edited images, and a private online gallery.
      </p>
      <div class="investment-desktop__ctas">
        <Button href="/services/wedding" variant="primary">Wedding Packages</Button>
        <a href="/services" class="investment-desktop__link">
          View all packages <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

{/* ═══════════════════════════════════════════════
    MOBILE (< md): image hook + three category rows
    ═══════════════════════════════════════════════ */}
<section class="investment-mobile md:hidden py-[var(--spacing-section)] bg-surface-dim">
  <div class="container-editorial">
    <div class="gallery-frame reveal-left image-caption mb-12" data-caption="Full-Day Coverage">
      <Image
        src={image}
        alt={imageAlt}
        class="parallax-img w-full"
        widths={[480, 640, 960]}
        sizes="100vw"
        quality={85}
      />
    </div>

    <div class="reveal stagger-2">
      <p class="text-label-md text-on-surface-muted mb-6 eyebrow-rule">Investment</p>
      <h2 class="text-display-md text-on-surface mb-10">Our Packages</h2>

      <div class="investment-mobile__list">
        <a href="/services/wedding" class="investment-mobile__row group">
          <div class="investment-mobile__row-body">
            <h3 class="text-heading-md text-on-surface mb-2">Wedding</h3>
            <p class="text-label-md text-on-surface-muted">Starting at $1,200</p>
            <span class="service-sale-tag mt-2">
              <span class="service-sale-dot" aria-hidden="true"></span>
              Limited Offer
            </span>
          </div>
          <span class="investment-mobile__arrow" aria-hidden="true">&rarr;</span>
        </a>

        <a href="/services/pre-wedding" class="investment-mobile__row group">
          <div class="investment-mobile__row-body">
            <h3 class="text-heading-md text-on-surface mb-2">Pre-Wedding</h3>
            <p class="text-label-md text-on-surface-muted">Starting at $350</p>
            <span class="service-sale-tag mt-2">
              <span class="service-sale-dot" aria-hidden="true"></span>
              Limited Offer
            </span>
          </div>
          <span class="investment-mobile__arrow" aria-hidden="true">&rarr;</span>
        </a>

        <a href="/services/civil-ceremony" class="investment-mobile__row investment-mobile__row--last group">
          <div class="investment-mobile__row-body">
            <h3 class="text-heading-md text-on-surface mb-2">Civil Ceremony</h3>
            <p class="text-label-md text-on-surface-muted">Starting at $500</p>
          </div>
          <span class="investment-mobile__arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>

      <p class="text-body-lg text-on-surface-variant mb-10">
        Every package includes a personal consultation, carefully edited images, and a private online gallery.
      </p>
      <Button href="/services" variant="primary">View All Packages</Button>
    </div>
  </div>
</section>

<style>
  /* ── Desktop CTA row ──────────────────────────── */
  .investment-desktop__ctas {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .investment-desktop__link {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-on-surface-muted);
    white-space: nowrap;
    transition: color var(--duration-hover) var(--ease-gallery);
  }

  .investment-desktop__link:hover {
    color: var(--color-on-surface);
  }

  .investment-desktop__link span {
    display: inline-block;
    transition: transform var(--duration-hover) var(--ease-gallery);
  }

  .investment-desktop__link:hover span {
    transform: translateX(4px);
  }

  /* ── Mobile package list ──────────────────────── */
  .investment-mobile__list {
    border-top: 1px solid color-mix(in srgb, var(--color-on-surface-muted) 25%, transparent);
    margin-bottom: 2.5rem;
  }

  .investment-mobile__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-on-surface-muted) 25%, transparent);
    transition: background-color var(--duration-hover) var(--ease-gallery);
  }

  .investment-mobile__row--last {
    border-bottom: none;
  }

  .investment-mobile__row-body {
    flex: 1;
    min-width: 0;
  }

  .investment-mobile__arrow {
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-on-surface-muted);
    transition: transform var(--duration-hover) var(--ease-gallery),
                color var(--duration-hover) var(--ease-gallery);
  }

  .investment-mobile__row:active .investment-mobile__arrow,
  .investment-mobile__row:hover .investment-mobile__arrow {
    transform: translateX(4px);
    color: var(--color-on-surface);
  }
</style>
