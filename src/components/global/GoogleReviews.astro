---
import { Image } from 'astro:assets';
import googleReviews from '../../data/google-reviews.json';
import portfolio from '../../data/portfolio.json';

const { aggregate, reviews } = googleReviews;

// Editorial curation: longest, most evocative review leads;
// a short, punchy review fills the asymmetric secondary slot;
// three standard entries close the spread.
const lead = reviews[2] ?? reviews[0];          // Amit Chawla — most cinematic
const secondary = reviews[6] ?? reviews[3];     // Shubha Kaushik — short + punchy
const standard = [reviews[0], reviews[1], reviews[3]].filter(Boolean);

// Resolve secondary review's album image (if linked to a portfolio entry).
const portfolioImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/portfolio/**/*.{jpg,jpeg,png,webp,avif}',
  { eager: true }
);

let secondaryAlbum: { href: string; image: ImageMetadata; alt: string; caption: string } | null = null;
if (secondary?.albumSlug) {
  const entry = portfolio.find((p) => (p.slug ?? p.id) === secondary.albumSlug);
  if (entry) {
    const cover =
      portfolioImages[`/src/assets/images/portfolio/${entry.id}/${entry.coverImage}`]?.default ||
      portfolioImages[`/src/assets/images/portfolio/${entry.coverImage}`]?.default ||
      portfolioImages[`/src/assets/images/portfolio/${entry.id}/01.jpg`]?.default;
    if (cover) {
      secondaryAlbum = {
        href: `/portfolio/${entry.slug ?? entry.id}`,
        image: cover,
        alt: `${entry.couple}, ${entry.location} — pre-wedding photography by AD Photography`,
        caption: `View ${entry.couple.split('+')[0].trim()}'s gallery`,
      };
    }
  }
}
---

<section class="google-reviews" aria-labelledby="google-reviews-heading">
  <div class="container-editorial">
    <header class="google-reviews__header">
      <div class="google-reviews__header-lead reveal">
        <p class="text-label-md text-on-surface-muted eyebrow-rule mb-6">Reviews on Google</p>
        <h2 id="google-reviews-heading" class="google-reviews__title">
          Verified words<br /><em>from real couples.</em>
        </h2>
      </div>

      <aside class="google-reviews__aggregate reveal stagger-1" aria-label="Aggregate Google rating">
        <span class="google-reviews__brand" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.99.66-2.25 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.99 10.99 0 0 0 12 23z"/>
            <path fill="#FBBC04" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.07H2.18A11 11 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.83z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A10.99 10.99 0 0 0 2.18 7.07l3.66 2.83C6.71 7.31 9.14 5.38 12 5.38z"/>
          </svg>
          <span>Google</span>
        </span>

        <div class="google-reviews__rating-row">
          <span class="google-reviews__score">{aggregate.rating.toFixed(1)}</span>
          <span class="google-reviews__stars" aria-label={`${aggregate.rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#f9ab00" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </span>
        </div>

        <p class="google-reviews__count">from {aggregate.count} verified reviews</p>
      </aside>
    </header>

    <div class="google-reviews__spread">
      <article class="google-reviews__entry google-reviews__entry--lead reveal">
        <span class="google-reviews__rule" aria-hidden="true"></span>
        <div class="google-reviews__meta">
          <span class="google-reviews__name">{lead.name}</span>
          <span class="google-reviews__dot" aria-hidden="true">·</span>
          <span class="google-reviews__date">{lead.date}</span>
        </div>
        <blockquote class="google-reviews__quote google-reviews__quote--lead">
          <span class="google-reviews__open" aria-hidden="true">&ldquo;</span>{lead.text}
        </blockquote>
        <span class="google-reviews__entry-stars" aria-label={`${lead.rating} out of 5 stars`}>
          {Array.from({ length: lead.rating }).map(() => (
            <svg width="13" height="13" viewBox="0 0 24 24" fill="#f9ab00" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </span>
      </article>

      <article class="google-reviews__entry google-reviews__entry--secondary reveal stagger-1">
        <span class="google-reviews__rule" aria-hidden="true"></span>
        <div class="google-reviews__meta">
          <span class="google-reviews__name">{secondary.name}</span>
          <span class="google-reviews__dot" aria-hidden="true">·</span>
          <span class="google-reviews__date">{secondary.date}</span>
        </div>

        {secondaryAlbum && (
          <a
            href={secondaryAlbum.href}
            class="google-reviews__album hover-zoom image-caption"
            data-caption={secondaryAlbum.caption}
            aria-label={secondaryAlbum.caption}
          >
            <Image
              src={secondaryAlbum.image}
              alt={secondaryAlbum.alt}
              widths={[480, 720, 960]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              loading="lazy"
              decoding="async"
            />
          </a>
        )}

        <blockquote class="google-reviews__quote google-reviews__quote--pull">
          {secondary.text}
        </blockquote>
        <span class="google-reviews__entry-stars" aria-label={`${secondary.rating} out of 5 stars`}>
          {Array.from({ length: secondary.rating }).map(() => (
            <svg width="13" height="13" viewBox="0 0 24 24" fill="#f9ab00" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </span>
      </article>

      {standard.map((review, i) => (
        <article class={`google-reviews__entry google-reviews__entry--row reveal stagger-${i + 1}`}>
          <span class="google-reviews__rule" aria-hidden="true"></span>
          <div class="google-reviews__meta">
            <span class="google-reviews__name">{review.name}</span>
            <span class="google-reviews__dot" aria-hidden="true">·</span>
            <span class="google-reviews__date">{review.date}</span>
          </div>
          <blockquote class="google-reviews__quote">{review.text}</blockquote>
          <span class="google-reviews__entry-stars" aria-label={`${review.rating} out of 5 stars`}>
            {Array.from({ length: review.rating }).map(() => (
              <svg width="12" height="12" viewBox="0 0 24 24" fill="#f9ab00" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </span>
        </article>
      ))}
    </div>

    <div class="google-reviews__footer reveal">
      <a
        href={aggregate.profileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="google-reviews__cta magnetic"
        aria-label={`Read all ${aggregate.count} reviews on Google in a new tab`}
      >
        Read all reviews on Google <span aria-hidden="true">&rarr;</span>
      </a>
      <span class="google-reviews__divider" aria-hidden="true"></span>
      <a
        href={aggregate.writeReviewUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="google-reviews__cta google-reviews__cta--secondary"
      >
        Leave a review <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
  .google-reviews {
    background: var(--color-background);
    color: var(--color-on-surface);
    padding-top: var(--spacing-section);
    padding-bottom: var(--spacing-section);
  }

  /* ── Header: asymmetric split ────────────────────────────────── */
  .google-reviews__header {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 1fr);
    align-items: end;
    column-gap: 4rem;
    row-gap: 2.5rem;
    margin-bottom: clamp(3.5rem, 7vw, 6rem);
  }

  .google-reviews__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 5.2vw, 4.25rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-on-surface);
    margin: 0;
  }

  .google-reviews__title em {
    font-style: italic;
    font-weight: 400;
    color: var(--color-on-surface-variant);
  }

  .google-reviews__aggregate {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.625rem;
    padding-bottom: 0.5rem;
  }

  .google-reviews__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
  }

  .google-reviews__brand span { line-height: 1; }

  .google-reviews__rating-row {
    display: inline-flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .google-reviews__score {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-on-surface);
  }

  .google-reviews__stars {
    display: inline-flex;
    gap: 0.18rem;
    transform: translateY(-2px);
  }

  .google-reviews__count {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--color-on-surface-variant);
    margin: 0;
  }

  /* ── Spread: 12-col asymmetric editorial grid ────────────────── */
  .google-reviews__spread {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: clamp(1.5rem, 3vw, 3rem);
    row-gap: clamp(3rem, 6vw, 5rem);
  }

  .google-reviews__entry {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
  }

  .google-reviews__entry--lead     { grid-column: 1 / span 7; }
  .google-reviews__entry--secondary { grid-column: 9 / span 4; }
  .google-reviews__entry--row      { grid-column: span 4; }

  /* Hairline accent — echoes the editorial eyebrow-rule language */
  .google-reviews__rule {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--color-on-surface);
    opacity: 0.45;
  }

  .google-reviews__meta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
    font-family: var(--font-sans);
  }

  .google-reviews__name {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-on-surface);
  }

  .google-reviews__dot {
    color: var(--color-on-surface-muted);
    line-height: 1;
  }

  .google-reviews__date {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-on-surface-variant);
    font-style: italic;
    font-family: var(--font-serif);
  }

  /* ── Quote — sans for readability, serif accents around it ───── */
  .google-reviews__quote {
    font-family: var(--font-sans);
    font-weight: 400;
    color: var(--color-on-surface);
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    letter-spacing: 0;
    text-wrap: pretty;
  }

  .google-reviews__quote--lead {
    font-size: clamp(1.125rem, 1.4vw, 1.375rem);
    line-height: 1.55;
    font-weight: 400;
    color: var(--color-on-surface);
  }

  .google-reviews__quote--pull {
    /* short pull-quote stays serif italic — it reads as a poetic beat, not body */
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 1.5vw, 1.5rem);
    line-height: 1.5;
    letter-spacing: 0.005em;
    color: var(--color-on-surface);
  }

  .google-reviews__open {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 3em;
    line-height: 0;
    color: var(--color-on-surface-muted);
    margin-right: 0.12em;
    vertical-align: -0.32em;
  }

  .google-reviews__entry-stars {
    display: inline-flex;
    gap: 0.125rem;
    margin-top: 0.25rem;
    opacity: 0.85;
  }

  /* ── Album link on the secondary entry ───────────────────────── */
  .google-reviews__album {
    display: block;
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-surface-container);
    margin: 0.25rem 0 0.5rem;
  }

  .google-reviews__album :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Footer CTAs ─────────────────────────────────────────────── */
  .google-reviews__footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: clamp(4rem, 7vw, 6rem);
  }

  .google-reviews__cta {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-on-surface);
    white-space: nowrap;
    transition: color var(--duration-hover) var(--ease-gallery);
    display: inline-flex;
    align-items: center;
  }

  .google-reviews__cta span {
    display: inline-block;
    margin-left: 0.55rem;
    transition: transform var(--duration-hover) var(--ease-gallery);
  }

  .google-reviews__cta:hover { color: var(--color-on-surface-variant); }
  .google-reviews__cta:hover span { transform: translateX(4px); }

  .google-reviews__cta--secondary { color: var(--color-on-surface-variant); }

  .google-reviews__divider {
    width: 1px;
    height: 1.25rem;
    background: color-mix(in srgb, var(--color-on-surface-variant) 35%, transparent);
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .google-reviews__header {
      grid-template-columns: 1fr;
      align-items: start;
      row-gap: 1.75rem;
    }
    .google-reviews__entry--lead      { grid-column: 1 / -1; }
    .google-reviews__entry--secondary { grid-column: 1 / span 6; }
    .google-reviews__entry--row       { grid-column: span 6; }
  }

  @media (max-width: 640px) {
    .google-reviews__entry--lead,
    .google-reviews__entry--secondary,
    .google-reviews__entry--row {
      grid-column: 1 / -1;
    }
    .google-reviews__quote--lead { font-size: 1.375rem; }
    .google-reviews__quote--pull { font-size: 1.25rem; }
    .google-reviews__quote { font-size: 1.0625rem; }
    .google-reviews__footer {
      flex-direction: column;
      gap: 1rem;
    }
    .google-reviews__divider {
      width: 2rem;
      height: 1px;
    }
  }
</style>
