---
// src/components/global/GearStrip.astro
// Compressed 4-camera summary — horizontal on desktop (1 row), 2x2 on
// mobile. Shares data + imagery with GearBreaker.astro and
// MobileGearBreaker.astro, but drops the long description so it reads as
// a glanceable strip rather than a full section. Drop this into any page
// that needs the "four looks, one day" proof without the full essay.
//
// Pages can override individual tile images (e.g. the wedding service page
// swaps in a wedding-shoot frame for card 01) by passing `imageOverrides`.
import { Image } from 'astro:assets';
import gear from '../../data/gear.json';

import tileImage01 from '../../assets/images/gear/01-sony.jpg';
import tileImage02 from '../../assets/images/gear/02-fujifilm.jpg';
import tileImage03 from '../../assets/images/gear/03-canon.jpg';
import tileImage04 from '../../assets/images/gear/04-sony-compact.jpg';

type TileImage = { src: ImageMetadata; alt: string };

interface Props {
  imageOverrides?: Partial<Record<string, TileImage>>;
}

const { imageOverrides = {} } = Astro.props;

const defaultImageMap: Record<string, TileImage> = {
  '01': {
    src: tileImage01,
    alt: 'Editorial gallery frame shot on Sony mirrorless',
  },
  '02': {
    src: tileImage02,
    alt: 'Fujifilm film-simulation frame with Classic Chrome tones',
  },
  '03': {
    src: tileImage03,
    alt: 'Vintage Canon point-and-shoot candid',
  },
  '04': {
    src: tileImage04,
    alt: 'Candid frame shot on a handheld Sony compact',
  },
};

const imageMap = { ...defaultImageMap, ...imageOverrides };
---

<section class="gear-strip" aria-label="The cameras I shoot with">
  <div class="gear-strip__intro">
    <p class="text-label-sm text-on-dark-variant eyebrow-rule eyebrow-rule-center eyebrow-rule-on-dark reveal mb-4">The Kit</p>
    <h2 class="text-heading-lg text-on-dark reveal stagger-1 gear-strip__head">Four cameras. Four looks. One day.</h2>
  </div>

  <ol class="gear-strip__grid" role="list">
    {gear.map((item, i) => {
      const img = imageMap[item.num];
      return (
        <li class="gear-tile reveal" style={`transition-delay: ${i * 90}ms`}>
          <figure class="gear-tile__media" aria-hidden="true">
            {img && (
              <Image
                src={img.src}
                alt={img.alt}
                class="gear-tile__img"
                widths={[320, 480, 640]}
                sizes="(min-width: 1024px) 22vw, 44vw"
                quality={72}
                format="avif"
                loading="lazy"
              />
            )}
          </figure>
          <div class="gear-tile__body">
            <p class="gear-tile__num" aria-hidden="true">{item.num}</p>
            <p class="text-label-sm text-on-dark-variant gear-tile__label">{item.camera}</p>
            <h3 class="text-heading-md text-on-dark gear-tile__role">{item.role}</h3>
          </div>
        </li>
      );
    })}
  </ol>
</section>

<style>
  .gear-strip {
    background: var(--color-surface-dark);
    padding-block: clamp(3rem, 7vw, 5rem);
    padding-inline: clamp(1.5rem, 5vw, 3rem);
  }

  .gear-strip__intro {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 40rem;
    margin-inline: auto;
  }
  .gear-strip__head {
    max-width: 22ch;
    margin-inline: auto;
    line-height: 1.2;
  }

  .gear-strip__grid {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 1400px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  @media (min-width: 1024px) {
    .gear-strip__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .gear-tile {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gear-tile__media {
    margin: 0;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--color-surface-container);
  }
  .gear-tile__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gear-tile__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .gear-tile__num {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.5rem, 2vw, 1.875rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-on-dark-variant);
    opacity: 0.8;
    margin: 0 0 0.15rem;
  }
  .gear-tile__label { margin: 0; }
  .gear-tile__role { margin: 0; line-height: 1.2; }
</style>
