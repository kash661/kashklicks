{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kashklicks",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-17",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  }
}
